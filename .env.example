# ==========================================
# Ortam Değişkenleri (docker-compose için)
# ==========================================
# Bu dosyayı .env.example olarak commit edin.
# Gerçek değerlerle .env dosyası oluşturun.
# .env dosyasını ASLA git'e pushlamayın!

POSTGRES_DB=filistindb
POSTGRES_USER=kanvasuser
POSTGRES_PASSWORD=changeme_in_production

# ==========================================
# Brevo SMTP Mail Ayarları
# ==========================================
# Brevo > SMTP & API sayfasındaki SMTP bilgilerini girin.
# EMAIL_FROM_EMAIL Brevo panelinde doğrulanmış bir gönderici adresi olmalıdır.

EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_ENABLE_SSL=true
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM_EMAIL=
EMAIL_FROM_NAME=7ANRPS48
