@model List<FilistinProje.Core.Varliklar.SepetItem>
@inject FilistinProje.Service.Services.ISiteSettingsService SiteSettingsService
@inject IStringLocalizer<SharedResource> Localizer

@{
    ViewData["Title"] = Localizer["MyCart"];
    var siteSettings = SiteSettingsService.GetSettings();
    var currencySymbol = string.IsNullOrWhiteSpace(siteSettings.ParaBirimi) ? "₪" : siteSettings.ParaBirimi;
    decimal sepetToplami = Model.Sum(x => x.Toplam);
    decimal indirimTutari = (decimal)(ViewBag.IndirimTutari ?? 0);
    decimal ucretsizKargoLimiti = (decimal)(ViewBag.UcretsizKargoLimiti ?? 500);
    decimal kargoBedeli = (decimal)(ViewBag.GosterilecekKargoBedeli ?? 0);
    decimal genelToplam = (decimal)(ViewBag.GenelToplam ?? (sepetToplami - indirimTutari));
}

@functions {
    private static string FormatCartOptionLabel(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        var sections = value
            .Split('|', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .ToList();

        if (!sections.Any())
        {
            return string.Empty;
        }

        var firstParts = sections[0]
            .Split('/', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(x => !IsGenericCartOption(x))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        var cleanSections = new List<string>();

        if (firstParts.Any())
        {
            cleanSections.Add(string.Join(" / ", firstParts));
        }

        cleanSections.AddRange(sections
            .Skip(1)
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Distinct(StringComparer.OrdinalIgnoreCase));

        return string.Join(" | ", cleanSections);
    }

    private static bool IsGenericCartOption(string value)
    {
        var normalized = value.Trim().ToLowerInvariant();
        return normalized is "standart" or "standard" or "varsayilan" or "varsayılan";
    }
}

<!-- Breadcrumb -->
<div class="bg-[#f1ede7] border-b border-[#e5e2dc] py-3">
    <div class="container mx-auto px-4 flex items-center gap-2 text-xs text-[#47473d]">
        <a href="/" class="hover:text-[#313511] transition-colors">@Localizer["HomePage"]</a>
        <span>/</span>
        <span class="text-[#1c1c18] font-medium">@Localizer["MyCart"]</span>
    </div>
</div>

<div class="container mx-auto px-4 py-10">
    <div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div>
            <h1 class="font-serif text-3xl text-[#313511] mb-1">@Localizer["MyCart"]</h1>
            <p class="text-xs text-[#47473d]">@Localizer["ProductCount", Model.Count]</p>
        </div>
        @if (Model.Any())
        {
            <form method="post" action="/Sepet/Temizle" onsubmit="return confirm('@Localizer["ClearCartConfirm"]');">
                @Html.AntiForgeryToken()
                <button type="submit" class="inline-flex items-center justify-center gap-2 rounded-full border border-red-200 bg-white px-4 py-2 text-xs font-semibold uppercase tracking-widest text-red-600 transition-colors hover:border-red-300 hover:bg-red-50">
                    <i class="fas fa-trash-alt text-[11px]"></i>
                    @Localizer["ClearCart"]
                </button>
            </form>
        }
    </div>

    @if (TempData["SepetBasari"] != null)
    {
        <div class="mb-6 rounded-lg border border-[#cbd3a3] bg-[#f7f8ed] px-4 py-3 text-sm text-[#313511]">
            @TempData["SepetBasari"]
        </div>
    }
    @if (TempData["SepetHata"] != null)
    {
        <div class="mb-6 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
            @TempData["SepetHata"]
        </div>
    }

    @if (!Model.Any())
    {
        <div class="text-center py-24">
            <i class="fas fa-shopping-bag fa-4x text-[#e5e2dc] mb-6"></i>
            <h3 class="font-serif text-2xl text-[#313511] mb-3">@Localizer["CartEmpty"]</h3>
            <p class="text-sm text-[#47473d] mb-8 max-w-sm mx-auto">
                @Localizer["ExploreCartEmpty"]
            </p>
            <a href="/Urun" class="inline-block bg-[#313511] text-white px-8 py-3 text-xs tracking-widest uppercase rounded-full hover:bg-[#1c2001] transition-colors">
                @Localizer["StartShopping"]
            </a>
        </div>
    }
    else
    {
        <div class="flex flex-col lg:flex-row gap-8">
            <!-- Ürün Listesi -->
            <div class="flex-1 space-y-4">
                @foreach (var item in Model)
                {
                    var optionLabel = FormatCartOptionLabel(item.SecenekAdi);

                    <article class="bg-white border border-[#e5e2dc] rounded-lg p-4 flex gap-4 relative">
                        <!-- Sil Butonu -->
                        <form method="post" action="/Sepet/Sil" class="absolute end-3 top-3">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="sepetItemId" value="@item.Id" />
                            <button type="submit" class="w-7 h-7 flex items-center justify-center text-gray-400 hover:text-red-500 transition-colors rounded-full hover:bg-red-50" title="@Localizer["RemoveProduct"]">
                                <i class="fas fa-times text-xs"></i>
                            </button>
                        </form>

                        <!-- Ürün Görseli -->
                        <a href="/Urun/Detay/@item.UrunId" class="flex-shrink-0 w-24 h-24 bg-[#f1ede7] rounded overflow-hidden block">
                            <img src="@item.UrunResimUrl" class="w-full h-full object-cover" alt="@item.UrunBaslik" loading="lazy" decoding="async" />
                        </a>

                        <!-- Ürün Bilgisi -->
                        <div class="flex-1 min-w-0 pe-6">
                            <a href="/Urun/Detay/@item.UrunId" class="font-medium text-sm text-[#1c1c18] hover:text-[#b58735] transition-colors line-clamp-2 block mb-1">
                                @item.UrunBaslik
                            </a>
                            @if (!string.IsNullOrWhiteSpace(optionLabel))
                            {
                                <span class="text-xs text-[#47473d] bg-[#f1ede7] px-2 py-0.5 rounded">@optionLabel</span>
                            }
                            @if (item.HediyePaketi)
                            {
                                <span class="inline-flex items-center gap-1 text-[10px] bg-[#313511] text-white font-semibold uppercase tracking-wider rounded-full px-2.5 py-0.5 mt-1">
                                    <i class="fas fa-gift text-[10px]"></i> @Localizer["GiftWrapShort"]
                                </span>
                            }

                            <div class="mt-3">
                                <form method="post" action="/Sepet/NotGuncelle" class="flex flex-col gap-1">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="sepetItemId" value="@item.Id" />
                                    <label class="text-[10px] uppercase tracking-widest text-[#a09e99] font-medium">@Localizer["NoteSpecialRequest"]</label>
                                    <textarea name="musteriNotu"
                                             rows="2"
                                             maxlength="500"
                                             placeholder="@Localizer["NotePlaceholder"]"
                                             class="w-full border border-[#e5e2dc] rounded px-3 py-2 text-xs text-[#1c1c18] bg-[#fcf9f3] focus:ring-1 focus:ring-[#b58735] focus:outline-none resize-none placeholder:text-[#a09e99]">@item.MusteriNotu</textarea>
                                    @if (!string.IsNullOrWhiteSpace(item.MusteriNotu))
                                    {
                                        <div class="rounded border border-[#dfd3ba] bg-[#f7f1e6] px-2 py-1 text-[10px] text-[#47473d]">
                                            @Localizer["SavedNote"] @item.MusteriNotu
                                        </div>
                                    }
                                    <div class="flex items-center justify-between">
                                        <span class="text-[9px] text-[#a09e99]">@Localizer["Max500Chars"]</span>
                                        <button type="submit" class="text-[10px] text-[#b58735] hover:text-[#313511] transition-colors font-medium">
                                            <i class="fas fa-save me-1"></i>@Localizer["Save"]
                                        </button>
                                    </div>
                                </form>
                            </div>

                            <div class="flex items-center justify-between mt-3">
                                <!-- Adet Kontrol -->
                                <div class="flex items-center border border-[#e5e2dc] rounded overflow-hidden">
                                    @if (item.Adet > 1)
                                    {
                                        <form method="post" action="/Sepet/AdetGuncelle">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="sepetItemId" value="@item.Id" />
                                            <input type="hidden" name="yeniAdet" value="@(item.Adet - 1)" />
                                            <button type="submit" class="w-8 h-8 flex items-center justify-center text-[#47473d] hover:bg-[#f1ede7] transition-colors text-xs">
                                                <i class="fas fa-minus"></i>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form method="post" action="/Sepet/Sil">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="sepetItemId" value="@item.Id" />
                                            <button type="submit" class="w-8 h-8 flex items-center justify-center text-red-400 hover:bg-red-50 transition-colors text-xs">
                                                <i class="fas fa-trash-alt"></i>
                                            </button>
                                        </form>
                                    }
                                    <span class="w-8 h-8 flex items-center justify-center text-sm font-medium text-[#1c1c18] border-x border-[#e5e2dc]">@item.Adet</span>
                                    <form method="post" action="/Sepet/AdetGuncelle">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="sepetItemId" value="@item.Id" />
                                        <input type="hidden" name="yeniAdet" value="@(item.Adet + 1)" />
                                        <button type="submit" class="w-8 h-8 flex items-center justify-center text-[#47473d] hover:bg-[#f1ede7] transition-colors text-xs">
                                            <i class="fas fa-plus"></i>
                                        </button>
                                    </form>
                                </div>
                                <!-- Fiyat -->
                                <span class="font-semibold text-[#1c1c18]">@currencySymbol@item.Toplam.ToString("N2")</span>
                            </div>
                        </div>
                    </article>
                }

                @* Tamamlayıcı Ürünler (Cross-Selling) *@
                @if (ViewBag.TamamlayiciUrunler != null && ((List<FilistinProje.Core.Varliklar.Urun>)ViewBag.TamamlayiciUrunler).Any())
                {
                    var tamamlayiciList = (List<FilistinProje.Core.Varliklar.Urun>)ViewBag.TamamlayiciUrunler;
                    <div class="pt-8 mt-12 border-t border-[#e5e2dc]">
                        <h3 class="font-serif text-2xl text-[#313511] mb-6">@Localizer["SpecialSelections"]</h3>
                        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
                            @foreach (var urun in tamamlayiciList)
                            {
                                var defaultSecenek = urun.UrunSecenek?
                                    .OrderByDescending(x => x.VarsayilanMi)
                                    .ThenBy(x => x.Sira)
                                    .FirstOrDefault(x => x.SatinAlinabilirMi)
                                    ?? urun.UrunSecenek?.FirstOrDefault();
                                    
                                var gorsel = !string.IsNullOrWhiteSpace(urun.AnaGorselUrl)
                                    ? urun.AnaGorselUrl
                                    : urun.UrunResimleri?.OrderBy(r => r.Sira).FirstOrDefault()?.ResimYolu;
                                    
                                var urunUrl = "/Urun/Detay/" + (string.IsNullOrEmpty(urun.Slug) ? (FilistinProje.Core.Helpers.SlugHelper.GenerateSlug(urun.Baslik) + "-" + urun.Id) : urun.Slug + "-" + urun.Id);

                                <div class="bg-white border border-[#e5e2dc] rounded-lg p-3 flex flex-col justify-between group">
                                    <div>
                                        <a href="@urunUrl" class="block relative aspect-square overflow-hidden bg-[#f8f6f2] rounded mb-3 flex items-center justify-center p-2">
                                            @if (!string.IsNullOrWhiteSpace(gorsel))
                                            {
                                                <img src="@gorsel" alt="@urun.Baslik" class="max-h-full max-w-full object-contain transition-transform duration-500 group-hover:scale-105" loading="lazy" decoding="async" />
                                            }
                                            else
                                            {
                                                <div class="flex h-full w-full items-center justify-center text-gray-300">
                                                    <i class="fas fa-image fa-2x"></i>
                                                </div>
                                            }
                                        </a>
                                        <a href="@urunUrl" class="block">
                                            <h4 class="text-xs font-semibold tracking-wide text-[#1c1c18] hover:text-[#b58735] transition-colors line-clamp-2 mb-1 min-h-[32px]">@urun.Baslik</h4>
                                        </a>
                                        <p class="text-xs font-medium text-[#47473d] mb-3">@urun.EtkinFiyat.ToString("N0") @currencySymbol</p>
                                    </div>

                                    @if (defaultSecenek != null)
                                    {
                                        <button type="button" onclick="quickAddToCart(@urun.Id, @defaultSecenek.Id)" class="w-full bg-[#f1ede7] text-[#313511] text-[10px] uppercase tracking-widest py-2 rounded hover:bg-[#313511] hover:text-white transition-colors font-medium">
                                            @Localizer["AddToCart"]
                                        </button>
                                    }
                                    else
                                    {
                                        <a href="@urunUrl" class="w-full bg-[#f1ede7] text-[#313511] text-center text-[10px] uppercase tracking-widest py-2 rounded hover:bg-[#313511] hover:text-white transition-colors font-medium">
                                            @Localizer["Review"]
                                        </a>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>

            <script>
                function quickAddToCart(urunId, secenekId) {
                    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
                    const params = new URLSearchParams();
                    params.append('UrunId', urunId);
                    if (secenekId) params.append('SecenekId', secenekId);
                    params.append('Adet', '1');
                    
                    fetch('/Sepet/Ekle?' + params.toString(), {
                        method: 'POST',
                        headers: {
                            'RequestVerificationToken': token
                        }
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            if (window.showToast) {
                                window.showToast('@Localizer["ProductAdded"]', 'success');
                            }
                            setTimeout(() => {
                                window.location.reload();
                            }, 800);
                        } else {
                            if (window.showToast) {
                                window.showToast(data.message || '@Localizer["ProductAddFailed"]', 'error');
                            } else {
                                alert(data.message || '@Localizer["ProductAddFailed"]');
                            }
                        }
                    })
                    .catch(err => {
                        console.error(err);
                        if (window.showToast) {
                            window.showToast('@Localizer["ConnectionErrorOccurred"]', 'error');
                        } else {
                            alert('@Localizer["ConnectionError"]');
                        }
                    });
                }
            </script>

            <!-- Sipariş Özeti -->
            <aside class="lg:w-80 flex-shrink-0">
                <div class="bg-white border border-[#e5e2dc] rounded-lg p-6 sticky top-28">
                    <h2 class="font-serif text-lg text-[#313511] mb-5 pb-3 border-b border-[#e5e2dc]">@Localizer["OrderSummary"]</h2>

                    @{
                        var kalanTutar = ucretsizKargoLimiti - (sepetToplami - indirimTutari);
                        var shippingProgress = Math.Min(100, (int)(((double)(sepetToplami - indirimTutari) / (double)ucretsizKargoLimiti) * 100));
                    }
                    @if (kalanTutar > 0)
                    {
                        <div class="mb-5 bg-amber-50 border border-amber-200 rounded-lg p-4">
                            <div class="flex items-center gap-2 text-xs text-amber-800 mb-3">
                                <i class="fas fa-truck text-[#b58735]"></i>
                                <span>@Localizer["FreeShippingNotice", currencySymbol + kalanTutar.ToString("N2")]</span>
                            </div>
                            <div class="w-full h-2 bg-amber-200 rounded-full overflow-hidden">
                                <div class="h-full bg-gradient-to-r from-[#b58735] to-[#d4a84b] rounded-full transition-all duration-700" style="width: @(shippingProgress)%"></div>
                            </div>
                            <div class="flex justify-between text-[10px] text-amber-700 mt-1">
                                <span>@currencySymbol@("0")</span>
                                <span>@Localizer["FreeShippingProgress", currencySymbol + kalanTutar.ToString("N2")]</span>
                                <span>@currencySymbol@ucretsizKargoLimiti.ToString("N2")</span>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="mb-5 bg-green-50 border border-green-200 rounded-lg p-4">
                            <div class="flex items-center gap-2 text-xs text-green-800">
                                <i class="fas fa-check-circle text-green-500"></i>
                                <span class="font-semibold">@Localizer["FreeShippingReached"]</span>
                            </div>
                        </div>
                    }

                    <div class="space-y-3 text-sm mb-5">
                        <div class="flex justify-between text-[#47473d]">
                            <span>@Localizer["Subtotal"]</span>
                            <span>@currencySymbol@sepetToplami.ToString("N2")</span>
                        </div>
                        @if (indirimTutari > 0)
                        {
                            <div class="flex justify-between text-green-600">
                                <span><i class="fas fa-tag me-1 text-xs"></i>@Localizer["Discount"]</span>
                                <span>-@currencySymbol@indirimTutari.ToString("N2")</span>
                            </div>
                        }
                        <div class="flex justify-between text-[#47473d]">
                            <span>@Localizer["Shipping"]</span>
                            @if (kargoBedeli == 0)
                            {
                                <span class="text-green-600 font-medium">@Localizer["Free"]</span>
                            }
                            else
                            {
                                <span class="text-[#1c1c18] font-medium">@currencySymbol@kargoBedeli.ToString("N2")</span>
                            }
                        </div>

                        <!-- Kargo Firması Seçimi -->
                        @if (ViewBag.KargoFirmalari != null && ((List<FilistinProje.Core.Varliklar.KargoFirmasi>)ViewBag.KargoFirmalari).Any())
                        {
                            var kargoList = (List<FilistinProje.Core.Varliklar.KargoFirmasi>)ViewBag.KargoFirmalari;
                            <div class="py-2 border-t border-dashed border-[#e5e2dc]">
                                <form id="kargoSecimForm" method="post" action="/Sepet/SecilenKargoGuncelle" class="flex flex-col gap-1">
                                    @Html.AntiForgeryToken()
                                    <label class="text-[10px] uppercase tracking-widest text-[#a09e99] font-medium">@Localizer["SelectShippingCompany"]</label>
                                    <select name="kargoId" onchange="this.form.submit()" class="w-full border border-[#e5e2dc] rounded px-2.5 py-1.5 text-xs text-[#1c1c18] bg-[#fcf9f3] focus:ring-1 focus:ring-[#b58735] focus:outline-none outline-none">
                                        @foreach (var kargo in kargoList)
                                        {
                                            bool isSelected = kargo.Id == ViewBag.SecilenKargoId;
                                            decimal kUcreti = (sepetToplami - indirimTutari) >= ucretsizKargoLimiti ? 0 : kargo.Fiyat;
                                            string ucretMetni = kUcreti == 0 ? Localizer["Free"].Value : $"{currencySymbol}{kUcreti:N2}";
                                            <option value="@kargo.Id" selected="@isSelected">
                                                @kargo.Ad (@ucretMetni)
                                            </option>
                                        }
                                    </select>
                                </form>
                            </div>
                        }

                        <div class="flex justify-between text-[#1c1c18] font-bold text-base pt-3 border-t border-[#e5e2dc]">
                            <span>@Localizer["Total"]</span>
                            <span>@currencySymbol@genelToplam.ToString("N2")</span>
                        </div>
                    </div>

                    <!-- Kupon -->
                    @if (ViewBag.KuponKodu != null)
                    {
                        <div class="flex items-center justify-between bg-green-50 border border-green-200 rounded px-3 py-2 mb-4 text-sm text-green-700">
                            <span><i class="fas fa-check-circle me-1"></i>@ViewBag.KuponKodu</span>
                            <form method="post" action="/Sepet/KuponKaldir">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="text-red-400 hover:text-red-600"><i class="fas fa-times"></i></button>
                            </form>
                        </div>
                    }
                    else
                    {
                        <form action="/Sepet/KuponUygula" method="post" class="flex mb-4">
                            @Html.AntiForgeryToken()
                            <input type="text" name="kuponKodu" placeholder="@Localizer["DiscountCode"]" required
                                   class="flex-1 border border-[#e5e2dc] border-e-0 rounded-s px-3 py-2 text-xs focus:ring-1 focus:ring-[#b58735] outline-none bg-[#fcf9f3]" />
                            <button type="submit" class="bg-[#f1ede7] border border-[#e5e2dc] rounded-e px-3 py-2 text-xs hover:bg-[#e5e2dc] transition-colors text-[#313511] font-medium">
                                @Localizer["Apply"]
                            </button>
                        </form>
                    }

                    <a asp-controller="Siparis" asp-action="Odeme"
                       class="w-full bg-[#313511] text-white text-center text-xs tracking-widest uppercase py-3.5 rounded block hover:bg-[#1c2001] transition-colors font-medium">
                        <i class="fas fa-lock me-2 text-[10px]"></i>@Localizer["ProceedToCheckout"]
                    </a>
                    <p class="text-center text-[10px] text-gray-400 mt-3">
                        <i class="fas fa-shield-alt me-1"></i>@Localizer["SslSecurePayment"]
                    </p>
                </div>
            </aside>
        </div>

        <!-- Mobil Ödeme Çubuğu -->
        <div class="fixed bottom-16 md:bottom-0 inset-x-0 z-30 lg:hidden bg-white border-t border-[#e5e2dc] px-4 py-3 flex items-center justify-between shadow-lg">
            <div>
                <div class="text-[10px] text-[#47473d] uppercase tracking-wide">@Localizer["Total"]</div>
                <div class="font-bold text-[#1c1c18]">@currencySymbol@genelToplam.ToString("N2")</div>
            </div>
            <a asp-controller="Siparis" asp-action="Odeme"
               class="bg-[#313511] text-white text-xs tracking-widest uppercase px-6 py-3 rounded-full hover:bg-[#1c2001] transition-colors">
                <i class="fas fa-lock me-1 text-[10px]"></i>@Localizer["ProceedToCheckout"]
            </a>
        </div>
    }
</div>
