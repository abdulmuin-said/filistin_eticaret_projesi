</script>

    <!-- Search Results Dropdown -->
    <div id="searchResultsDropdown" class="fixed bg-white border border-[#e5e2dc] rounded-xl shadow-xl z-[200] hidden overflow-y-auto" style="max-height: 420px; min-width: 280px;"></div>

    <script>
        window.toggleSearchBar = function(open) {
            const mobileBar = document.getElementById('mobileSearchBar');
            const desktopBar = document.getElementById('desktopSearchBar');
            const logo = document.getElementById('siteLogo');
            const nav = document.querySelector('nav');
            const mobileMenuBtn = document.getElementById('mobileMenuBtn');
            const mobileSearchBtn = document.getElementById('mobileSearchBtn');
            const mobileIcons = document.getElementById('mobileIcons');
            const mobileNav = document.getElementById('mobileNav');
            const mobileBackdrop = document.getElementById('mobileNavBackdrop');
            const isMobile = window.innerWidth < 768;

            if (mobileNav && !mobileNav.classList.contains('hidden')) window.toggleMobileNav(false);

            let shouldOpen;
            if (typeof open === 'boolean') {
                shouldOpen = open;
            } else {
                shouldOpen = isMobile
                    ? mobileBar.style.display !== 'flex'
                    : desktopBar.classList.contains('hidden') || desktopBar.style.display !== 'flex';
            }

            if (isMobile) {
                if (shouldOpen) {
                    mobileBar.style.display = 'flex';
                    mobileBar.classList.remove('hidden');
                    const msb = document.getElementById('mobileSearchBtn');
                    if (msb) msb.style.display = 'none';
                    setTimeout(() => document.getElementById('mobileSearchInput')?.focus(), 50);
                } else {
                    mobileBar.style.display = 'none';
                    mobileBar.classList.add('hidden');
                    const msb = document.getElementById('mobileSearchBtn');
                    if (msb) msb.style.display = 'inline-flex';
                    const inp = document.getElementById('mobileSearchInput');
                    if (inp) inp.value = '';
                    document.getElementById('searchResultsDropdown')?.classList.add('hidden');
                }
            } else {
                if (shouldOpen) {
                    desktopBar.style.display = 'flex';
                    desktopBar.classList.remove('hidden');
                    const dsb = document.getElementById('desktopSearchBtn');
                    if (dsb) dsb.style.display = 'none';
                    setTimeout(() => document.getElementById('desktopSearchInput')?.focus(), 50);
                } else {
                    desktopBar.style.display = 'none';
                    desktopBar.classList.add('hidden');
                    const dsb = document.getElementById('desktopSearchBtn');
                    if (dsb) dsb.style.display = 'block';
                    const inp = document.getElementById('desktopSearchInput');
                    if (inp) inp.value = '';
                    document.getElementById('searchResultsDropdown')?.classList.add('hidden');
                }
            }
        };

        document.getElementById('mobileSearchCloseBtn')?.addEventListener('click', () => window.toggleSearchBar(false));
        document.getElementById('desktopSearchCloseBtn')?.addEventListener('click', () => window.toggleSearchBar(false));
        document.getElementById('mobileSearchBtn')?.addEventListener('click', (event) => {
            event.preventDefault();
            window.toggleSearchBar(true);
        });
        document.getElementById('desktopSearchBtn')?.addEventListener('click', (event) => {
            event.preventDefault();
            window.toggleSearchBar(true);
        });
        document.getElementById('mobileSearchSubmit')?.addEventListener('click', function (e) {
            e.preventDefault();
            const term = document.getElementById('mobileSearchInput')?.value.trim() || '';
            window.location.href = '/Urun' + (term ? '?s=' + encodeURIComponent(term) : '');
        });

        (function () {
            const desktopInput = document.getElementById('desktopSearchInput');
            const mobileInput = document.getElementById('mobileSearchInput');
            const resultsDropdown = document.getElementById('searchResultsDropdown');
            let searchTimer = null, abortController = null;
            let selectedIndex = -1;
            let currentResults = [];

            /* ---- helpers ---- */

            function escapeHtml(value) {
                return String(value || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
            }

            function getActiveInput() {
                return window.innerWidth < 768 ? mobileInput : desktopInput;
            }

            function positionDropdown() {
                if (!resultsDropdown || resultsDropdown.classList.contains('hidden')) return;
                const input = getActiveInput();
                if (!input) return;
                const rect = input.getBoundingClientRect();
                const scrollTop = window.scrollY || document.documentElement.scrollTop;
                const width = Math.max(rect.width, 300);
                resultsDropdown.style.width = width + 'px';
                if (window.innerWidth < 768) {
                    resultsDropdown.style.top = (rect.bottom + scrollTop + 6) + 'px';
                    resultsDropdown.style.left = '16px';
                    resultsDropdown.style.right = '16px';
                    resultsDropdown.style.minWidth = 'unset';
                } else {
                    resultsDropdown.style.top = (rect.bottom + scrollTop + 8) + 'px';
                    resultsDropdown.style.left = Math.max(rect.left, 8) + 'px';
                    resultsDropdown.style.right = 'auto';
                    resultsDropdown.style.minWidth = '340px';
                    resultsDropdown.style.maxWidth = Math.min(500, window.innerWidth - 32) + 'px';
                }
            }

            /* ---- render helpers ---- */

            function renderItemsHtml(items) {
                return items.slice(0, 8).map((item, idx) => {
                    const title = escapeHtml(item.baslik || '');
                    const price = item.fiyat ? escapeHtml(item.fiyat) : '';
                    const image = item.gorsel ? `<img src="${escapeHtml(item.gorsel)}" alt="${title}" class="w-12 h-12 object-cover rounded" loading="lazy">` : `<div class="w-12 h-12 rounded bg-[#f1ede7] flex items-center justify-center"><i class="fas fa-image text-[#b58735]"></i></div>`;
                    const url = item.slug ? '/Urun/Detay/' + encodeURIComponent(item.slug) + '-' + item.id : '/Urun/Detay/' + item.id;
                    return `<a href="${url}" class="search-result-item flex items-center gap-3 px-3 py-2.5 rounded-lg transition-colors hover:bg-[#f7f1e6] group" data-index="${idx}" role="option" aria-selected="false">
                        ${image}
                        <div class="flex-1 min-w-0">
                            <div class="text-sm font-medium text-[#1c1c18] truncate group-hover:text-[#b58735] transition-colors">${title}</div>
                            ${price ? `<div class="text-xs text-[#b58735] mt-0.5 font-semibold">${price}</div>` : ''}
                        </div>
                        <i class="fas fa-arrow-right text-[10px] text-[#b58735] opacity-0 group-hover:opacity-100 transition-opacity"></i>
                    </a>`;
                }).join('');
            }

            function renderDropdown(items) {
                currentResults = items;
                selectedIndex = -1;
                if (!items || items.length === 0) {
                    showResults('<div class="px-4 py-5 text-center text-sm text-[#6f6a5e]"><i class="fas fa-search mr-1"></i>@Localizer["NoResultsFound"]</div>');
                    return;
                }
                const term = (getActiveInput()?.value || '').trim();
                const visible = items.slice(0, 8);
                const resultCountLabel = '<div class="text-[10px] uppercase tracking-widest text-[#a09e99] px-2 pb-2">' + items.length + ' @Localizer["ResultsFound"]</div>';
                const itemsHtml = renderItemsHtml(items);
                const footer = items.length > 8
                    ? `<a href="/Urun?s=${encodeURIComponent(term)}" class="block text-center text-xs text-[#b58735] font-semibold py-2.5 border-t border-[#e5e2dc] hover:bg-[#f7f1e6] transition-colors rounded-b-lg" role="option">@Localizer["ViewAllResults"] <i class="fas fa-arrow-right ml-1 text-[10px]"></i></a>`
                    : '';
                showResults('<div class="p-2" role="listbox" aria-label="@Localizer["SearchResults"]">' + resultCountLabel + itemsHtml + footer + '</div>');
                // Scroll to top on new results
                if (resultsDropdown) resultsDropdown.scrollTop = 0;
            }

            function showLoading() {
                if (!resultsDropdown) return;
                resultsDropdown.innerHTML = '<div class="px-4 py-6 text-center text-sm text-[#6f6a5e]"><i class="fas fa-spinner fa-spin mr-2"></i>@Localizer["Searching"]</div>';
                resultsDropdown.classList.remove('hidden');
                positionDropdown();
            }

            function showResults(html) {
                if (!resultsDropdown) return;
                resultsDropdown.innerHTML = html;
                resultsDropdown.classList.remove('hidden');
                positionDropdown();
            }

            function hideResults() {
                resultsDropdown?.classList.add('hidden');
                currentResults = [];
                selectedIndex = -1;
            }

            /* ---- keyboard navigation ---- */

            function getResultLinks() {
                if (!resultsDropdown || resultsDropdown.classList.contains('hidden')) return [];
                return Array.from(resultsDropdown.querySelectorAll('.search-result-item'));
            }

            function updateSelection() {
                const links = getResultLinks();
                links.forEach((link, i) => {
                    link.classList.toggle('bg-[#f7f1e6]', i === selectedIndex);
                    link.setAttribute('aria-selected', i === selectedIndex ? 'true' : 'false');
                });
                if (selectedIndex >= 0 && links[selectedIndex]) {
                    links[selectedIndex].scrollIntoView({ block: 'nearest' });
                }
            }

            function navigateSelection(direction) {
                const links = getResultLinks();
                if (links.length === 0) return;
                selectedIndex = Math.max(0, Math.min(links.length - 1, selectedIndex + direction));
                updateSelection();
            }

            function commitSelection() {
                const links = getResultLinks();
                if (selectedIndex >= 0 && selectedIndex < links.length) {
                    window.location.href = links[selectedIndex].href;
                    return true;
                }
                // No selection — submit the form to go to search results page
                return false;
            }

            /* ---- fetch ---- */

            function runSearch(term) {
                if (term.length < 2) { hideResults(); return; }
                if (abortController) abortController.abort();
                abortController = new AbortController();
                showLoading();
                fetch('/Urun/CanliAra?q=' + encodeURIComponent(term), { signal: abortController.signal })
                    .then(r => r.ok ? r.json() : [])
                    .then(items => { renderDropdown(items); })
                    .catch(error => {
                        if (error.name !== 'AbortError') {
                            showResults('<div class="px-4 py-5 text-center text-sm text-red-600"><i class="fas fa-exclamation-circle mr-1"></i>@Localizer["SearchUnavailable"]</div>');
                        }
                    });
            }

            /* ---- event bindings ---- */

            [desktopInput, mobileInput].forEach(input => {
                if (!input) return;

                input.addEventListener('input', function () {
                    clearTimeout(searchTimer);
                    const term = this.value.trim();
                    if (term.length < 2) { hideResults(); return; }
                    searchTimer = setTimeout(() => runSearch(term), 220);
                });

                input.addEventListener('keydown', function (e) {
                    if (e.key === 'ArrowDown') {
                        e.preventDefault();
                        if (resultsDropdown?.classList.contains('hidden') && this.value.trim().length >= 2) {
                            runSearch(this.value.trim());
                        } else {
                            navigateSelection(1);
                        }
                    } else if (e.key === 'ArrowUp') {
                        e.preventDefault();
                        navigateSelection(-1);
                    } else if (e.key === 'Enter') {
                        if (!resultsDropdown?.classList.contains('hidden')) {
                            const committed = commitSelection();
                            if (committed) { e.preventDefault(); return; }
                        }
                        // fall through to default form submit
                    } else if (e.key === 'Escape') {
                        hideResults();
                    }
                });

                input.setAttribute('aria-autocomplete', 'list');
                input.setAttribute('aria-controls', 'searchResultsDropdown');
                input.setAttribute('aria-expanded', 'false');
                input.setAttribute('role', 'combobox');
            });

            /* ---- global close/resize ---- */

            document.addEventListener('click', function (e) {
                if (!resultsDropdown?.contains(e.target) &&
                    !e.target.closest('#desktopSearchInput') &&
                    !e.target.closest('#mobileSearchInput')) {
                    hideResults();
                }
            });

            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape') { hideResults(); window.toggleSearchBar(false); }
            });

            window.addEventListener('resize', positionDropdown);
            window.addEventListener('scroll', positionDropdown, true);

            /* update aria-expanded on dropdown toggle */
            const observer = new MutationObserver(() => {
                const input = getActiveInput();
                if (input) {
                    input.setAttribute('aria-expanded', resultsDropdown?.classList.contains('hidden') ? 'false' : 'true');
                }
            });
            if (resultsDropdown) observer.observe(resultsDropdown, { attributes: true, attributeFilter: ['class'] });
        })();
    </script>

<script>
        window.toggleFavori = function(btn, urunId) {
            const evt = window.event;
            if (evt) {
                evt.preventDefault();
                evt.stopPropagation();
            }
            
            const originalHtml = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin text-sm text-[#47473d]"></i>';
            btn.disabled = true;

            let token = document.querySelector('#globalAntiForgeryForm input[name="__RequestVerificationToken"]')?.value;
            
            fetch('/Favori/Toggle?urunId=' + urunId, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token || ''
                }
            })
            .then(res => res.json())
            .then(data => {
                if(data.success) {
                    if(data.isAdded) {
                        btn.innerHTML = '<i class="fas fa-heart text-sm text-red-500"></i>';
                        if(window.showToast) window.showToast('@Localizer["ProductAddedToFavorites"]', 'success');
                    } else {
                        btn.innerHTML = '<i class="far fa-heart text-sm text-[#47473d] group-hover/btn:text-red-500 transition-colors"></i>';
                        if(window.showToast) window.showToast('@Localizer["ProductRemovedFromFavorites"]', 'info');
                    }
                } else {
                    if (data.message === '@Localizer["PleaseLogin"]') {
                        window.location.href = '/Hesap/GirisYap?ReturnUrl=' + window.location.pathname;
                    } else {
                        if(window.showToast) window.showToast(data.message || '@Localizer["AnErrorOccurred"]', 'error');
                        btn.innerHTML = originalHtml;
                    }
                }
            })
            .catch(err => {
                console.error(err);
                if(window.showToast) window.showToast('@Localizer["ConnectionError"]', 'error');
                btn.innerHTML = originalHtml;
            })
            .finally(() => {
                btn.disabled = false;
            });
        };
    </script>

