@model FilistinProje.Core.Varliklar.Urun
@using FilistinProje.Service.Helpers
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@inject FilistinProje.Service.Services.ISiteSettingsService SiteSettingsService
@inject IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = Model.LocalizedBaslik;
    var siteSettings = SiteSettingsService.GetSettings();
    var brandName = string.IsNullOrWhiteSpace(siteSettings.MarkaAdi) ? siteSettings.SiteAdi : siteSettings.MarkaAdi;
    var currencySymbol = string.IsNullOrWhiteSpace(siteSettings.ParaBirimi) ? "₪" : siteSettings.ParaBirimi;

    // --- VARYANT VE FÃ„Â°YAT HESAPLAMA ---
    var secenekler = ViewBag.Secenekler as List<FilistinProje.Core.Varliklar.UrunSecenek> ?? new List<FilistinProje.Core.Varliklar.UrunSecenek>();
    var stokBiteniGriGoster = siteSettings.StokBiteniGriGoster;
    var stoktaYokSatisIzni = siteSettings.StoktaYokSatisIzni;
    var varsayilanSecenek = secenekler
        .OrderByDescending(x => x.VarsayilanMi)
        .ThenBy(x => x.Sira)
        .ThenBy(x => x.SatisFiyati)
        .FirstOrDefault(x => stoktaYokSatisIzni || x.SatinAlinabilirMi)
        ?? secenekler
            .OrderByDescending(x => x.VarsayilanMi)
            .ThenBy(x => x.Sira)
            .ThenBy(x => x.SatisFiyati)
            .FirstOrDefault();
    var isWholesale = ViewBag.IsWholesale is bool ws && ws;
    decimal gosterilecekFiyat;
    if (isWholesale && Model.TopFiyat.HasValue && Model.TopFiyat.Value > 0)
    {
        gosterilecekFiyat = Model.TopFiyat.Value;
    }
    else
    {
        gosterilecekFiyat = varsayilanSecenek != null ? varsayilanSecenek.SatisFiyati : Model.EtkinFiyat;
    }
    decimal eskiFiyat = gosterilecekFiyat * 1.15m;

    // --- YORUM VERÃ„Â°LERÃ„Â° ---
    decimal? gosterilecekEskiFiyatEski = varsayilanSecenek == null && Model.IndirimVarMi ? Model.Fiyat : null;
    decimal? gosterilecekEskiFiyat = varsayilanSecenek != null && Model.Fiyat > gosterilecekFiyat
        ? Model.Fiyat
        : gosterilecekEskiFiyatEski;
    int? gosterilecekIndirimYuzdesi = gosterilecekEskiFiyat.HasValue && gosterilecekEskiFiyat.Value > gosterilecekFiyat
        ? (int)Math.Round((1 - (gosterilecekFiyat / gosterilecekEskiFiyat.Value)) * 100)
        : null;
    int toplamStok = secenekler.Any() ? secenekler.Where(x => !x.SilindiMi && x.AktifMi).Sum(x => x.StokAdedi) : Model.ToplamStok;
    bool stoktaVar = secenekler.Any()
        ? secenekler.Any(x => stoktaYokSatisIzni || x.SatinAlinabilirMi)
        : Model.StoktaVarMi;
    string stokDurumuMetni = varsayilanSecenek != null
        ? (stoktaYokSatisIzni || varsayilanSecenek.SatinAlinabilirMi ? Localizer["MadeToOrder"].Value : (varsayilanSecenek.OnSipariseAcikMi ? Localizer["PreOrderOpen"].Value : Localizer["OutOfStock"].Value))
        : (stoktaVar
            ? Localizer["MadeToOrder"].Value
            : Localizer["OutOfStock"].Value);
    var stokIkonClass = stoktaVar ? "fas fa-check-circle text-green-600" : "fas fa-times-circle text-red-600";
    int minSiparisAdedi = Model.MinSiparisAdedi > 0 ? Model.MinSiparisAdedi : 1;
    int varsayilanMax = varsayilanSecenek?.StokAdedi > 0
        ? varsayilanSecenek.StokAdedi
        : (varsayilanSecenek?.OnSipariseAcikMi == true ? Math.Max(minSiparisAdedi, 25) : Math.Max(minSiparisAdedi, 10));
    int maxSiparisAdedi = Model.MaxSiparisAdedi ?? varsayilanMax;
    if (maxSiparisAdedi < minSiparisAdedi)
    {
        maxSiparisAdedi = minSiparisAdedi;
    }

    var rawVaryantMetni = varsayilanSecenek != null 
        ? (string.IsNullOrWhiteSpace(varsayilanSecenek.VaryantBasligi) ? (varsayilanSecenek.Olcu ?? "Standart") : varsayilanSecenek.VaryantBasligi) 
        : string.Empty;
    var seciliVaryantMetni = string.Join(" / ", rawVaryantMetni.Split(new[] { " / " }, StringSplitOptions.RemoveEmptyEntries).Where(x => !x.Contains("Standart", StringComparison.OrdinalIgnoreCase) && !x.Contains("Bask", StringComparison.OrdinalIgnoreCase)));
    if (string.IsNullOrWhiteSpace(seciliVaryantMetni) && !string.IsNullOrWhiteSpace(rawVaryantMetni)) seciliVaryantMetni = rawVaryantMetni.Split('/')[0].Trim();
    if (secenekler.Count <= 1)
    {
        seciliVaryantMetni = string.Empty;
    }
    var seciliVaryantDetayi = varsayilanSecenek?.VaryantOzeti ?? string.Empty;
    int gosterilecekUretimSuresi = varsayilanSecenek?.UretimSuresiGun > 0
        ? varsayilanSecenek.UretimSuresiGun
        : Model.UretimSuresiGun;
    int gosterilecekKargoSuresi = Model.KargoyaVerilisSuresiGun > 0 ? Model.KargoyaVerilisSuresiGun : 3;
    int gosterilecekTeslimSuresi = Model.TahminiTeslimSuresiGun > 0
        ? Model.TahminiTeslimSuresiGun
        : siteSettings.SiparisTeslimSuresiGun;
    int iadeSuresi = siteSettings.IadeHakkiGun > 0 ? siteSettings.IadeHakkiGun : 14;
    bool cerceveSecimiGerekli = (Model.UrunTipi ?? string.Empty).Contains("kanvas", StringComparison.OrdinalIgnoreCase)
        || (Model.Kategori?.Ad ?? string.Empty).Contains("kanvas", StringComparison.OrdinalIgnoreCase)
        || (Model.Kategori?.ParentKategori?.Ad ?? string.Empty).Contains("kanvas", StringComparison.OrdinalIgnoreCase);
    var cerceveModelleri = new[] { "Çerçevesiz", "Siyah", "Beyaz", "Gold", "Gümüş", "Meşe", "Ceviz" };

    var teknikSatirlari = (Model.TeknikOzellikler ?? string.Empty)
        .Split(new[] { "\r\n", "\n" }, StringSplitOptions.RemoveEmptyEntries)
        .Select(x => x.Trim())
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .ToList();

    var dinamikOzellikler = (Model.UrunOzellikleri ?? Enumerable.Empty<FilistinProje.Core.Varliklar.UrunOzellikDegeri>())
        .Where(x =>
            !x.SilindiMi &&
            x.UrunOzellikTanimi != null &&
            x.UrunOzellikTanimi.AktifMi &&
            x.UrunOzellikTanimi.DetaySayfasindaGoster &&
            !string.IsNullOrWhiteSpace(x.Deger))
        .OrderBy(x => x.UrunOzellikTanimi.Sira)
        .ThenBy(x => x.UrunOzellikTanimi.Ad)
        .ToList();

    var teknikTabloSatirlari = new List<(string Baslik, string Deger)>();
    teknikTabloSatirlari.AddRange(dinamikOzellikler
        .Where(x => x.UrunOzellikTanimi.TeknikTablodaGoster)
        .Select(x => (x.UrunOzellikTanimi.Ad, x.DegerGosterimi)));

    foreach (var satir in teknikSatirlari)
    {
        var ayiriciIndex = satir.IndexOf(':');
        if (ayiriciIndex > 0 && ayiriciIndex < satir.Length - 1)
        {
            teknikTabloSatirlari.Add((satir[..ayiriciIndex].Trim(), satir[(ayiriciIndex + 1)..].Trim()));
        }
        else
        {
            teknikTabloSatirlari.Add(("Detay", satir));
        }
    }

    var tumMedya = ViewBag.TumMedya as List<FilistinProje.Core.Varliklar.UrunResim> ?? new List<FilistinProje.Core.Varliklar.UrunResim>();
    var galeriMedyalari = ViewBag.Galeri as List<FilistinProje.Core.Varliklar.UrunResim> ?? tumMedya.Where(x => !x.VideoMu).ToList();
    var videoMedyalari = ViewBag.VideoMedyalari as List<FilistinProje.Core.Varliklar.UrunResim> ?? new List<FilistinProje.Core.Varliklar.UrunResim>();
    var yakinDetayMedyalari = ViewBag.YakinDetayMedyalari as List<FilistinProje.Core.Varliklar.UrunResim> ?? new List<FilistinProje.Core.Varliklar.UrunResim>();
    var uretimMedyalari = ViewBag.UretimMedyalari as List<FilistinProje.Core.Varliklar.UrunResim> ?? new List<FilistinProje.Core.Varliklar.UrunResim>();
    var kullanimMedyalari = ViewBag.KullanimMedyalari as List<FilistinProje.Core.Varliklar.UrunResim> ?? new List<FilistinProje.Core.Varliklar.UrunResim>();
    var varsayilanMedya = galeriMedyalari
        .OrderByDescending(x => x.VarsayilanMi)
        .ThenBy(x => x.Sira)
        .FirstOrDefault();
    var varsayilanGaleriGorseli = !string.IsNullOrWhiteSpace(varsayilanSecenek?.GorselUrl)
        ? varsayilanSecenek.GorselUrl
        : (varsayilanMedya?.ResimYolu ?? Model.AnaGorselUrl);
    var varsayilanGaleriAltMetni = !string.IsNullOrWhiteSpace(varsayilanMedya?.AltMetin)
        ? varsayilanMedya.AltMetin
        : Model.LocalizedBaslik;
    var varyantMedyaHaritasi = tumMedya
        .Where(x => x.UrunSecenekId.HasValue && !x.VideoMu && !string.IsNullOrWhiteSpace(x.ResimYolu))
        .GroupBy(x => x.UrunSecenekId!.Value)
        .ToDictionary(
            x => x.Key,
            x => x.OrderByDescending(y => y.VarsayilanMi).ThenBy(y => y.Sira).Select(y => y.ResimYolu).First());
    bool medyaVitriniVar = videoMedyalari.Any() || yakinDetayMedyalari.Any() || uretimMedyalari.Any() || kullanimMedyalari.Any();

    List<FilistinProje.Core.Varliklar.Yorum> yorumlar = ViewBag.Yorumlar ?? new List<FilistinProje.Core.Varliklar.Yorum>();
    double ortalamaPuan = ViewBag.OrtalamaPuan != null ? (double)ViewBag.OrtalamaPuan : 0;
    int yorumSayisi = ViewBag.YorumSayisi != null ? (int)ViewBag.YorumSayisi : 0;
    
    // YÃ„Â±ldÃ„Â±z Hesaplama
    int tamYildiz = (int)ortalamaPuan;
    bool yarimYildiz = (ortalamaPuan - tamYildiz) >= 0.5;
    
    // --- SCHEMA.ORG Ã„Â°Ãƒâ€¡Ã„Â°N URL VE GÃƒâ€“RSEL ---
    var request = HttpContextAccessor.HttpContext?.Request;
    string baseUrl = request != null ? SiteSettingsService.BuildAbsoluteUrl(string.Empty) : "";
    string detaySlug = string.IsNullOrWhiteSpace(Model.Slug) ? $"{FilistinProje.Core.Helpers.SlugHelper.GenerateSlug(Model.LocalizedBaslik)}-{Model.Id}" : $"{Model.Slug}-{Model.Id}";
    string productUrl = $"{baseUrl}/Urun/Detay/{detaySlug}";
    var encodedProductUrl = Uri.EscapeDataString(productUrl);
    var encodedProductTitle = Uri.EscapeDataString(Model.LocalizedBaslik);
    var schemaImagePath = !string.IsNullOrWhiteSpace(varsayilanMedya?.EtkinPosterYolu) ? varsayilanMedya.EtkinPosterYolu : varsayilanGaleriGorseli;
    string productImage = schemaImagePath.StartsWith("http", StringComparison.OrdinalIgnoreCase) ? schemaImagePath : $"{baseUrl}{schemaImagePath}";
    var seoDescriptionSource = !string.IsNullOrWhiteSpace(Model.LocalizedKisaAciklama) ? Model.LocalizedKisaAciklama : Model.LocalizedAciklama;
    var seoDescription = System.Text.RegularExpressions.Regex.Replace(seoDescriptionSource ?? string.Empty, "<.*?>", " ");
    seoDescription = System.Net.WebUtility.HtmlDecode(seoDescription);
    seoDescription = System.Text.RegularExpressions.Regex.Replace(seoDescription, @"\s+", " ").Trim();
    if (seoDescription.Length > 155)
    {
        var cut = seoDescription[..155].Trim();
        var lastSpace = cut.LastIndexOf(' ');
        seoDescription = (lastSpace > 80 ? cut[..lastSpace] : cut).TrimEnd('.', ',', ';', ':') + "...";
    }
    if (string.IsNullOrWhiteSpace(seoDescription))
    {
        seoDescription = $"{Model.LocalizedBaslik} {Localizer["MadeToOrder"].Value}. {brandName}.";
    }

    var keywordParts = new List<string?>
    {
        Model.LocalizedBaslik,
        Model.Kategori?.Ad,
        Model.UrunTipi,
        Model.Marka,
        "dekorasyon",
        "premium dekorasyon",
        "siparişe özel üretim"
    };
    keywordParts.AddRange((Model.Etiketler ?? string.Empty).Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries));

    ViewData["SeoTitle"] = !string.IsNullOrWhiteSpace(Model.LocalizedSeoTitle) ? Model.LocalizedSeoTitle : $"{Model.LocalizedBaslik} | {brandName}";
    ViewData["MetaDescription"] = !string.IsNullOrWhiteSpace(Model.LocalizedSeoDescription) ? Model.LocalizedSeoDescription : seoDescription;
    ViewData["MetaKeywords"] = !string.IsNullOrWhiteSpace(Model.SeoKeywords) ? Model.SeoKeywords : string.Join(", ", keywordParts.Where(x => !string.IsNullOrWhiteSpace(x)).Distinct(StringComparer.OrdinalIgnoreCase));
    ViewData["CanonicalUrl"] = productUrl;
    ViewData["OgType"] = "product";
    ViewData["OgImage"] = productImage;
    
    <!-- SCHEMA.ORG JSON-LD: Google Shopping Rich Snippets -->
    var productSchema = SchemaGenerator.GenerateProductSchema(
        Model, 
        ortalamaPuan, 
        yorumSayisi, 
        productImage, 
        productUrl,
        brandName
    );
}


<!-- Ã¢Å“Â¨ SCHEMA.ORG JSON-LD: Google Shopping Rich Snippets Ã¢Å“Â¨ -->
<script type="application/ld+json">
@Html.Raw(productSchema)
</script>


<!-- Mobile Lightbox -->
<div id="mobileLightbox" class="fixed inset-0 z-[99990] hidden bg-black/95 items-center justify-center" role="dialog" aria-modal="true" aria-label="@Localizer["ProductImage"]">
    <button type="button" class="absolute top-4 right-4 z-[100000] text-white bg-black/50 hover:bg-black/70 rounded-full w-12 h-12 flex items-center justify-center" onclick="closeMobileLightbox()" aria-label="@Localizer["CloseImage"]">
        <i class="fas fa-times text-2xl"></i>
    </button>
    <div class="relative z-[99991] w-full h-full flex items-center justify-center overflow-hidden px-4 py-20" id="lightboxImgContainer">
        <img id="mobileLightboxImage" class="max-w-full max-h-full object-contain transition-transform duration-200" src="@varsayilanGaleriGorseli" alt="@varsayilanGaleriAltMetni" decoding="async">
    </div>
    <div class="absolute bottom-8 left-1/2 z-[100000] transform -translate-x-1/2 flex items-center gap-4 bg-black/60 text-white rounded-full px-4 py-2">
        <button type="button" class="w-10 h-10 flex items-center justify-center" onclick="rotateMobileImage()" aria-label="@Localizer["Rotate"]"><i class="fas fa-redo"></i></button>
        <button type="button" class="w-10 h-10 flex items-center justify-center" onclick="zoomOutMobile()" aria-label="@Localizer["ZoomOut"]"><i class="fas fa-search-minus"></i></button>
        <span id="zoomLevel" class="text-sm min-w-[42px] text-center">100%</span>
        <button type="button" class="w-10 h-10 flex items-center justify-center" onclick="zoomInMobile()" aria-label="@Localizer["ZoomIn"]"><i class="fas fa-search-plus"></i></button>
    </div>
</div>

<!-- Desktop Lightbox Modal -->
<div class="fixed inset-0 z-[99990] hidden bg-black/95 items-center justify-center" id="desktopLightboxModal" role="dialog" aria-modal="true" aria-label="@Localizer["ProductImage"]">
    <button type="button" class="absolute top-4 right-4 z-[100000] text-white bg-black/50 hover:bg-black/70 rounded-full w-12 h-12 flex items-center justify-center" id="closeDesktopModalBtn" aria-label="@Localizer["CloseImage"]">
        <i class="fas fa-times text-2xl"></i>
    </button>
    <div class="absolute top-4 left-1/2 z-[100000] transform -translate-x-1/2 flex items-center gap-3 bg-black/60 text-white rounded-full px-4 py-2">
        <button type="button" class="w-10 h-10 flex items-center justify-center" onclick="rotateDesktopImage()" aria-label="@Localizer["Rotate"]"><i class="fas fa-redo"></i></button>
        <button type="button" class="w-10 h-10 flex items-center justify-center" onclick="zoomOutDesktop()" aria-label="@Localizer["ZoomOut"]"><i class="fas fa-search-minus"></i></button>
        <button type="button" class="w-10 h-10 flex items-center justify-center" onclick="zoomInDesktop()" aria-label="@Localizer["ZoomIn"]"><i class="fas fa-search-plus"></i></button>
    </div>
    <div class="relative z-[99991] w-full h-full flex items-center justify-center overflow-hidden px-6 py-20">
        <img id="desktopLightboxImage" src="@varsayilanGaleriGorseli" class="max-w-full max-h-full object-contain transition-transform duration-200" alt="@varsayilanGaleriAltMetni" loading="lazy" decoding="async">
    </div>
</div>


<!-- Yorum Yapma Modal -->
<div class="fixed inset-0 z-50 hidden bg-black bg-opacity-50 items-center justify-center" id="commentModal">
    <div class="bg-white rounded-lg w-full max-w-md p-6 relative">
        <button class="absolute top-4 right-4 text-gray-400 hover:text-black" id="closeCommentModalBtn"><i class="fas fa-times"></i></button>
        <h5 class="font-serif text-2xl text-[#313511] mb-6">@Localizer["RateProduct"]</h5>
        <form action="/Urun/YorumYap" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="UrunId" value="@Model.Id" />
            
            <div class="flex flex-row-reverse justify-center gap-2 mb-6">
                <input type="radio" id="star5" name="Puan" value="5" class="hidden peer/5" />
                <label for="star5" class="text-gray-300 peer-checked/5:text-[#b58735] hover:text-[#b58735] cursor-pointer text-2xl transition-colors"><i class="fas fa-star"></i></label>
                
                <input type="radio" id="star4" name="Puan" value="4" class="hidden peer/4" />
                <label for="star4" class="text-gray-300 peer-checked/4:text-[#b58735] hover:text-[#b58735] cursor-pointer text-2xl transition-colors"><i class="fas fa-star"></i></label>
                
                <input type="radio" id="star3" name="Puan" value="3" class="hidden peer/3" />
                <label for="star3" class="text-gray-300 peer-checked/3:text-[#b58735] hover:text-[#b58735] cursor-pointer text-2xl transition-colors"><i class="fas fa-star"></i></label>
                
                <input type="radio" id="star2" name="Puan" value="2" class="hidden peer/2" />
                <label for="star2" class="text-gray-300 peer-checked/2:text-[#b58735] hover:text-[#b58735] cursor-pointer text-2xl transition-colors"><i class="fas fa-star"></i></label>
                
                <input type="radio" id="star1" name="Puan" value="1" class="hidden peer/1" checked />
                <label for="star1" class="text-gray-300 peer-checked/1:text-[#b58735] hover:text-[#b58735] cursor-pointer text-2xl transition-colors"><i class="fas fa-star"></i></label>
            </div>

            @if (User.Identity?.IsAuthenticated != true)
            {
                <div class="mb-4">
                    <label class="block text-xs uppercase tracking-widest text-[#1c1c18] font-medium mb-1.5">@Localizer["YourFullName"]</label>
                    <input type="text" name="AdSoyad" class="w-full border border-[#e5e2dc] rounded px-4 py-2 text-sm focus:ring-[#b58735] focus:border-[#b58735]" required>
                </div>
            }

            <div class="mb-6">
                    <label class="block text-xs uppercase tracking-widest text-[#1c1c18] font-medium mb-1.5">@Localizer["YourComment"]</label>
                <textarea name="YorumMetni" class="w-full border border-[#e5e2dc] rounded px-4 py-2 text-sm focus:ring-[#b58735] focus:border-[#b58735]" rows="4" required></textarea>
            </div>

            <button type="submit" class="w-full bg-[#313511] text-white text-xs tracking-widest uppercase py-3 rounded hover:bg-[#1c2001] transition-colors">@Localizer["SubmitReview"]</button>
        </form>
    </div>
</div>

<!-- Breadcrumb -->
<div class="bg-[#f1ede7] border-b border-[#e5e2dc] py-3">
    <div class="container mx-auto px-4 flex items-center gap-2 text-xs text-[#47473d]">
        <a href="/" class="hover:text-[#313511] transition-colors">@Localizer["HomePage"]</a>
        <span>/</span>
        <a href="/Urun" class="hover:text-[#313511] transition-colors">@Localizer["Collection"]</a>
        <span>/</span>
        <span class="text-[#1c1c18] font-medium">@Model.LocalizedBaslik</span>
    </div>
</div>

<div class="container mx-auto px-4 py-12">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
        
        <!-- Left: Image Gallery -->
        <div class="space-y-4">
            <div id="mainProductImageContainer" class="relative bg-[#f1ede7] aspect-square rounded-lg overflow-hidden group cursor-zoom-in flex items-center justify-center p-4" onclick="openProductLightbox()">
                <img id="mainProductImage" src="@varsayilanGaleriGorseli" data-default-src="@(varsayilanMedya?.ResimYolu ?? Model.AnaGorselUrl)" data-default-alt="@varsayilanGaleriAltMetni" data-product-name="@Model.LocalizedBaslik" class="w-full h-full object-contain transition-transform duration-700 ease-out group-hover:scale-[2] main-product-image" alt="@varsayilanGaleriAltMetni" decoding="async" fetchpriority="high">
                
                <button type="button" class="absolute left-4 top-1/2 -translate-y-1/2 bg-white/80 backdrop-blur-sm w-10 h-10 rounded-full shadow-sm text-[#313511] flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity hover:bg-white z-10" onclick="navigateGallery('prev', event)">
                    <i class="fas fa-chevron-left"></i>
                </button>
                <button type="button" class="absolute right-4 top-1/2 -translate-y-1/2 bg-white/80 backdrop-blur-sm w-10 h-10 rounded-full shadow-sm text-[#313511] flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity hover:bg-white z-10" onclick="navigateGallery('next', event)">
                    <i class="fas fa-chevron-right"></i>
                </button>

                <div class="absolute bottom-4 right-4 bg-white/80 backdrop-blur-sm w-10 h-10 rounded-full shadow-sm text-[#313511] flex items-center justify-center z-10">
                    <i class="fas fa-search-plus"></i>
                </div>
            </div>
            
            @if (galeriMedyalari.Any())
            {
                <div class="flex gap-3 overflow-x-auto pb-2 custom-scrollbar">
                    @foreach (var resim in galeriMedyalari)
                    {
                        var altMetin = string.IsNullOrWhiteSpace(resim.AltMetin) ? Model.LocalizedBaslik : resim.AltMetin;
                        <button type="button" class="thumbnail-item flex-shrink-0 w-20 h-20 md:w-24 md:h-24 rounded border-2 @(string.Equals(resim.ResimYolu, varsayilanGaleriGorseli, StringComparison.OrdinalIgnoreCase) ? "border-[#313511]" : "border-transparent") overflow-hidden transition-colors bg-[#fcf9f3]" data-image="@resim.ResimYolu" data-alt="@altMetin" onclick="changeProductImage(this.dataset.image, this, this.dataset.alt)">
                                            <img src="@resim.EtkinPosterYolu" class="w-full h-full object-cover" alt="@altMetin" loading="lazy" decoding="async">
                        </button>
                    }
                </div>
            }
        </div>

        <!-- Right: Product Info -->
        <div class="flex flex-col">
            <h1 class="font-serif text-3xl md:text-4xl lg:text-5xl text-[#313511] mb-4">@Model.LocalizedBaslik</h1>
            
            <div class="flex items-center gap-4 mb-6">
                <div class="flex text-[#b58735] text-sm">
                    @for (int i = 1; i <= 5; i++)
                    {
                        if (i <= tamYildiz)
                        {
                            <i class="fas fa-star"></i>
                        }
                        else if (i == tamYildiz + 1 && yarimYildiz)
                        {
                            <i class="fas fa-star-half-alt"></i>
                        }
                        else
                        {
                            <i class="far fa-star"></i>
                        }
                    }
                </div>
                <span class="text-xs text-[#47473d]">@Localizer["ReviewCount", yorumSayisi]</span>
            </div>

            <div class="flex items-end gap-4 mb-6">
                @if (!Model.FiyatGizliMi)
                {
                    <span id="priceDisplay" class="font-sans text-2xl font-medium tracking-tight text-[#1c1c18]">@gosterilecekFiyat.ToString("N2") @currencySymbol</span>
                    @if (gosterilecekEskiFiyat.HasValue)
                    {
                        <span id="oldPriceDisplay" class="text-lg text-[#47473d] line-through mb-1 font-sans">@gosterilecekEskiFiyat.Value.ToString("N2") @currencySymbol</span>
                    }
                }
                else
                {
                    <span class="text-lg font-medium" style="color:#b58735;">@Localizer["ContactForPrice"].Value</span>
                }
                @if (gosterilecekIndirimYuzdesi.HasValue)
                {
                    <span id="discountBadge" class="bg-[#b58735] text-white text-xs px-2 py-1 rounded mb-1">%@gosterilecekIndirimYuzdesi.Value @Localizer["Discount"]</span>
                }
                else
                {
                    <span id="discountBadge" class="bg-[#b58735] text-white text-xs px-2 py-1 rounded mb-1 hidden"></span>
                }
            </div>
            @if (User.IsInRole("Wholesale") && Model.TopFiyat.HasValue && Model.TopFiyat.Value > 0)
            {
                <div class="flex items-center gap-2 mb-6 bg-[#f8f6f2] border border-[#e5e2dc] rounded px-4 py-2">
                    <i class="fas fa-tags text-[#b58735] text-sm"></i>
                    <span class="text-xs uppercase tracking-widest text-[#47473d] font-medium">Toptan Fiyat:</span>
                    <span class="text-lg font-semibold text-[#b58735]">@Model.TopFiyat?.ToString("N2") @currencySymbol</span>
                </div>
            }

            <div class="flex flex-wrap items-center gap-y-2 gap-x-6 text-xs text-[#47473d] mb-6 border-y border-[#e5e2dc] py-4">
                <span id="stockStatusText" class="flex items-center gap-2"><i class="@stokIkonClass"></i> @stokDurumuMetni</span>
                <span class="flex items-center gap-2"><i class="fas fa-truck text-[#a09e99]"></i> @Localizer["ShippingInDays", gosterilecekKargoSuresi]</span>
                @if (gosterilecekUretimSuresi > 0)
                {
                    <span id="productionTimeText" class="flex items-center gap-2"><i class="fas fa-hammer text-[#a09e99]"></i> @Localizer["ProductionInDays", gosterilecekUretimSuresi]</span>
                }
            </div>

            @if (Model.KampanyaBitisTarihi.HasValue && Model.KampanyaBitisTarihi.Value > DateTime.UtcNow)
            {
                <div class="mb-4">
                    @await Html.PartialAsync("_CountdownPartial", Model.KampanyaBitisTarihi.Value)
                </div>
            }

            <div id="variantSummaryText" class="text-sm text-[#47473d] mb-6 @(string.IsNullOrWhiteSpace(seciliVaryantMetni) ? "hidden" : "")">
                <i class="fas fa-layer-group mr-1.5"></i>@seciliVaryantMetni
            </div>

@if (!string.IsNullOrWhiteSpace(Model.LocalizedKisaAciklama))
            {
                <p class="text-sm text-[#47473d] mb-8 leading-relaxed">@Model.LocalizedKisaAciklama</p>
            }

            @if (secenekler.Count > 1)
            {
                <div class="mb-8">
                    <label class="block text-xs uppercase tracking-widest text-[#1c1c18] font-medium mb-3">@Localizer["SelectSize"]</label>
                    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
                        @foreach (var varyant in secenekler)
                        {
                            var varyantSatinAlinabilir = stoktaYokSatisIzni || varyant.SatinAlinabilirMi;
                            var varyantOldPrice = Model.Fiyat > varyant.SatisFiyati ? Model.Fiyat : 0;
                            var varyantMedyaUrl = !string.IsNullOrWhiteSpace(varyant.GorselUrl) ? varyant.GorselUrl : (varyantMedyaHaritasi.TryGetValue(varyant.Id, out var eslesen) ? eslesen : string.Empty);
                            var rawVb = string.IsNullOrWhiteSpace(varyant.VaryantBasligi) ? varyant.Olcu : varyant.VaryantBasligi;
                            var cleanVb = string.Join(" / ", rawVb.Split(new[] { " / " }, StringSplitOptions.RemoveEmptyEntries).Where(x => !x.Contains("Standart", StringComparison.OrdinalIgnoreCase) && !x.Contains("Bask", StringComparison.OrdinalIgnoreCase)));
                            if (string.IsNullOrWhiteSpace(cleanVb)) cleanVb = rawVb.Split('/')[0].Trim();
                            var varyantUretimSuresi = varyant.UretimSuresiGun > 0 ? varyant.UretimSuresiGun : Model.UretimSuresiGun;
                            var checkedAttr = varyant.Id == varsayilanSecenek?.Id ? "checked" : null;
                            var disabledAttr = !varyantSatinAlinabilir ? "disabled" : null;
                            var dusukStok = varyant.StokAdedi > 0 && varyant.StokAdedi <= 5;
                            
                            <label class="relative border-2 @(varyant.Id == varsayilanSecenek?.Id ? "border-[#313511] bg-[#313511] text-white shadow-md" : "border-[#e5e2dc] bg-white text-[#47473d] hover:border-[#b58735]") rounded-lg px-4 py-3 cursor-pointer transition-all duration-150 @(!varyantSatinAlinabilir ? "opacity-40 cursor-not-allowed pointer-events-none" : "")">
                                <input type="radio" id="variant-@varyant.Id" name="productVariant" value="@varyant.Id" class="variant-radio absolute opacity-0 w-0 h-0" checked="@checkedAttr" disabled="@disabledAttr" data-price="@varyant.SatisFiyati" data-oldprice="@(varyantOldPrice > 0 ? varyantOldPrice.ToString(System.Globalization.CultureInfo.InvariantCulture) : string.Empty)" data-stock="@varyant.StokAdedi" data-preorder="@varyant.OnSipariseAcikMi.ToString().ToLowerInvariant()" data-production="@varyantUretimSuresi" data-image="@varyantMedyaUrl" data-label="@cleanVb" data-olcu="@cleanVb">
                                <div class="flex flex-col items-center text-center gap-1">
                                    <span class="text-sm font-semibold leading-tight">@cleanVb</span>
                                    <span class="text-xs @(varyant.Id == varsayilanSecenek?.Id ? "text-white/80" : "text-[#b58735]") font-medium">@varyant.SatisFiyati.ToString("N0") @currencySymbol</span>
                                    @if (dusukStok)
                                    {
                                        <span class="text-[10px] @(varyant.Id == varsayilanSecenek?.Id ? "text-amber-200" : "text-amber-600") font-semibold uppercase tracking-wider">Son @varyant.StokAdedi Adet</span>
                                    }
                                    @if (!varyantSatinAlinabilir)
                                    {
                                        <span class="text-[10px] text-red-400 font-semibold uppercase tracking-wider">@Localizer["OutOfStock"]</span>
                                    }
                                </div>
                                @if (varyant.Id == varsayilanSecenek?.Id)
                                {
                                    <div class="absolute -top-2 -right-2 w-5 h-5 bg-[#b58735] rounded-full flex items-center justify-center shadow-sm">
                                        <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                                    </div>
                                }
                            </label>
                        }
                    </div>
                </div>
                <div id="lowStockWarning" class="hidden mb-6 bg-red-50 border border-red-200 rounded-lg px-4 py-3 flex items-center gap-3">
                    <div class="w-8 h-8 bg-red-100 rounded-full flex items-center justify-center flex-shrink-0">
                        <i class="fas fa-exclamation-triangle text-red-500 text-sm"></i>
                    </div>
                    <div>
                        <p class="text-sm font-semibold text-red-700">Sınırlı Stok</p>
                        <p id="lowStockText" class="text-xs text-red-600 mt-0.5">Bu varyanttan son <span id="lowStockCount" class="font-bold">0</span> adet kaldı.</p>
                    </div>
                </div>
            }

@if (cerceveSecimiGerekli)
            {
                <div id="frameSelectionBlock" class="mb-8">
                    <label class="mb-3 block text-xs font-medium uppercase tracking-widest text-[#1c1c18]">@Localizer["SelectFrameModel"]</label>
                    <div class="grid grid-cols-4 gap-3 sm:grid-cols-7">
                        @{
                            var cerceveMap = new Dictionary<string, (string image, string label)>
                            {
                                { "Çerçevesiz", ("/cercevesiz.png", "Çerçevesiz") },
                                { "Siyah", ("/siyah çerçeve .png", "Siyah") },
                                { "Beyaz", ("/beyaz çerçeve .png", "Beyaz") },
                                { "Gold", ("/altın çerçeve.png", "Altın") },
                                { "Gümüş", ("/gümüş çerçeve.png", "Gümüş") },
                                { "Meşe", ("/naturel çerçeve.png", "Naturel") },
                                { "Ceviz", ("/kahve çerçeve.png", "Ceviz") }
                            }!;
                        }
                        @foreach (var cerceve in cerceveModelleri)
                        {
                            var map = cerceveMap.GetValueOrDefault(cerceve, (image: string.Empty, label: cerceve));
                            <label class="group relative cursor-pointer rounded-lg border-2 border-[#e5e2dc] bg-white p-2 text-center transition-all hover:border-[#b58735] has-[:checked]:border-[#b58735] has-[:checked]:bg-[#f7f1e6] has-[:checked]:shadow-sm"
                                   title="@map.label"
                                   onclick="selectFrameOption(this, '@cerceve'); updatePriceWithFrame();">
                                <input type="radio" name="CerceveModeli" value="@cerceve" class="frame-radio absolute h-0 w-0 opacity-0" />
                                <div class="mb-1.5 flex h-16 items-center justify-center">
                                    <img src="@map.image" alt="@map.label" class="max-h-full max-w-full object-contain" loading="lazy" onerror="this.style.display='none'" />
                                </div>
                                <span class="text-[11px] font-medium text-[#47473d] group-has-[:checked]:text-[#313511]">@map.label</span>
                                <div class="absolute -top-1.5 -right-1.5 hidden h-4 w-4 items-center justify-center rounded-full bg-[#b58735] group-has-[:checked]:flex">
                                    <svg class="h-2.5 w-2.5 text-white" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                                </div>
                            </label>
                        }
                    </div>
                    <p id="frameSelectionError" class="mt-2 hidden text-xs font-medium text-red-600">@Localizer["FrameSelectionRequired"]</p>
                </div>
            }

            @if (stoktaVar)
            {
                <div class="flex items-end gap-4 mb-8">
                    <div>
                        <label class="block text-xs uppercase tracking-widest text-[#1c1c18] font-medium mb-3">@Localizer["Quantity"]</label>
                        <div class="flex items-center border border-[#e5e2dc] rounded bg-white">
                            <button type="button" class="w-10 h-12 flex items-center justify-center text-[#47473d] hover:bg-[#f1ede7] transition-colors" onclick="decreaseQuantity()">-</button>
                            <input type="number" id="productQuantity" class="w-12 h-12 text-center text-sm border-none bg-transparent p-0 focus:ring-0 text-[#1c1c18] font-semibold" value="@minSiparisAdedi" min="@minSiparisAdedi" max="@maxSiparisAdedi" readonly>
                            <button type="button" class="w-10 h-12 flex items-center justify-center text-[#47473d] hover:bg-[#f1ede7] transition-colors" onclick="increaseQuantity()">+</button>
                        </div>
                    </div>
                    
                    <form id="addToCartForm" method="post" action="/Sepet/Ekle" class="flex-1">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="UrunId" value="@Model.Id" />
                        <input type="hidden" id="selectedVariantId" name="SecenekId" value="@varsayilanSecenek?.Id" />
                        <input type="hidden" id="selectedQuantity" name="Adet" value="@minSiparisAdedi" />
                        <input type="hidden" id="selectedFrameModel" name="CerceveModeli" value="@(cerceveSecimiGerekli ? "" : "Çerçevesiz")" />
                        <input type="hidden" id="selectedFrameFarki" name="CerceveFarki" value="0" />
                        <input type="hidden" id="hediyePaketiHidden" name="HediyePaketi" value="false" />
                        <input type="hidden" id="hediyePaketFiyatiHidden" name="HediyePaketFiyati" value="@Model.HediyePaketFiyati.ToString(System.Globalization.CultureInfo.InvariantCulture)" />
                        <input type="hidden" id="musteriNotuHidden" name="MusteriNotu" value="" />

                        <button type="button" id="ajaxSepetBtn" class="w-full h-12 bg-[#313511] text-white text-xs uppercase tracking-widest rounded hover:bg-[#1c2001] transition-colors flex items-center justify-center gap-2">
                            <i class="fas fa-shopping-bag add-to-cart-icon"></i> <span class="add-to-cart-text">@Localizer["AddToCart"]</span>
                        </button>
                    </form>
                    <button type="button" onclick="window.toggleFavori(this, @Model.Id)" class="group/btn h-12 w-12 flex-shrink-0 flex items-center justify-center border border-[#e5e2dc] rounded-lg hover:border-[#b58735] hover:shadow-sm transition-all duration-200 bg-white" title="@Localizer["AddToFavorites"]">
                        <i class="far fa-heart text-[#47473d] group-hover/btn:text-red-400 transition-colors text-lg"></i>
                    </button>
                </div>

                @if (Model.HediyePaketiVarMi)
                {
                    <div class="mb-6 bg-[#fcf9f3] border border-[#e5e2dc] rounded-xl p-4">
                        <label class="flex items-center gap-3 cursor-pointer select-none" onclick="toggleGiftWrap(this)">
                            <input type="checkbox" id="giftWrapCheckbox" class="w-5 h-5 rounded border-[#b58735] text-[#313511] focus:ring-[#b58735] cursor-pointer" />
                            <div>
                                <span class="text-sm font-semibold text-[#1c1c18]">@Localizer["GiftWrap"]</span>
                                <span class="text-xs text-[#b58735] font-medium ml-1">(+@Model.HediyePaketFiyati.ToString("N0") @currencySymbol)</span>
                                <p class="text-xs text-[#47473d] mt-0.5">@Localizer["GiftWrapDesc"]</p>
                            </div>
                        </label>
                        <div id="giftNoteBlock" class="hidden mt-3 pl-8">
                            <textarea id="giftNoteText" rows="2" maxlength="500" class="w-full text-sm border border-[#e5e2dc] rounded-lg px-3 py-2 bg-white text-[#1c1c18] placeholder:text-[#a09e99] focus:border-[#b58735] focus:ring-1 focus:ring-[#b58735] outline-none resize-none" placeholder="@Localizer["GiftNotePlaceholder"]"></textarea>
                        </div>
                    </div>
                }

                <div id="selectionSummary" class="hidden mb-4 bg-gradient-to-r from-[#fcf9f3] to-[#f5f0e6] border-2 border-[#b58735] rounded-xl px-3 py-3 sm:px-5 sm:py-4">
                    <div class="flex items-center justify-center gap-1.5 overflow-hidden text-center sm:gap-2">
                        <div class="flex shrink-0 items-center gap-1 sm:gap-2">
                            <i class="fas fa-ruler-combined hidden sm:inline text-[#b58735] text-sm sm:text-lg"></i>
                            <span id="summaryOlcu" class="whitespace-nowrap text-sm sm:text-lg font-bold text-[#1c1c18]">-</span>
                        </div>
                        @if (cerceveSecimiGerekli)
                        {
                            <span class="shrink-0 text-[#b58735] text-sm sm:text-lg font-light">|</span>
                            <div class="min-w-0 max-w-[42%] sm:max-w-none">
                                <span id="summaryCerceve" class="block truncate text-sm sm:text-lg font-bold text-[#313511]">@Localizer["SelectFrame"]</span>
                            </div>
                        }
                        <span class="shrink-0 text-[#b58735] text-sm sm:text-lg font-light">|</span>
                        <div class="flex shrink-0 items-center">
                            <span id="summaryFiyat" class="whitespace-nowrap text-sm sm:text-xl font-extrabold text-[#313511]">0 @currencySymbol</span>
                            <span id="summaryBirimFiyat" class="hidden sm:inline text-xs text-[#47473d] font-normal ml-1"></span>
                        </div>
                        <span id="summaryGiftBadge" class="hidden shrink-0 text-[10px] bg-[#313511] text-white font-semibold uppercase tracking-wider rounded-full px-2.5 py-0.5">@Localizer["GiftWrapShort"]</span>
                    </div>
                </div>

                <div class="mb-8 flex flex-wrap items-center gap-3 border-y border-[#e5e2dc] py-4">
                <span class="mr-1 text-xs uppercase tracking-widest text-[#47473d]">@Localizer["Share"]</span>
                <a href="https://www.facebook.com/sharer/sharer.php?u=@encodedProductUrl" target="_blank" rel="noopener noreferrer" aria-label="@Localizer["ShareOnFacebook"]" class="flex h-9 w-9 items-center justify-center rounded-full border border-[#e5e2dc] bg-white text-[#313511] transition-colors hover:border-[#b58735] hover:text-[#b58735]">
                    <i class="fab fa-facebook-f text-sm"></i>
                </a>
                <a href="@(string.IsNullOrWhiteSpace(siteSettings.InstagramUrl) ? "https://www.instagram.com/" : siteSettings.InstagramUrl)" target="_blank" rel="noopener noreferrer" aria-label="@Localizer["OpenInInstagram"]" class="flex h-9 w-9 items-center justify-center rounded-full border border-[#e5e2dc] bg-white text-[#313511] transition-colors hover:border-[#b58735] hover:text-[#b58735]">
                    <i class="fab fa-instagram text-sm"></i>
                </a>
                <a href="https://wa.me/?text=@encodedProductTitle%20@encodedProductUrl" target="_blank" rel="noopener noreferrer" aria-label="@Localizer["ShareOnWhatsApp"]" class="flex h-9 w-9 items-center justify-center rounded-full border border-[#e5e2dc] bg-white text-[#313511] transition-colors hover:border-[#b58735] hover:text-[#b58735]">
                    <i class="fab fa-whatsapp text-sm"></i>
                </a>
                <button type="button" onclick="copyProductLink(this)" data-url="@productUrl" class="flex h-9 items-center gap-2 rounded-full border border-[#e5e2dc] bg-white px-4 text-xs uppercase tracking-widest text-[#313511] transition-colors hover:border-[#b58735] hover:text-[#b58735]">
                    <i class="fas fa-link text-xs"></i>
                    @Localizer["CopyLink"]
                </button>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.MalzemeBilgisi) || !string.IsNullOrWhiteSpace(Model.PaketlemeBilgisi))
            {
                <div class="mb-8 border-l-2 border-[#b58735] bg-[#f1ede7] px-5 py-4">
                    @if (!string.IsNullOrWhiteSpace(Model.MalzemeBilgisi))
                    {
                        <p class="mb-2 text-sm text-[#1c1c18]"><span class="font-semibold">@Localizer["MaterialLabel"]</span> @Model.MalzemeBilgisi</p>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.PaketlemeBilgisi))
                    {
                        <p class="text-sm text-[#47473d]"><span class="font-semibold text-[#1c1c18]">@Localizer["PackagingLabel"]</span> @Model.PaketlemeBilgisi</p>
                    }
                </div>
            }

            <div class="mb-8 grid grid-cols-1 gap-3 sm:grid-cols-3">
                <div class="border border-[#e5e2dc] bg-white px-4 py-3">
                    <p class="mb-1 flex items-center gap-2 text-[10px] uppercase tracking-widest text-[#313511]"><i class="fas fa-industry text-[#b58735]"></i> @Localizer["Production"]</p>
                    <p id="productionCardText" class="text-sm text-[#47473d]">@(gosterilecekUretimSuresi > 0 ? Localizer["BusinessDays", gosterilecekUretimSuresi].Value : Localizer["MadeToOrder"].Value)</p>
                </div>
                <div class="border border-[#e5e2dc] bg-white px-4 py-3">
                    <p class="mb-1 flex items-center gap-2 text-[10px] uppercase tracking-widest text-[#313511]"><i class="fas fa-box-open text-[#b58735]"></i> @Localizer["Packaging"]</p>
                    <p class="text-sm text-[#47473d]">@Localizer["CarefulDelivery"]</p>
                </div>
                <div class="border border-[#e5e2dc] bg-white px-4 py-3">
                    <p class="mb-1 flex items-center gap-2 text-[10px] uppercase tracking-widest text-[#313511]"><i class="fas fa-route text-[#b58735]"></i> @Localizer["Delivery"]</p>
                    <p class="text-sm text-[#47473d]">@Localizer["EstimatedDeliveryDays", gosterilecekTeslimSuresi]</p>
                </div>
            </div>
            }
            else
            {
                <div class="bg-amber-50 border border-amber-200 text-amber-700 p-4 rounded text-sm mb-8">
                    @Localizer["ProductNotAvailable"]
                </div>
            }

            <div class="grid grid-cols-3 gap-2 py-4 border-y border-[#e5e2dc]">
                <div class="text-center">
                    <i class="fas fa-building-columns text-[#b58735] mb-2 text-lg"></i>
                    <p class="text-xs text-[#1c1c18] font-semibold mb-1">@Localizer["BankTransfer"]</p>
                    <p class="text-[10px] text-[#47473d]">@Localizer["BankTransferFooter"]</p>
                </div>
                <div class="text-center">
                    <i class="fas fa-truck text-[#b58735] mb-2 text-lg"></i>
                    <p class="text-xs text-[#1c1c18] font-semibold mb-1">@Localizer["FreeShipping"]</p>
                    <p class="text-[10px] text-[#47473d]">@Localizer["BusinessDays", gosterilecekKargoSuresi]</p>
                </div>
                <div class="text-center">
                    <i class="fas fa-undo-alt text-[#b58735] mb-2 text-lg"></i>
                    <p class="text-xs text-[#1c1c18] font-semibold mb-1">@Localizer["ReturnGuarantee"]</p>
                    <p class="text-[10px] text-[#47473d]">@Localizer["WithinDays", iadeSuresi]</p>
                </div>
            </div>
            
        </div>
    </div>

    <!-- Tabs Section -->
    <div class="mt-20 border-t border-[#e5e2dc] pt-12">
        <div class="flex flex-col lg:flex-row gap-12">
            
            <!-- Left: Description and Specs -->
            <div class="lg:w-2/3 space-y-12">
                <div>
                    <h2 class="font-serif text-2xl text-[#313511] mb-6 flex items-center gap-3">
                        <i class="fas fa-file-alt text-[#b58735]"></i> @Localizer["ProductDescription"]
                    </h2>
                    <div class="prose prose-sm max-w-none text-[#47473d] leading-relaxed">
                        @Html.Raw(Model.LocalizedAciklama ?? Localizer["NoDescription"].Value)
                    </div>
                </div>

                @if (teknikTabloSatirlari.Any())
                {
                    <div>
                        <h2 class="font-serif text-2xl text-[#313511] mb-6 flex items-center gap-3">
                            <i class="fas fa-cogs text-[#b58735]"></i> @Localizer["TechnicalSpecs"]
                        </h2>
                        <div class="bg-white border border-[#e5e2dc] rounded-lg overflow-hidden">
                            <table class="w-full text-sm text-left">
                                <tbody class="divide-y divide-[#e5e2dc]">
                                    @foreach (var satir in teknikTabloSatirlari)
                                    {
                                        <tr class="hover:bg-[#fcf9f3]">
                                            <th class="px-6 py-4 font-semibold text-[#1c1c18] w-1/3 bg-[#f1ede7]">@satir.Baslik</th>
                                            <td class="px-6 py-4 text-[#47473d]">@satir.Deger</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
                
                @if (medyaVitriniVar)
                {
                    <div>
                        <h2 class="font-serif text-2xl text-[#313511] mb-6 flex items-center gap-3">
                            <i class="fas fa-photo-video text-[#b58735]"></i> @Localizer["MediaAndGalleries"]
                        </h2>
                        
                        @if (videoMedyalari.Any())
                        {
                            <div class="mb-8">
                                <h3 class="text-lg font-semibold text-[#1c1c18] mb-4">@Localizer["VideoTutorial"]</h3>
                                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                    @foreach (var medya in videoMedyalari)
                                    {
                                        <div class="bg-white border border-[#e5e2dc] rounded-lg overflow-hidden">
                                            <div class="aspect-video bg-black relative">
                                                @if (!string.IsNullOrWhiteSpace(ProductMediaEmbedHelper.GetEmbedUrl(medya.EtkinKaynak)))
                                                {
                                                    <iframe src="@ProductMediaEmbedHelper.GetEmbedUrl(medya.EtkinKaynak)" class="w-full h-full" title="@medya.Baslik" allowfullscreen></iframe>
                                                }
                                                else
                                                {
                                                    <video controls class="w-full h-full object-cover" poster="@medya.EtkinPosterYolu">
                                                        <source src="@(string.IsNullOrWhiteSpace(medya.VideoUrl) ? medya.ResimYolu : medya.VideoUrl)" type="video/mp4" />
                                                    </video>
                                                }
                                            </div>
                                            <div class="p-4">
                                                <h5 class="text-sm font-semibold text-[#1c1c18] mb-1">@medya.Baslik</h5>
                                                <p class="text-xs text-[#47473d]">@UrunMedyaCatalog.GetAreaLabel(medya.MedyaAlani)</p>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                    </div>
                }
            </div>

            <!-- Right: Reviews -->
            <div class="lg:w-1/3">
                <h2 class="font-serif text-2xl text-[#313511] mb-6 flex items-center gap-3">
                    <i class="fas fa-comments text-[#b58735]"></i> @Localizer["Reviews"]
                </h2>
                
                @if (yorumlar != null && yorumlar.Count > 0)
                {
                    var puanDagilimi = Enumerable.Range(1, 5).Select(p => new { Puan = p, Adet = yorumlar.Count(y => y.Puan == p), Yuzde = yorumlar.Count > 0 ? (int)Math.Round((double)yorumlar.Count(y => y.Puan == p) / yorumlar.Count * 100) : 0 }).OrderByDescending(x => x.Puan).ToList();

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
                        <div class="bg-white border border-[#e5e2dc] rounded-lg p-6 text-center">
                            <h3 class="font-serif text-5xl text-[#313511] mb-2">@ortalamaPuan.ToString("0.0")</h3>
                            <div class="text-[#b58735] mb-1">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    if (i <= tamYildiz)
                                    {
                                        <i class="fas fa-star"></i>
                                    }
                                    else if (i == tamYildiz + 1 && yarimYildiz)
                                    {
                                        <i class="fas fa-star-half-alt"></i>
                                    }
                                    else
                                    {
                                        <i class="far fa-star"></i>
                                    }
                                }
                            </div>
                            <p class="text-sm text-[#47473d] mb-4">@Localizer["TotalReviewCount", yorumSayisi]</p>
                            <button class="w-full border border-[#313511] text-[#313511] text-xs tracking-widest uppercase py-2.5 rounded hover:bg-[#313511] hover:text-white transition-colors" id="openCommentModalBtn">
                                @Localizer["WriteReview"]
                            </button>
                        </div>

                        <div class="bg-white border border-[#e5e2dc] rounded-lg p-6">
                            <h4 class="text-xs uppercase tracking-widest text-[#1c1c18] font-medium mb-4">Puan Dağılımı</h4>
                            @foreach (var item in puanDagilimi)
                            {
                                <div class="flex items-center gap-3 mb-2.5 last:mb-0">
                                    <span class="text-xs font-medium text-[#47473d] w-6 text-right">@item.Puan<i class="fas fa-star text-[10px] ml-0.5 text-[#b58735]"></i></span>
                                    <div class="flex-1 h-2.5 bg-[#f1ede7] rounded-full overflow-hidden">
                                        <div class="h-full bg-[#b58735] rounded-full transition-all duration-500" style="width: @item.Yuzde%"></div>
                                    </div>
                                    <span class="text-xs text-[#47473d] w-8 text-right">@item.Adet</span>
                                </div>
                            }
                        </div>
                    </div>

                    <div id="reviewsList" class="space-y-4 max-h-[600px] overflow-hidden transition-all duration-500">
                        @foreach (var yorum in yorumlar)
                        {
                            <div class="bg-white border border-[#e5e2dc] rounded-lg p-4">
                                <div class="flex items-start justify-between mb-2">
                                    <div class="flex items-center gap-3">
                                        <div class="w-10 h-10 rounded-full bg-[#f1ede7] text-[#313511] flex items-center justify-center font-semibold text-sm">
                                            @{
                                                var names = yorum.AdSoyad.Split(' ');
                                                string initials = "";
                                                if (names.Length > 0) { initials += names[0][0]; }
                                                if (names.Length > 1) { initials += names[names.Length - 1][0]; }
                                                else if (names[0].Length > 1) { initials += names[0][1]; }
                                            }
                                            @initials
                                        </div>
                                        <div>
                                            <h5 class="text-sm font-semibold text-[#1c1c18]">@yorum.AdSoyad</h5>
                                            <div class="text-[#b58735] text-[10px]">
                                                @for (int i = 0; i < yorum.Puan; i++) { <i class="fas fa-star"></i> }
                                            </div>
                                        </div>
                                    </div>
                                    <span class="text-[10px] text-[#47473d]">@yorum.OlusturulmaTarihi.ToString("dd MMM yyyy")</span>
                                </div>
                                <p class="text-sm text-[#47473d] mt-2">@yorum.YorumMetni</p>
                            </div>
                        }
                    </div>

                    @if (yorumlar.Count > 3)
                    {
                        <div class="text-center mt-6">
                            <button id="showAllReviewsBtn" class="inline-block border border-[#313511] text-[#313511] text-xs tracking-widest uppercase px-8 py-2.5 rounded hover:bg-[#313511] hover:text-white transition-colors" onclick="toggleAllReviews()">Tüm Yorumları Gör (@yorumlar.Count)</button>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-12 bg-white border border-[#e5e2dc] rounded-lg">
                        <i class="far fa-comments fa-3x text-[#e5e2dc] mb-4"></i>
                        <h5 class="text-[#313511] font-semibold mb-2">@Localizer["NoReviewsYet"]</h5>
                        <p class="text-sm text-[#47473d] mb-6">@Localizer["BeFirstToReview"]</p>
                        <button class="bg-[#313511] text-white text-xs tracking-widest uppercase px-6 py-2.5 rounded hover:bg-[#1c2001] transition-colors" id="openCommentModalBtnEmpty">
                            @Localizer["WriteFirstReview"]
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@{
    var benzerUrunler = ViewBag.BenzerUrunler as List<FilistinProje.Core.DTOs.BenzerUrunDto>;
}
@if (benzerUrunler != null && benzerUrunler.Count > 0)
{
    <section class="py-16 bg-[#fafaf8]">
        <div class="container mx-auto px-4">
            <div class="flex items-center justify-center mb-10">
                <hr class="w-1/4 border-[#e5e2dc] hidden md:block"/>
                <h2 class="font-serif text-3xl mx-8 text-center text-[#313511]">@Localizer["SimilarProducts"]</h2>
                <hr class="w-1/4 border-[#e5e2dc] hidden md:block"/>
            </div>
            <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-4 md:gap-6">
                @foreach (var item in benzerUrunler)
                {
                    decimal itemFiyat = item.IndirimliFiyat ?? item.Fiyat;
                    decimal? bEskiFiyat = (item.IndirimliFiyat != null && item.IndirimliFiyat < item.Fiyat) ? item.Fiyat : null;
                    string bProductUrl = !string.IsNullOrEmpty(item.Slug) ? $"/Urun/Detay/{item.Slug}-{item.Id}" : $"/Urun/Detay/{FilistinProje.Core.Helpers.SlugHelper.GenerateSlug(item.Baslik)}-{item.Id}";
                    string gorsel = !string.IsNullOrEmpty(item.AnaGorselUrl) ? item.AnaGorselUrl : "/img/products/placeholder.webp";
                    <a href="@bProductUrl" class="group block">
                        <div class="relative overflow-hidden mb-3 aspect-square bg-[#f1ede7] rounded">
                            <img alt="@item.LocalizedBaslik" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" src="@gorsel" loading="lazy" decoding="async" />
                        </div>
                        <h3 class="text-xs font-semibold text-[#1c1c18] tracking-wide line-clamp-2 mb-1">@item.LocalizedBaslik</h3>
                        <div class="flex items-center gap-2">
                            <span class="text-sm font-bold text-[#313511]">@itemFiyat.ToString("N2") @currencySymbol</span>
                            @if (bEskiFiyat != null)
                            {
                                <span class="text-xs text-[#999] line-through">@bEskiFiyat?.ToString("N2") @currencySymbol</span>
                            }
                        </div>
                    </a>
                }
            </div>
        </div>
    </section>
}



<script>
const PRODUCT_CURRENCY = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(currencySymbol));

// Modal event listeners
document.addEventListener('DOMContentLoaded', function() {
    const desktopModal = document.getElementById('desktopLightboxModal');
    const mobileModal = document.getElementById('mobileLightbox');
    const closeBtn = document.getElementById('closeDesktopModalBtn');

    [desktopModal, mobileModal].forEach(modal => {
        if (modal && modal.parentElement !== document.body) {
            document.body.appendChild(modal);
        }
    });

    if (closeBtn && desktopModal) {
        closeBtn.addEventListener('click', closeDesktopLightbox);
    }

    [desktopModal, mobileModal].forEach(modal => {
        if (modal) {
            modal.addEventListener('click', event => {
                if (event.target === modal) {
                    closeProductLightbox();
                }
            });
        }
    });

    window.addEventListener('keydown', event => {
        if (event.key === 'Escape' || event.code === 'Escape') {
            closeProductLightbox();
        }
    }, true);

    const commentModal = document.getElementById('commentModal');
    if (commentModal) {
        const openBtns = [document.getElementById('openCommentModalBtn'), document.getElementById('openCommentModalBtnEmpty')];
        openBtns.forEach(btn => btn && btn.addEventListener('click', () => {
            commentModal.classList.remove('hidden');
            commentModal.classList.add('flex');
        }));

        const closeCommentBtn = document.getElementById('closeCommentModalBtn');
        if (closeCommentBtn) {
            closeCommentBtn.addEventListener('click', () => {
                commentModal.classList.add('hidden');
                commentModal.classList.remove('flex');
            });
        }
    }

    setTimeout(function() {
        updateSelectionSummary();
        updateVariantCardStyles();
    }, 100);
});

document.getElementById('productQuantity')?.addEventListener('input', function() {
    var val = parseInt(this.value) || 0;
    var min = parseInt(this.getAttribute('min')) || 1;
    var max = parseInt(this.getAttribute('max')) || 99;
    if (val < min) this.value = min;
    if (val > max) this.value = max;
    var selectedQuantity = document.getElementById('selectedQuantity');
    if (selectedQuantity) selectedQuantity.value = this.value;
    updateSelectionSummary();
});

let currentZoom = 1;
let currentRotation = 0;
let previousBodyOverflow = '';

function syncLightboxImage() {
    const mainImage = document.getElementById('mainProductImage');
    if (!mainImage) return;

    const imageSrc = mainImage.currentSrc || mainImage.src;
    const imageAlt = mainImage.alt || mainImage.getAttribute('data-product-name') || '';

    const desktopImage = document.getElementById('desktopLightboxImage');
    if (desktopImage && imageSrc) {
        desktopImage.src = imageSrc;
        desktopImage.alt = imageAlt;
    }

    const mobileImage = document.getElementById('mobileLightboxImage');
    if (mobileImage && imageSrc) {
        mobileImage.src = imageSrc;
        mobileImage.alt = imageAlt;
    }
}

function lockLightboxScroll() {
    previousBodyOverflow = document.body.style.overflow;
    document.body.style.overflow = 'hidden';
}

function unlockLightboxScroll() {
    document.body.style.overflow = previousBodyOverflow;
}

function openProductLightbox() {
    syncLightboxImage();
    lockLightboxScroll();

    if (window.innerWidth >= 1024) {
        const dm = document.getElementById('desktopLightboxModal');
        if (dm) {
            dm.classList.remove('hidden');
            dm.classList.add('flex');
            resetDesktopZoom();
        }
    } else {
        const mm = document.getElementById('mobileLightbox');
        if (mm) {
            mm.classList.remove('hidden');
            mm.classList.add('flex');
            resetMobileZoom();
        }
    }
}

function toggleAllReviews() {
    var list = document.getElementById('reviewsList');
    var btn = document.getElementById('showAllReviewsBtn');
    if (!list || !btn) return;
    if (list.style.maxHeight && list.style.maxHeight !== '600px') {
        list.style.maxHeight = '600px';
        btn.textContent = 'Tüm Yorumları Gör (' + btn.textContent.match(/\d+/)?.[0] + ')';
    } else {
        list.style.maxHeight = list.scrollHeight + 'px';
        btn.textContent = 'Gizle';
    }
}

function closeProductLightbox() {
    closeDesktopLightbox();
    closeMobileLightbox();
}

function closeDesktopLightbox() {
    const dm = document.getElementById('desktopLightboxModal');
    if (dm) {
        dm.classList.add('hidden');
        dm.classList.remove('flex');
        resetDesktopZoom();
    }
    unlockLightboxScroll();
}

function closeMobileLightbox() {
    const mm = document.getElementById('mobileLightbox');
    if (mm) {
        mm.classList.add('hidden');
        mm.classList.remove('flex');
        resetMobileZoom();
    }
    unlockLightboxScroll();
}

function resetMobileZoom() {
    currentZoom = 1;
    currentRotation = 0;
    updateMobileTransform();
}

function zoomInMobile() {
    if (currentZoom < 3) { currentZoom += 0.5; updateMobileTransform(); }
}

function zoomOutMobile() {
    if (currentZoom > 1) { currentZoom -= 0.5; updateMobileTransform(); }
}

function rotateMobileImage() {
    currentRotation = (currentRotation + 90) % 360;
    updateMobileTransform();
}

function updateMobileTransform() {
    const img = document.getElementById('mobileLightboxImage');
    if (img) img.style.transform = `scale(${currentZoom}) rotate(${currentRotation}deg)`;
    const zl = document.getElementById('zoomLevel');
    if (zl) zl.innerText = `${Math.round(currentZoom * 100)}%`;
}

function resetDesktopZoom() {
    currentZoom = 1;
    currentRotation = 0;
    updateDesktopTransform();
}

function zoomInDesktop() {
    if (currentZoom < 3) { currentZoom += 0.5; updateDesktopTransform(); }
}

function zoomOutDesktop() {
    if (currentZoom > 1) { currentZoom -= 0.5; updateDesktopTransform(); }
}

function rotateDesktopImage() {
    currentRotation = (currentRotation + 90) % 360;
    updateDesktopTransform();
}

function updateDesktopTransform() {
    const img = document.getElementById('desktopLightboxImage');
    if (img) {
        img.style.transform = `scale(${currentZoom}) rotate(${currentRotation}deg)`;
    }
}

function changeProductImage(imageUrl, thumbnailElement, altText) {
    const mainImage = document.getElementById('mainProductImage');
    if (mainImage) {
        mainImage.src = imageUrl;
        if (altText) mainImage.alt = altText;
    }
    
    const deskImg = document.getElementById('desktopLightboxImage');
    if (deskImg) deskImg.src = imageUrl;
    
    const mobImg = document.getElementById('mobileLightboxImage');
    if (mobImg) mobImg.src = imageUrl;
    
    const thumbnails = document.querySelectorAll('.thumbnail-item');
    thumbnails.forEach(item => {
        if (item) {
            item.classList.remove('border-[#313511]');
            item.classList.add('border-transparent');
        }
    });
    if (thumbnailElement) {
        thumbnailElement.classList.remove('border-transparent');
        thumbnailElement.classList.add('border-[#313511]');
        thumbnailElement.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
    }

}

const FRAME_PRICE_PER_METER = 250;

function parseOlcu(olcuText) {
    if (!olcuText) return null;
    var match = olcuText.match(/(\d+(?:[.,]\d+)?)\s*(?:cm)?\s*[xX×]\s*(\d+(?:[.,]\d+)?)/i);
    if (!match) return null;
    var w = parseFloat(match[1].replace(',', '.'));
    var h = parseFloat(match[2].replace(',', '.'));
    if (isNaN(w) || isNaN(h)) return null;
    return { width: w, height: h };
}

function calcFrameFiyat(olcuText, cerceve) {
    if (!cerceve || cerceve === 'Çerçevesiz') return 0;
    var dims = parseOlcu(olcuText);
    if (!dims) return 0;
    var cevreMetre = ((dims.width + dims.height) * 2) / 100;
    return cevreMetre * FRAME_PRICE_PER_METER;
}

function updateSelectionSummary() {
    var selectedVariant = document.querySelector('.variant-radio:checked');
    var selectedFrame = document.querySelector('.frame-radio:checked');
    var summary = document.getElementById('selectionSummary');
    if (!summary) return;

    if (!selectedVariant && !selectedFrame) {
        summary.classList.add('hidden');
        return;
    }

    var olcu = selectedVariant ? selectedVariant.getAttribute('data-olcu') || selectedVariant.getAttribute('data-label') || '-' : '-';
    var cerceve = selectedFrame ? selectedFrame.value : null;
    var temelFiyat = selectedVariant ? parseFloat(selectedVariant.getAttribute('data-price')) || 0 : 0;
    var adet = parseInt(document.getElementById('productQuantity')?.value) || 1;
    var cerceveFarki = selectedVariant ? calcFrameFiyat(olcu, cerceve || 'Çerçevesiz') : 0;
    var toplamBirim = temelFiyat + cerceveFarki;
    var toplam = toplamBirim * adet;

    var summaryOlcuEl = document.getElementById('summaryOlcu');
    if (summaryOlcuEl) summaryOlcuEl.textContent = olcu;

    var summaryCerceveEl = document.getElementById('summaryCerceve');
    if (summaryCerceveEl) {
        summaryCerceveEl.textContent = cerceve || '@Localizer["SelectFrame"]';
    }

    var giftPrice = 0;
    var giftCheck = document.getElementById('giftWrapCheckbox');
    if (giftCheck && giftCheck.checked) {
        var giftPriceInput = document.getElementById('hediyePaketFiyatiHidden');
        if (giftPriceInput) giftPrice = parseFloat(giftPriceInput.value) || 0;
    }
    var toplamBirimGift = toplamBirim + giftPrice;
    var toplamGift = toplamBirimGift * adet;

    var summaryFiyatEl = document.getElementById('summaryFiyat');
    if (summaryFiyatEl) {
        summaryFiyatEl.textContent = toplamGift.toLocaleString('tr-TR', { minimumFractionDigits: 0, maximumFractionDigits: 2 }) + ' @currencySymbol';
    }

    var summaryBirimFiyatEl = document.getElementById('summaryBirimFiyat');
    if (summaryBirimFiyatEl) {
        summaryBirimFiyatEl.textContent = adet > 1 ? `(birim: ${toplamBirimGift.toLocaleString('tr-TR', { minimumFractionDigits: 0, maximumFractionDigits: 2 })} @currencySymbol)` : '';
    }

    var giftBadge = document.getElementById('summaryGiftBadge');
    if (giftBadge) {
        if (giftPrice > 0) {
            giftBadge.classList.remove('hidden');
        } else {
            giftBadge.classList.add('hidden');
        }
    }

    summary.classList.remove('hidden');
}

function toggleGiftWrap(container) {
    var checkbox = container.querySelector('input[type="checkbox"]');
    if (!checkbox) return;
    checkbox.checked = !checkbox.checked;
    
    var hiddenInput = document.getElementById('hediyePaketiHidden');
    if (hiddenInput) hiddenInput.value = checkbox.checked ? 'true' : 'false';
    
    var noteBlock = document.getElementById('giftNoteBlock');
    if (noteBlock) {
        if (checkbox.checked) {
            noteBlock.classList.remove('hidden');
        } else {
            noteBlock.classList.add('hidden');
        }
    }
    
    updateSelectionSummary();
    
    var priceDisplay = document.getElementById('priceDisplay');
    if (priceDisplay) {
        var selectedVariant = document.querySelector('.variant-radio:checked');
        if (selectedVariant) {
            var basePrice = parseFloat(selectedVariant.getAttribute('data-price')) || 0;
            var olcu = selectedVariant.getAttribute('data-olcu') || selectedVariant.getAttribute('data-label') || '';
            var selectedFrame = document.querySelector('.frame-radio:checked');
            var cerceve = selectedFrame ? selectedFrame.value : null;
            var cerceveFarki = calcFrameFiyat(olcu, cerceve || 'Çerçevesiz');
            var totalPrice = basePrice + cerceveFarki;
            if (checkbox.checked) {
                var giftPriceInput = document.getElementById('hediyePaketFiyatiHidden');
                if (giftPriceInput) totalPrice += parseFloat(giftPriceInput.value) || 0;
            }
            priceDisplay.innerHTML = totalPrice.toLocaleString('tr-TR', { minimumFractionDigits: 0, maximumFractionDigits: 2 }) + ' @currencySymbol';
        }
    }
}

function updatePriceWithFrame() {
    var selectedVariant = document.querySelector('.variant-radio:checked');
    var selectedFrame = document.querySelector('.frame-radio:checked');
    if (!selectedVariant) return;

    var basePrice = parseFloat(selectedVariant.getAttribute('data-price')) || 0;
    var olcu = selectedVariant.getAttribute('data-olcu') || selectedVariant.getAttribute('data-label') || '';
    var cerceve = selectedFrame ? selectedFrame.value : null;
    var cerceveFarki = calcFrameFiyat(olcu, cerceve || 'Çerçevesiz');
    var newPrice = basePrice + cerceveFarki;

    var priceDisplay = document.getElementById('priceDisplay');
    if (priceDisplay) {
        priceDisplay.innerHTML = `${newPrice.toLocaleString('tr-TR', { minimumFractionDigits: 0, maximumFractionDigits: 2 })} @currencySymbol`;
    }

    var frameFarkiInput = document.getElementById('selectedFrameFarki');
    if (frameFarkiInput) {
        frameFarkiInput.value = cerceveFarki.toFixed(2);
    }

    updateSelectionSummary();
}

function updateVariantCardStyles() {
    document.querySelectorAll('.variant-radio').forEach(function(radio) {
        var card = radio.closest('label');
        if (!card) return;
        if (radio.checked) {
            card.className = 'relative border-2 border-[#313511] bg-[#313511] text-white shadow-md rounded-lg px-4 py-3 cursor-pointer transition-all duration-150';
            var existingBadge = card.querySelector('.variant-check-badge');
            if (!existingBadge) {
                var badge = document.createElement('div');
                badge.className = 'variant-check-badge absolute -top-2 -right-2 w-5 h-5 bg-[#b58735] rounded-full flex items-center justify-center shadow-sm';
                badge.innerHTML = '<svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>';
                card.appendChild(badge);
            }
            var priceSpan = card.querySelector('.variant-price');
            if (priceSpan) priceSpan.className = 'variant-price text-xs text-white/80 font-medium';
            var stockSpan = card.querySelector('.variant-stock-warning');
            if (stockSpan) stockSpan.className = stockSpan.className.replace(/text-amber-600/g, 'text-amber-200');
        } else {
            card.className = 'relative border-2 border-[#e5e2dc] bg-white text-[#47473d] hover:border-[#b58735] rounded-lg px-4 py-3 cursor-pointer transition-all duration-150';
            var badge = card.querySelector('.variant-check-badge');
            if (badge) badge.remove();
            var priceSpan = card.querySelector('.variant-price');
            if (priceSpan) priceSpan.className = 'variant-price text-xs text-[#b58735] font-medium';
            var stockSpan = card.querySelector('.variant-stock-warning');
            if (stockSpan) stockSpan.className = stockSpan.className.replace(/text-amber-200/g, 'text-amber-600');
        }
    });
}

document.querySelectorAll('.variant-radio').forEach(function(radio) {
    radio.addEventListener('change', function() {
        if (this.checked) {
            var price = parseFloat(this.getAttribute('data-price')) || 0;
            var oldPrice = parseFloat(this.getAttribute('data-oldprice')) || 0;
            var imageUrl = this.getAttribute('data-image');
            var label = this.getAttribute('data-label');
            var isPreorder = this.getAttribute('data-preorder') === 'true';
            var stock = parseInt(this.getAttribute('data-stock')) || 0;
            var productionDays = parseInt(this.getAttribute('data-production')) || 0;

            var selectedVariantId = document.getElementById('selectedVariantId');
            if (selectedVariantId) selectedVariantId.value = this.value;

            updateVariantCardStyles();
            updatePriceWithFrame();
            
            var oldPriceDisplay = document.getElementById('oldPriceDisplay');
            var discountBadge = document.getElementById('discountBadge');
            var selectedFrame = document.querySelector('.frame-radio:checked');
            var cerceveFarki = 0;
            if (selectedFrame) {
                var olcuText = this.getAttribute('data-olcu') || this.getAttribute('data-label') || '';
                cerceveFarki = calcFrameFiyat(olcuText, selectedFrame.value);
            }
            var effectivePrice = price + cerceveFarki;
            var effectiveOldPrice = oldPrice > 0 ? oldPrice + cerceveFarki : 0;
            
            if (effectiveOldPrice > effectivePrice) {
                if (oldPriceDisplay) {
                    oldPriceDisplay.innerHTML = effectiveOldPrice.toLocaleString('tr-TR', {minimumFractionDigits: 2}) + ' ' + PRODUCT_CURRENCY;
                    oldPriceDisplay.classList.remove('hidden');
                }
                if (discountBadge) {
                    var discount = Math.round((1 - (effectivePrice / effectiveOldPrice)) * 100);
                    discountBadge.innerHTML = '%' + discount + ' @Localizer["Discount"]';
                    discountBadge.classList.remove('hidden');
                }
            } else {
                if (oldPriceDisplay) oldPriceDisplay.classList.add('hidden');
                if (discountBadge) discountBadge.classList.add('hidden');
            }
            
            if (imageUrl) {
                changeProductImage(imageUrl, null, label);
            }
            
            var variantSummary = document.getElementById('variantSummaryText');
            if (variantSummary) {
                variantSummary.innerHTML = '<i class="fas fa-layer-group mr-1.5"></i> ' + label;
                variantSummary.classList.remove('hidden');
            }
            
            var lowStockWarning = document.getElementById('lowStockWarning');
            var lowStockCount = document.getElementById('lowStockCount');
            if (lowStockWarning && lowStockCount) {
                if (stock > 0 && stock <= 5) {
                    lowStockCount.textContent = stock;
                    lowStockWarning.classList.remove('hidden');
                } else {
                    lowStockWarning.classList.add('hidden');
                }
            }

            var stockStatusText = document.getElementById('stockStatusText');
            if (stockStatusText) {
                if (stock > 0) {
                    stockStatusText.innerHTML = '<i class="fas fa-check-circle text-green-600"></i> @Localizer["MadeToOrder"]';
                } else if (isPreorder) {
                    stockStatusText.innerHTML = '<i class="fas fa-clock text-blue-600"></i> @Localizer["PreOrder"]';
                } else {
                    stockStatusText.innerHTML = '<i class="fas fa-times-circle text-red-600"></i> @Localizer["OutOfStock"]';
                }
            }

            var productionTimeText = document.getElementById('productionTimeText');
            if (productionTimeText && productionDays > 0) {
                productionTimeText.innerHTML = '<i class="fas fa-hammer text-[#a09e99]"></i> @Localizer["ProductionInDaysJS"]'.replace('{0}', productionDays);
            }

            var productionCardText = document.getElementById('productionCardText');
            if (productionCardText && productionDays > 0) {
                productionCardText.innerText = '@Localizer["BusinessDaysJS"]'.replace('{0}', productionDays);
            }
            
            var quantityInput = document.getElementById('productQuantity');
            if (quantityInput) {
                quantityInput.max = stock > 0 ? stock : (isPreorder ? 99 : 1);
                var minQuantity = parseInt(quantityInput.getAttribute('min')) || 1;
                quantityInput.value = minQuantity;
                var selectedQuantity = document.getElementById('selectedQuantity');
                if (selectedQuantity) selectedQuantity.value = minQuantity;
            }
        }
    });
});

document.querySelectorAll('.frame-radio').forEach(function(radio) {
    radio.addEventListener('change', function () {
        var selectedFrameModel = document.getElementById('selectedFrameModel');
        if (selectedFrameModel) selectedFrameModel.value = this.value;
        var frameSelectionError = document.getElementById('frameSelectionError');
        var frameSelectionBlock = document.getElementById('frameSelectionBlock');
        if (frameSelectionError) frameSelectionError.classList.add('hidden');
        if (frameSelectionBlock) frameSelectionBlock.classList.remove('ring-2', 'ring-red-400', 'ring-offset-2');

        updatePriceWithFrame();
    });
});

function increaseQuantity() {
    const input = document.getElementById('productQuantity');
    const selectedInput = document.getElementById('selectedQuantity');
    if (!input) return;
    
    let max = parseInt(input.getAttribute('max')) || 99;
    let val = parseInt(input.value) || 1;
    if (val < max) {
        input.value = val + 1;
        if (selectedInput) selectedInput.value = val + 1;
        updateSelectionSummary();
    }
}

function decreaseQuantity() {
    const input = document.getElementById('productQuantity');
    const selectedInput = document.getElementById('selectedQuantity');
    if (!input) return;
    
    let min = parseInt(input.getAttribute('min')) || 1;
    let val = parseInt(input.value) || 1;
    if (val > min) {
        input.value = val - 1;
        if (selectedInput) selectedInput.value = val - 1;
        updateSelectionSummary();
    }
}

const ajaxSepetBtn = document.getElementById('ajaxSepetBtn');
if (ajaxSepetBtn) {
    ajaxSepetBtn.addEventListener('click', async function (e) {
        e.preventDefault();
        const form = document.getElementById('addToCartForm');
        const token = form.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
        const frameSelectionBlock = document.getElementById('frameSelectionBlock');
        const selectedFrame = document.querySelector('input[name="CerceveModeli"]:checked');

        if (frameSelectionBlock && !selectedFrame) {
            const frameSelectionError = document.getElementById('frameSelectionError');
            if (frameSelectionError) frameSelectionError.classList.remove('hidden');
            frameSelectionBlock.classList.add('ring-2', 'ring-red-400', 'ring-offset-2');
            frameSelectionBlock.scrollIntoView({ behavior: 'smooth', block: 'center' });

            if (window.showToast) {
                window.showToast('@Localizer["FrameSelectionRequired"]', 'error');
            } else {
                alert('@Localizer["FrameSelectionRequired"]');
            }

            return;
        }
        
        const url = '/Sepet/Ekle';
        const urunId = form.querySelector('input[name="UrunId"]')?.value;
        const adet = form.querySelector('input[name="Adet"]')?.value;
        const secenekId = document.getElementById('selectedVariantId')?.value;
        const cerceveModeli = selectedFrame?.value;
        const cerceveFarki = document.getElementById('selectedFrameFarki')?.value;
        
        const params = new URLSearchParams();
        params.append('UrunId', urunId);
        params.append('Adet', adet || '1');
        if (secenekId) params.append('SecenekId', secenekId);
        if (cerceveModeli) params.append('CerceveModeli', cerceveModeli);
        if (cerceveFarki && cerceveFarki !== '0') params.append('CerceveFarki', cerceveFarki);
        
        var hediyePaketiCheck = document.getElementById('giftWrapCheckbox');
        if (hediyePaketiCheck && hediyePaketiCheck.checked) {
            params.append('HediyePaketi', 'true');
            var hediyeFiyat = document.getElementById('hediyePaketFiyatiHidden')?.value;
            if (hediyeFiyat) params.append('HediyePaketFiyati', hediyeFiyat);
            var giftNote = document.getElementById('giftNoteText')?.value;
            if (giftNote) params.append('MusteriNotu', giftNote);
        }
        
        const originalHtml = this.innerHTML;
        this.innerHTML = '<i class="fas fa-check"></i> @Localizer["Added"]';
        this.disabled = true;

        fetch(url + '?' + params.toString(), {
            method: 'POST',
            headers: {
                'RequestVerificationToken': token
            }
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                const btn = this;
                const icon = btn.querySelector('.add-to-cart-icon');
                const text = btn.querySelector('.add-to-cart-text');
                
                if (icon) {
                    icon.classList.remove('fa-shopping-bag');
                    icon.classList.add('fa-check');
                }
                if (text) {
                    text.textContent = '@Localizer["Added"]';
                }
                btn.classList.add('bg-green-600');

                // Update cart counter with bounce
                const cartCounter = document.getElementById('cartItemCount');
                const cartCounterMobile = document.getElementById('cartItemCountMobile');
                const cartCounters = [cartCounter, cartCounterMobile].filter(el => el);
                
                cartCounters.forEach(counter => {
                    let current = parseInt(counter.innerText) || 0;
                    let added = parseInt(adet) || 1;
                    counter.innerText = current + added;
                    counter.classList.add('scale-150', 'bounce-animation');
                    setTimeout(() => {
                        counter.classList.remove('scale-150', 'bounce-animation');
                        counter.classList.add('scale-125');
                        setTimeout(() => counter.classList.remove('scale-125'), 150);
                    }, 300);
                });

                if (window.showToast) {
                    window.showToast('@Localizer["AddedToCartSuccess"]', 'success');
                }
                
                // 1 saniye sonra butonu sıfırla (tekrar tıklanabilir olsun)
                setTimeout(() => {
                    if (icon) {
                        icon.classList.remove('fa-check');
                        icon.classList.add('fa-shopping-bag');
                    }
                    if (text) text.textContent = '@Localizer["AddToCart"]';
                    btn.classList.remove('bg-green-600');
                    btn.disabled = false;
                }, 1000);
                
                // 2 saniye sonra sepete yönlendir
                setTimeout(() => {
                    window.location.href = '/Sepet';
                }, 2000);
            } else {
                if (window.showToast) {
                    window.showToast(data.message || '@Localizer["ErrorOccurred"]', 'error');
                } else {
                    alert(data.message || '@Localizer["ErrorOccurred"]');
                }
                this.innerHTML = originalHtml;
                this.disabled = false;
            }
        })
        .catch(error => {
            console.error(error);
            if (window.showToast) {
                window.showToast('@Localizer["ConnectionError"]', 'error');
            } else {
                alert('@Localizer["ConnectionErrorShort"]');
            }
            this.innerHTML = originalHtml;
            this.disabled = false;
        });
    });
}

function navigateGallery(direction, event) {
    if (event) event.stopPropagation();
    
    const thumbnails = Array.from(document.querySelectorAll('.thumbnail-item'));
    if (thumbnails.length <= 1) return;
    
    const mainImage = document.getElementById('mainProductImage');
    const currentSrc = mainImage.getAttribute('src');
    
    let currentIndex = thumbnails.findIndex(item => item.getAttribute('data-image') === currentSrc);
    if (currentIndex === -1) currentIndex = 0;
    
    let nextIndex;
    if (direction === 'next') {
        nextIndex = (currentIndex + 1) % thumbnails.length;
    } else {
        nextIndex = (currentIndex - 1 + thumbnails.length) % thumbnails.length;
    }
    
    const nextThumb = thumbnails[nextIndex];
    if (nextThumb) {
        nextThumb.click();
    }
}

function copyProductLink(button) {
    const url = button?.getAttribute('data-url') || window.location.href;
    const originalHtml = button.innerHTML;

    const markCopied = () => {
        button.innerHTML = '<i class="fas fa-check text-xs"></i> @Localizer["Copied"]';
        setTimeout(() => {
            button.innerHTML = originalHtml;
        }, 1800);
    };

    if (navigator.clipboard && window.isSecureContext) {
        navigator.clipboard.writeText(url).then(markCopied).catch(() => {
            window.prompt('@Localizer["ProductLink"]', url);
        });
        return;
    }

    window.prompt('@Localizer["ProductLink"]', url);
}

function selectFrameOption(label, value) {
    const radios = document.querySelectorAll('input[name="CerceveModeli"]');
    radios.forEach(r => r.checked = false);
    const radio = label.querySelector('input[name="CerceveModeli"]');
    if (radio) {
        radio.checked = true;
        radio.dispatchEvent(new Event('change', { bubbles: true }));
    }
}

// Masaüstü fare koordinatlarına göre pürüzsüz zoom (transform-origin)
document.addEventListener("DOMContentLoaded", function () {
    const container = document.getElementById('mainProductImageContainer');
    const img = document.getElementById('mainProductImage');
    
    if (container && img) {
        container.addEventListener('mousemove', function (e) {
            const rect = container.getBoundingClientRect();
            const x = ((e.clientX - rect.left) / rect.width) * 100;
            const y = ((e.clientY - rect.top) / rect.height) * 100;
            img.style.transformOrigin = x + '% ' + y + '%';
        });
        container.addEventListener('mouseleave', function () {
            img.style.transformOrigin = 'center center';
        });
    }
});
</script>
