@model FilistinProje.Core.Varliklar.Urun
@inject IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["AddNewProduct"];
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4>🎨 @Localizer["AddNewCanvas"]</h4>
                </div>
                <div class="card-body">

                    <form asp-action="Ekle" method="post">

                        <div class="mb-3">
                            <label class="form-label">@Localizer["ProductName"]</label>
                            <input asp-for="Baslik" class="form-control" placeholder="@Localizer["ProductNamePlaceholder"]" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">@Localizer["SelectCategory"]</label>
                            <select asp-for="KategoriId" class="form-control" asp-items="ViewBag.Kategoriler">
                                <option value="">@Localizer["PleaseSelect"]</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">@Localizer["ImageUrlLabel"]</label>
                            <input asp-for="AnaGorselUrl" class="form-control" placeholder="@Localizer["ImageUrlPlaceholder"]" required />
                            <small class="text-muted">@Localizer["ImageUrlHelp"]</small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">@Localizer["Description"]</label>
                            <textarea asp-for="Aciklama" class="form-control" rows="3"></textarea>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success btn-lg">💾 @Localizer["Save"]</button>
                            <a href="/Urun" class="btn btn-secondary">@Localizer["Cancel"]</a>
                        </div>

                    </form>
                    </div>
            </div>
        </div>
    </div>
</div>
