@model IEnumerable<FilistinProje.Core.Varliklar.Siparis>
@inject FilistinProje.Service.Services.ISiteSettingsService SiteSettingsService
@inject IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["MyOrders"];
    var siteSettings = SiteSettingsService.GetSettings();
    var currencySymbol = string.IsNullOrWhiteSpace(siteSettings.ParaBirimi) ? "₪" : siteSettings.ParaBirimi;
    var aktifFiltre = Context.Request.Query["filtre"].FirstOrDefault() ?? "all";
    var siparisler = Model.OrderByDescending(x => x.OlusturulmaTarihi).ToList();
    var filtreliSiparisler = aktifFiltre switch
    {
        "pending" => siparisler.Where(x => x.Durum == 0 || x.Durum == 1 || x.Durum == 8).ToList(),
        "shipped" => siparisler.Where(x => x.Durum == 2).ToList(),
        "delivered" => siparisler.Where(x => x.Durum == 3).ToList(),
        "cancelled" => siparisler.Where(x => x.Durum >= 4).ToList(),
        _ => siparisler
    };
}

@{
    string DurumAdi(int durum) => durum switch
    {
        8 => Localizer["StatusPackaging"].Value,
        0 => Localizer["StatusOrderReceived"].Value,
        1 => Localizer["StatusPreparing"].Value,
        2 => Localizer["StatusShipped"].Value,
        3 => Localizer["StatusDelivered"].Value,
        5 => Localizer["StatusReturnRequest"].Value,
        6 => Localizer["StatusReturnApproved"].Value,
        7 => Localizer["StatusReturnCompleted"].Value,
        _ => Localizer["StatusCancelled"].Value
    };
    string DurumIkon(int durum) => durum switch
    {
        8 => "fas fa-box",
        0 => "fas fa-clock",
        1 => "fas fa-box-open",
        2 => "fas fa-truck-fast",
        3 => "fas fa-circle-check",
        5 => "fas fa-rotate-left",
        6 => "fas fa-clipboard-check",
        7 => "fas fa-coins",
        _ => "fas fa-circle-xmark"
    };
    string DurumRenk(int durum) => durum switch
    {
        8 => "bg-amber-50 text-amber-700 border-amber-200",
        3 or 7 => "bg-green-50 text-green-700 border-green-200",
        2 => "bg-blue-50 text-blue-700 border-blue-200",
        1 => "bg-amber-50 text-amber-700 border-amber-200",
        4 => "bg-red-50 text-red-700 border-red-200",
        _ => "bg-gray-50 text-gray-600 border-gray-200"
    };
}

<!-- Breadcrumb -->
<div class="bg-[#f1ede7] border-b border-[#e5e2dc] py-3">
    <div class="container mx-auto px-4 flex items-center gap-2 text-xs text-[#47473d]">
        <a href="/" class="hover:text-[#313511] transition-colors">@Localizer["HomePage"]</a>
        <span>/</span>
        <a href="/Profil" class="hover:text-[#313511] transition-colors">@Localizer["MyAccount"]</a>
        <span>/</span>
        <span class="text-[#1c1c18] font-medium">@Localizer["MyOrders"]</span>
    </div>
</div>

<div class="container mx-auto px-4 py-10">
    <div class="flex flex-col lg:flex-row gap-8">

        <!-- Yan Menü -->
        <aside class="lg:w-56 flex-shrink-0">
            <div class="bg-white border border-[#e5e2dc] rounded-lg overflow-hidden">
                <div class="bg-[#313511] p-4 text-center">
                    <p class="text-white text-sm font-medium">@Localizer["MyAccount"]</p>
                </div>
                <nav class="p-2">
                    <a href="/Profil" class="flex items-center gap-3 px-3 py-2.5 rounded text-sm text-[#47473d] hover:bg-[#f1ede7] transition-colors mb-1">
                        <i class="fas fa-user w-4"></i> @Localizer["Overview"]
                    </a>
                    <a href="/Profil/Siparislerim" class="flex items-center gap-3 px-3 py-2.5 rounded text-sm text-[#313511] bg-[#f1ede7] font-semibold mb-1">
                        <i class="fas fa-box w-4"></i> @Localizer["MyOrders"]
                    </a>
                    <a href="/Profil/Adreslerim" class="flex items-center gap-3 px-3 py-2.5 rounded text-sm text-[#47473d] hover:bg-[#f1ede7] transition-colors mb-1">
                        <i class="fas fa-location-dot w-4"></i> @Localizer["MyAddresses"]
                    </a>
                    <a href="/Favori" class="flex items-center gap-3 px-3 py-2.5 rounded text-sm text-[#47473d] hover:bg-[#f1ede7] transition-colors mb-1">
                        <i class="fas fa-heart w-4"></i> @Localizer["MyFavorites"]
                    </a>
                    <hr class="border-[#e5e2dc] my-2" />
                    <form action="/Hesap/CikisYap" method="post" class="m-0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="w-full flex items-center gap-3 px-3 py-2.5 rounded text-sm text-red-500 hover:bg-red-50 transition-colors text-left">
                            <i class="fas fa-right-from-bracket w-4"></i> @Localizer["Logout"]
                        </button>
                    </form>
                </nav>
            </div>
        </aside>

        <!-- Ana İçerik -->
        <main class="flex-1 min-w-0">
            <div class="flex items-center justify-between mb-8">
                <div>
                    <h1 class="font-serif text-3xl text-[#313511]">@Localizer["MyOrders"]</h1>
                    <p class="text-xs text-[#47473d] mt-1">@Localizer["OrderCount", Model.Count()]</p>
                </div>
                <a href="/Urun" class="border border-[#313511] text-[#313511] text-xs tracking-widest uppercase px-4 py-2 rounded hover:bg-[#313511] hover:text-white transition-colors">
                    @Localizer["BackToShopping"]
                </a>
            </div>

            @if (!filtreliSiparisler.Any())
            {
                <div class="text-center py-24 bg-white border border-[#e5e2dc] rounded-lg">
                    <i class="fas fa-basket-shopping fa-4x text-[#e5e2dc] mb-6"></i>
                    <h3 class="font-serif text-2xl text-[#313511] mb-3">@(aktifFiltre == "all" ? Localizer["NoOrdersYet"] : Localizer["NoOrdersInFilter"])</h3>
                    <p class="text-sm text-[#47473d] mb-6 max-w-sm mx-auto">@Localizer["BrowseProductsToOrder"]</p>
                    <a href="/Urun" class="inline-block bg-[#313511] text-white px-6 py-3 text-xs tracking-widest uppercase rounded-full hover:bg-[#1c2001] transition-colors">
                        @Localizer["BrowseProducts"]
                    </a>
                </div>
            }
            else
            {
                <!-- Filtre -->
                <div class="flex flex-wrap gap-2 mb-6">
                    <a href="?filtre=all" class="text-xs px-3 py-1.5 rounded transition-colors @(aktifFiltre == "all" ? "bg-[#313511] text-white" : "bg-white border border-[#e5e2dc] text-[#47473d] hover:bg-[#f1ede7]")">@Localizer["FilterAll"]</a>
                    <a href="?filtre=pending" class="text-xs px-3 py-1.5 rounded transition-colors @(aktifFiltre == "pending" ? "bg-[#313511] text-white" : "bg-white border border-[#e5e2dc] text-[#47473d] hover:bg-[#f1ede7]")">@Localizer["FilterPending"]</a>
                    <a href="?filtre=shipped" class="text-xs px-3 py-1.5 rounded transition-colors @(aktifFiltre == "shipped" ? "bg-[#313511] text-white" : "bg-white border border-[#e5e2dc] text-[#47473d] hover:bg-[#f1ede7]")">@Localizer["FilterShipped"]</a>
                    <a href="?filtre=delivered" class="text-xs px-3 py-1.5 rounded transition-colors @(aktifFiltre == "delivered" ? "bg-[#313511] text-white" : "bg-white border border-[#e5e2dc] text-[#47473d] hover:bg-[#f1ede7]")">@Localizer["FilterDelivered"]</a>
                    <a href="?filtre=cancelled" class="text-xs px-3 py-1.5 rounded transition-colors @(aktifFiltre == "cancelled" ? "bg-[#313511] text-white" : "bg-white border border-[#e5e2dc] text-[#47473d] hover:bg-[#f1ede7]")">@Localizer["FilterCancelled"]</a>
                </div>
                <div class="space-y-3">
                    @foreach (var item in filtreliSiparisler)
                    {
                        <div class="bg-white border border-[#e5e2dc] rounded-lg p-5 hover:border-[#c5c0b8] transition-colors">
                            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                                <div class="flex items-center gap-4">
                                    <div class="w-10 h-10 rounded-full bg-[#e2e6b3] flex items-center justify-center flex-shrink-0">
                                        <i class="@DurumIkon(item.Durum) text-[#313511] text-sm"></i>
                                    </div>
                                    <div>
                                        <div class="flex items-center gap-2 flex-wrap">
                                            <span class="font-semibold text-[#1c1c18] text-sm">#@item.Id</span>
                                            <span class="border text-xs px-2 py-0.5 rounded-full @DurumRenk(item.Durum)">
                                                @DurumAdi(item.Durum)
                                            </span>
                                            @if (item.FaturaYuklendiMi)
                                            {
                                                <a href="/Siparis/FaturaIndir?id=@item.Id" target="_blank" class="text-xs bg-green-50 text-green-700 border border-green-200 px-2 py-0.5 rounded hover:bg-green-100 transition-colors" title="@Localizer["DownloadInvoice"]">
                                                    <i class="fas fa-file-pdf mr-1"></i>@Localizer["Invoice"]
                                                </a>
                                            }
                                        </div>
                                        <div class="text-xs text-[#47473d] mt-0.5">
                                            @item.OlusturulmaTarihi.ToString("dd MMMM yyyy") — @item.OlusturulmaTarihi.ToString("HH:mm")
                                        </div>
                                    </div>
                                </div>
                                <div class="flex items-center gap-4 sm:flex-shrink-0">
                                    @if (!string.IsNullOrEmpty(item.KargoTakipNo))
                                    {
                                        <span class="text-xs bg-[#f1ede7] text-[#47473d] px-2 py-1 rounded">
                                            <i class="fas fa-barcode mr-1"></i>@item.KargoTakipNo
                                        </span>
                                    }
                                    <span class="font-semibold text-[#1c1c18]">@item.ToplamTutar.ToString("N2") @currencySymbol</span>
                                    <a href="/Profil/SiparisDetay/@item.Id"
                                       class="text-xs border border-[#e5e2dc] px-3 py-1.5 rounded hover:bg-[#f1ede7] text-[#313511] transition-colors whitespace-nowrap">
                                        @Localizer["Detail"] <i class="fas fa-chevron-right ml-1 text-[10px]"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </main>
    </div>
</div>
