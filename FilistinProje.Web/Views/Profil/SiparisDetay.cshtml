@model FilistinProje.Core.Varliklar.Siparis
@using FilistinProje.Core.Helpers
@inject FilistinProje.Service.Services.ISiteSettingsService SiteSettingsService
@inject IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["OrderDetail"] + " #" + Model.Id;
    var siteSettings = SiteSettingsService.GetSettings();
    var currencySymbol = string.IsNullOrWhiteSpace(siteSettings.ParaBirimi) ? "₪" : siteSettings.ParaBirimi;
    var urunler = ViewBag.Urunler as List<dynamic>;
    var statusStep = Model.Durum;
    var isCancelled = Model.Durum == 4;
    var isReturn = Model.Durum >= 5;
    var araToplam = Model.ToplamTutar + Model.IndirimTutari - Model.KargoUcreti;
}

<!-- Breadcrumb -->
<div class="bg-[#f1ede7] border-b border-[#e5e2dc] py-3">
    <div class="container mx-auto px-4 flex items-center gap-2 text-xs text-[#47473d]">
        <a href="/" class="hover:text-[#313511] transition-colors">@Localizer["HomePage"]</a>
        <span>/</span>
        <a href="/Profil" class="hover:text-[#313511] transition-colors">@Localizer["MyAccount"]</a>
        <span>/</span>
        <a href="/Profil/Siparislerim" class="hover:text-[#313511] transition-colors">@Localizer["MyOrders"]</a>
        <span>/</span>
        <span class="text-[#1c1c18] font-medium">#@Model.Id</span>
    </div>
</div>

<div class="container mx-auto px-4 py-10">
    <div class="flex flex-col lg:flex-row gap-8">
        
        <!-- Yan Menü -->
        <aside class="lg:w-56 flex-shrink-0">
            <div class="bg-white border border-[#e5e2dc] rounded-lg overflow-hidden">
                <div class="bg-[#313511] p-4 text-center">
                    <p class="text-white text-sm font-medium">@Localizer["MyAccount"]</p>
                </div>
                <nav class="p-2">
                    <a href="/Profil" class="flex items-center gap-3 px-3 py-2.5 rounded text-sm text-[#47473d] hover:bg-[#f1ede7] transition-colors mb-1">
                        <i class="fas fa-user w-4"></i> @Localizer["Overview"]
                    </a>
                    <a href="/Profil/Siparislerim" class="flex items-center gap-3 px-3 py-2.5 rounded text-sm text-[#313511] bg-[#f1ede7] font-semibold mb-1">
                        <i class="fas fa-box w-4"></i> @Localizer["MyOrders"]
                    </a>
                    <a href="/Profil/Adreslerim" class="flex items-center gap-3 px-3 py-2.5 rounded text-sm text-[#47473d] hover:bg-[#f1ede7] transition-colors mb-1">
                        <i class="fas fa-location-dot w-4"></i> @Localizer["MyAddresses"]
                    </a>
                    <a href="/Favori" class="flex items-center gap-3 px-3 py-2.5 rounded text-sm text-[#47473d] hover:bg-[#f1ede7] transition-colors mb-1">
                        <i class="fas fa-heart w-4"></i> @Localizer["MyFavorites"]
                    </a>
                    <hr class="border-[#e5e2dc] my-2" />
                    <form action="/Hesap/CikisYap" method="post" class="m-0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="w-full flex items-center gap-3 px-3 py-2.5 rounded text-sm text-red-500 hover:bg-red-50 transition-colors text-left">
                            <i class="fas fa-right-from-bracket w-4"></i> @Localizer["Logout"]
                        </button>
                    </form>
                </nav>
            </div>
        </aside>

        <main class="flex-1 min-w-0">
            <!-- Header -->
            <div class="flex flex-col md:flex-row md:items-center justify-between mb-8 gap-4">
                <div>
                    <span class="text-xs uppercase tracking-widest text-[#b58735] font-medium block mb-1">@Localizer["OrderDetail"]</span>
                    <h1 class="font-serif text-3xl text-[#313511]">@Localizer["OrderNo"] #@Model.Id</h1>
                    <p class="text-xs text-[#47473d] mt-2">@Localizer["CreatedOnDate", Model.OlusturulmaTarihi.ToString("dd.MM.yyyy HH:mm")]</p>
                </div>
                <div class="flex gap-3">
                    @if (Model.Durum == 0 || Model.Durum == 1)
                    {
                        var iptalSuresiSaat = siteSettings.IptalSuresiSaat;
                        var gecenSure = (DateTime.UtcNow - Model.OlusturulmaTarihi.ToUniversalTime()).TotalHours;
                        var kalanSaat = iptalSuresiSaat - gecenSure;
                        var iptalEdilebilir = iptalSuresiSaat <= 0 || gecenSure <= iptalSuresiSaat;

                        if (iptalEdilebilir && iptalSuresiSaat > 0)
                        {
                            <div class="flex items-center gap-2 text-xs text-amber-600 bg-amber-50 border border-amber-200 rounded px-3 py-1.5">
                                <i class="fas fa-clock"></i>
                                <span>
                                    @if (kalanSaat > 1)
                                    {
                                        @Localizer["CancelTimeRemaining_Hours", (int)kalanSaat]
                                    }
                                    else if (kalanSaat > 0)
                                    {
                                        @Localizer["CancelTimeRemaining_Minutes", (int)(kalanSaat * 60)]
                                    }
                                    else
                                    {
                                        @Localizer["CancelTimeExpiring"]
                                    }
                                </span>
                            </div>
                        }

                        if (iptalEdilebilir)
                        {
                            <form id="cancelForm-@Model.Id" method="post" action="/Profil/SiparisIptal" class="inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@Model.Id" />
                                <button type="button" onclick="confirmCancel(@Model.Id)"
                                        class="border border-red-200 text-red-600 bg-red-50 hover:bg-red-100 text-xs tracking-widest uppercase px-4 py-2 rounded transition-colors flex items-center gap-2">
                                    <i class="fas fa-ban"></i> @Localizer["CancelOrder"]
                                </button>
                            </form>
                        }
                        else if (iptalSuresiSaat > 0)
                        {
                            <div class="flex items-center gap-2 text-xs text-gray-500 bg-gray-50 border border-gray-200 rounded px-3 py-1.5">
                                <i class="fas fa-clock"></i>
                                <span>@Localizer["CancelPeriodExpired"]</span>
                            </div>
                        }
                    }
                    @if (Model.Durum == 3)
                    {
                        <a href="/Profil/IadeOlustur?siparisId=@Model.Id" class="border border-red-200 text-red-600 bg-red-50 hover:bg-red-100 text-xs tracking-widest uppercase px-4 py-2 rounded transition-colors flex items-center gap-2">
                            <i class="fas fa-rotate-left"></i> @Localizer["ReturnRequest"]
                        </a>
                    }
                    <a href="/Profil/Siparislerim" class="border border-[#e5e2dc] text-[#47473d] text-xs tracking-widest uppercase px-4 py-2 rounded hover:bg-[#f1ede7] transition-colors flex items-center gap-2">
                        <i class="fas fa-arrow-left"></i> @Localizer["BackToList"]
                    </a>
                </div>
            </div>

            @if (ViewBag.IadeDurumu != null)
            {
                <div class="bg-amber-50 border border-amber-200 text-amber-700 p-4 rounded mb-8 text-sm flex items-center gap-3">
                    <i class="fas fa-clock-rotate-left"></i>
                    <div>@Localizer["ReturnProcessActive"] <strong>@ViewBag.IadeDurumu</strong></div>
                </div>
            }

            <!-- Takip Adımları -->
            <div class="bg-white border border-[#e5e2dc] rounded-lg p-6 mb-8">
                <h3 class="font-serif text-xl text-[#313511] mb-6 border-b border-[#e5e2dc] pb-4">
                    @(isReturn ? Localizer["ReturnProcess"].Value : Localizer["OrderTracking"].Value)
                </h3>
                
                <div class="flex flex-col md:flex-row gap-6 relative">
                    <!-- Progress Line -->
                    <div class="hidden md:block absolute top-6 left-0 right-0 h-0.5 bg-[#e5e2dc] -z-10 mx-12"></div>
                    
                    @if (isCancelled)
                    {
                        <div class="text-sm text-red-600 bg-red-50 p-4 rounded border border-red-100 w-full">
                            <strong>@Localizer["CancelledOrder"]:</strong> @Localizer["CancelledOrderMessage"]
                        </div>
                    }
                    else if (isReturn)
                    {
                        var iadeAdimlari = new[] {
                            new { Icon = "fas fa-file-signature", Baslik = Localizer["StepRequestReceived"].Value, Puan = 5 },
                            new { Icon = "fas fa-clipboard-check", Baslik = Localizer["StepApproved"].Value, Puan = 6 },
                            new { Icon = "fas fa-coins", Baslik = Localizer["StepReturnCompleted"].Value, Puan = 7 },
                            new { Icon = "fas fa-circle-check", Baslik = Localizer["StepProcessClosed"].Value, Puan = 7 }
                        };
                        
                        foreach (var adim in iadeAdimlari)
                        {
                            var isActive = isReturn
                                ? statusStep >= adim.Puan
                                : SiparisDurumHelper.GetProgressStep(Model.Durum) >= SiparisDurumHelper.GetProgressStep(adim.Puan);
                            <div class="flex-1 text-center relative z-10">
                                <div class="w-12 h-12 mx-auto rounded-full flex items-center justify-center mb-3 transition-colors @(isActive ? "bg-[#313511] text-white" : "bg-[#f1ede7] text-[#a09e99] border-2 border-white")">
                                    <i class="@adim.Icon"></i>
                                </div>
                                <h4 class="text-xs font-semibold uppercase tracking-wider @(isActive ? "text-[#1c1c18]" : "text-[#a09e99]")">@adim.Baslik</h4>
                            </div>
                        }
                    }
                    else
                    {
                        var adimlar = new[] {
                            new { Icon = "fas fa-clipboard-check", Baslik = Localizer["StepOrderReceived"].Value, Puan = 0 },
                            new { Icon = "fas fa-box-open", Baslik = Localizer["StepProductionPreparing"].Value, Puan = 1 },
                            new { Icon = "fas fa-box", Baslik = Localizer["StepPackaging"].Value, Puan = 8 },
                            new { Icon = "fas fa-truck", Baslik = Localizer["StepInTransit"].Value, Puan = 2 },
                            new { Icon = "fas fa-circle-check", Baslik = Localizer["StepDelivered"].Value, Puan = 3 }
                        };
                        
                        foreach (var adim in adimlar)
                        {
                            var isActive = isReturn
                                ? statusStep >= adim.Puan
                                : SiparisDurumHelper.GetProgressStep(Model.Durum) >= SiparisDurumHelper.GetProgressStep(adim.Puan);
                            <div class="flex-1 text-center relative z-10">
                                <div class="w-12 h-12 mx-auto rounded-full flex items-center justify-center mb-3 transition-colors @(isActive ? "bg-[#313511] text-white" : "bg-[#f1ede7] text-[#a09e99] border-2 border-white")">
                                    <i class="@adim.Icon"></i>
                                </div>
                                <h4 class="text-xs font-semibold uppercase tracking-wider @(isActive ? "text-[#1c1c18]" : "text-[#a09e99]")">@adim.Baslik</h4>
                            </div>
                        }
                    }
                </div>

                @if (!string.IsNullOrEmpty(Model.KargoTakipNo) && !isCancelled)
                {
                    <div class="mt-8 bg-[#f8f9fa] border border-[#e5e2dc] rounded p-4 flex items-center justify-between">
                        <div>
                            <p class="text-[10px] uppercase tracking-widest text-[#47473d] mb-1">@Localizer["TrackingNumber"]</p>
                            <p class="font-mono text-lg font-medium text-[#1c1c18]" id="trackingNo">@Model.KargoTakipNo</p>
                        </div>
                        <button type="button" class="border border-[#e5e2dc] bg-white text-[#47473d] text-xs px-3 py-1.5 rounded hover:bg-[#f1ede7] transition-colors flex items-center gap-2" onclick="copyTracking(this)">
                            <i class="far fa-copy"></i> @Localizer["Copy"]
                        </button>
                    </div>
                }
            </div>

            <!-- Ürünler Tablosu -->
            <div class="bg-white border border-[#e5e2dc] rounded-lg overflow-hidden mb-8">
                <div class="p-6 border-b border-[#e5e2dc]">
                    <h3 class="font-serif text-xl text-[#313511]">@Localizer["PurchasedProducts"]</h3>
                </div>
                
                <div class="overflow-x-auto">
                    <table class="w-full text-sm text-left">
                        <thead class="bg-[#f1ede7] text-[#47473d] text-xs uppercase tracking-widest">
                            <tr>
                                <th class="px-6 py-4 font-medium">@Localizer["Product"]</th>
                                <th class="px-6 py-4 font-medium">@Localizer["Features"]</th>
                                <th class="px-6 py-4 font-medium text-center">@Localizer["Quantity"]</th>
                                <th class="px-6 py-4 font-medium text-right">@Localizer["Total"]</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-[#e5e2dc]">
                            @if (urunler != null)
                            {
                                foreach (var item in urunler)
                                {
                                    <tr class="hover:bg-[#fcf9f3] transition-colors">
                                        <td class="px-6 py-4">
                                            <div class="flex items-center gap-4">
                                            <img src="@item.Resim" alt="@item.Baslik" class="w-16 h-16 object-cover rounded border border-[#e5e2dc]" loading="lazy" decoding="async" />
                                                <div>
                                                    <a href="/Urun/Detay/@(FilistinProje.Core.Helpers.SlugHelper.GenerateSlug(item.Baslik))-@item.UrunId" class="font-semibold text-[#1c1c18] hover:text-[#b58735] transition-colors block mb-1">@item.Baslik</a>
                                                    <div class="text-xs text-[#47473d]">@Localizer["UnitPrice"]: @item.Fiyat.ToString("N2") @currencySymbol</div>
                                                    @if (Model.Durum == 3)
                                                    {
                                                        <a href="/Urun/Detay/@(FilistinProje.Core.Helpers.SlugHelper.GenerateSlug(item.Baslik))-@item.UrunId#reviews-section" class="text-[10px] text-[#b58735] hover:text-[#313511] uppercase tracking-wider mt-2 inline-block">
                                                            <i class="fas fa-star mr-1"></i>@Localizer["RateProductShort"]
                                                        </a>
                                                    }
                                                </div>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4">
                                            <span class="inline-block border border-[#e5e2dc] rounded bg-white px-2 py-1 text-xs">@item.Secenek</span>
                                            @if (!string.IsNullOrEmpty(item.SecenekDetay))
                                            {
                                                <div class="text-xs text-[#47473d] mt-2">@item.SecenekDetay</div>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(item.CerceveModeli))
                                            {
                                                <div class="text-xs text-[#47473d] mt-2">@Localizer["FrameLabel"]: @item.CerceveModeli</div>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(item.MusteriNotu))
                                            {
                                                <div class="mt-2 text-xs text-amber-700 bg-amber-50 border border-amber-200 rounded px-2 py-1">
                                                    <i class="fas fa-sticky-note mr-1"></i><strong>@Localizer["NoteLabel"]:</strong> @item.MusteriNotu
                                                </div>
                                            }
                                        </td>
                                        <td class="px-6 py-4 text-center font-medium">x @item.Adet</td>
                                        <td class="px-6 py-4 text-right font-medium">@item.Toplam.ToString("N2") @currencySymbol</td>
                                    </tr>
                                }
                            }
                        </tbody>
                        <tfoot class="bg-[#fcf9f3]">
                            <tr>
                                <td colspan="3" class="px-6 py-4 text-right text-[#47473d]">
                                    <div class="text-xs mb-1">@Localizer["Subtotal"]</div>
                                    <div class="font-medium text-[#1c1c18]">@araToplam.ToString("N2") @currencySymbol</div>
                                    @if (Model.IndirimTutari > 0)
                                    {
                                        <div class="text-green-600 text-xs mt-2">
                                            <i class="fas fa-tag mr-1"></i>@Localizer["Discount"] (@Model.KuponKodu): -@Model.IndirimTutari.ToString("N2") @currencySymbol
                                        </div>
                                    }
                                    <div class="text-xs mt-2">@Localizer["ShippingLabel"]: @(Model.KargoUcreti == 0 ? Localizer["Free"].Value : $"{Model.KargoUcreti.ToString("N2")} {currencySymbol}")</div>
                                </td>
                                <td class="px-6 py-4 text-right border-l border-[#e5e2dc]">
                                    <div class="text-[10px] uppercase tracking-widest text-[#47473d] mb-1">@Localizer["GrandTotal"]</div>
                                    <div class="font-serif text-2xl text-[#313511]">@Model.ToplamTutar.ToString("N2") @currencySymbol</div>
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>

            <!-- Adres ve Ödeme Bilgileri -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <!-- Teslimat Adresi -->
                <div class="bg-white border border-[#e5e2dc] rounded-lg p-6">
                    <h3 class="font-serif text-lg text-[#313511] mb-6 flex items-center gap-2 border-b border-[#e5e2dc] pb-3">
                        <i class="fas fa-location-dot text-[#b58735]"></i> @Localizer["DeliveryAddress"]
                    </h3>
                    <div class="space-y-4 text-sm">
                        <div class="flex gap-3">
                            <i class="fas fa-user text-[#a09e99] mt-1 w-4"></i>
                            <div>
                                <div class="text-[10px] uppercase tracking-widest text-[#a09e99] mb-0.5">@Localizer["FullName"]</div>
                                <div class="font-medium text-[#1c1c18]">@Model.MusteriAdSoyad</div>
                            </div>
                        </div>
                        <div class="flex gap-3">
                            <i class="fas fa-phone text-[#a09e99] mt-1 w-4"></i>
                            <div>
                                <div class="text-[10px] uppercase tracking-widest text-[#a09e99] mb-0.5">@Localizer["Phone"]</div>
                                <div class="font-medium text-[#1c1c18]">@Model.Telefon</div>
                            </div>
                        </div>
                        <div class="flex gap-3">
                            <i class="fas fa-map text-[#a09e99] mt-1 w-4"></i>
                            <div>
                                <div class="text-[10px] uppercase tracking-widest text-[#a09e99] mb-0.5">@Localizer["Address"]</div>
                                <div class="text-[#1c1c18]">@Model.AcikAdres</div>
                                <div class="text-xs text-[#47473d] mt-1">@Model.Ilce / @Model.Sehir</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Ödeme Bilgisi -->
                <div class="bg-white border border-[#e5e2dc] rounded-lg p-6">
                    <h3 class="font-serif text-lg text-[#313511] mb-6 flex items-center gap-2 border-b border-[#e5e2dc] pb-3">
                        <i class="fas fa-credit-card text-[#b58735]"></i> @Localizer["PaymentInfo"]
                    </h3>
                    <div class="space-y-4 text-sm">
                        <div class="flex gap-3">
                            <i class="fas fa-shield-halved text-[#a09e99] mt-1 w-4"></i>
                            <div>
                                <div class="text-[10px] uppercase tracking-widest text-[#a09e99] mb-0.5">@Localizer["PaymentStatus"]</div>
                                <div class="font-medium text-green-600">@Localizer["PaymentSuccessful"]</div>
                            </div>
                        </div>
                        <div class="flex gap-3">
                            <i class="fas fa-file-invoice text-[#a09e99] mt-1 w-4"></i>
                            <div>
                                <div class="text-[10px] uppercase tracking-widest text-[#a09e99] mb-0.5">@Localizer["Invoice"]</div>
                                @if (Model.FaturaYuklendiMi)
                                {
                                    <a href="/Siparis/FaturaIndir?id=@Model.Id" target="_blank" class="inline-flex items-center gap-2 text-green-600 hover:text-green-700 font-medium">
                                        <i class="fas fa-file-pdf"></i> @Localizer["DownloadInvoice"]
                                    </a>
                                    @if (Model.FaturaMailGonderildiMi)
                                    {
                                        <div class="text-xs text-green-600 mt-1">
                                            <i class="fas fa-check-circle mr-1"></i>@Localizer["SentViaEmail"] (@Model.FaturaMailGonderimTarihi?.ToString("dd.MM.yyyy"))
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="text-[#47473d]">@Localizer["InvoiceNotCreated"]</div>
                                }
                            </div>
                        </div>
                        <div class="flex gap-3">
                            <i class="fas fa-history text-[#a09e99] mt-1 w-4"></i>
                            <div>
                                <div class="text-[10px] uppercase tracking-widest text-[#a09e99] mb-0.5">@Localizer["DocumentsAndRecords"]</div>
                                <div class="text-[#1c1c18]">@Localizer["OrderRecordAdded"]</div>
                                <div class="text-xs text-[#47473d] mt-1">@Localizer["SupportContactInfo"]</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>

<script>
    function copyTracking(btn) {
        var copyText = document.getElementById('trackingNo');
        if (!copyText) return;

        navigator.clipboard.writeText(copyText.innerText);

        var originalHtml = btn.innerHTML;
        btn.innerHTML = '<i class="fas fa-check"></i> @Localizer["Copied"]';

        setTimeout(function () {
            btn.innerHTML = originalHtml;
        }, 1800);
    }

    function confirmCancel(orderId) {
        if (confirm('@Localizer["CancelOrderConfirm"]')) {
            document.getElementById('cancelForm-' + orderId).submit();
        }
    }
</script>
