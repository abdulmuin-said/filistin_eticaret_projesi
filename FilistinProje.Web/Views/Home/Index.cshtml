@using FilistinProje.Core.Varliklar
@model FilistinProje.Web.Models.HomeViewModel
@inject FilistinProje.Service.Services.ISiteSettingsService SiteSettingsService
@inject IStringLocalizer<SharedResource> Localizer

@{
    var siteSettings = SiteSettingsService.GetSettings();
    var currencySymbol = string.IsNullOrWhiteSpace(siteSettings.ParaBirimi) ? "₪" : siteSettings.ParaBirimi;
    var brandName = string.IsNullOrWhiteSpace(siteSettings.MarkaAdi) ? siteSettings.SiteAdi : siteSettings.MarkaAdi;
    ViewData["Title"] = Localizer["HomePage"];
    ViewData["SeoTitle"] = string.Format(Localizer["HomeSeoTitle"], brandName);
    ViewData["MetaDescription"] = string.Format(Localizer["HomeMetaDescription"], brandName);
    ViewData["MetaKeywords"] = Localizer["HomeMetaKeywords"];
    ViewData["OgType"] = "website";
    var aktifSlaytlar = Model.AktifSlaytlar ?? new List<FilistinProje.Core.Varliklar.Slayt>();
    var siteUrl = SiteSettingsService.BuildAbsoluteUrl(string.Empty);
    string BuildProductUrl(FilistinProje.Core.Varliklar.Urun urun)
        => "/Urun/Detay/" + (string.IsNullOrEmpty(urun.Slug) ? (FilistinProje.Core.Helpers.SlugHelper.GenerateSlug(urun.Baslik) + "-" + urun.Id) : urun.Slug + "-" + urun.Id);

    var websiteSchema = new Dictionary<string, object?>
    {
        ["@context"] = "https://schema.org",
        ["@type"] = "WebSite",
        ["name"] = brandName,
        ["url"] = siteUrl,
        ["potentialAction"] = new Dictionary<string, object?>
        {
            ["@type"] = "SearchAction",
            ["target"] = SiteSettingsService.BuildAbsoluteUrl("/Urun?s={search_term_string}"),
            ["query-input"] = "required name=search_term_string"
        }
    };

    var organizationSchema = new Dictionary<string, object?>
    {
        ["@context"] = "https://schema.org",
        ["@type"] = "Organization",
        ["name"] = brandName,
        ["url"] = siteUrl,
        ["logo"] = SiteSettingsService.BuildAbsoluteUrl(string.IsNullOrWhiteSpace(siteSettings.SiteLogoUrl) ? "/74anrps48logo2.svg" : siteSettings.SiteLogoUrl),
        ["description"] = ViewData["MetaDescription"]
    };
}

<script type="application/ld+json">
@Html.Raw(System.Text.Json.JsonSerializer.Serialize(websiteSchema))
</script>
<script type="application/ld+json">
@Html.Raw(System.Text.Json.JsonSerializer.Serialize(organizationSchema))
</script>
@if (aktifSlaytlar.Any())
{
<!-- BEGIN: HeroSection - Modern Reve.com Tarzı Slider -->
<section class="relative w-full h-[55vw] min-h-[180px] max-h-[320px] md:h-[700px] md:max-h-none overflow-hidden bg-[#1a1a1a]" id="heroSlider">

    <!-- Slaytlar (Fade geçiş) -->
    <div id="heroSlidesContainer" class="relative w-full h-full">
        @for (int i = 0; i < aktifSlaytlar.Count; i++)
        {
            var slide = aktifSlaytlar[i];
            var hasContent = !string.IsNullOrWhiteSpace(slide.LocalizedBaslik)
                          || !string.IsNullOrWhiteSpace(slide.LocalizedAltBaslik)
                          || !string.IsNullOrWhiteSpace(slide.LocalizedAciklama);

            <div class="hero-slide absolute inset-0 w-full h-full @(i == 0 ? "active" : "")"
                 data-index="@i"
                 style="z-index: @(aktifSlaytlar.Count - i);">

                @if (!string.IsNullOrWhiteSpace(slide.VideoUrl))
                {
                    <video class="absolute inset-0 w-full h-full object-cover"
                           muted playsinline preload="metadata"
                           data-hero-video>
                        <source src="@slide.VideoUrl">
                    </video>
                }
                else
                {
                    <img src="@(string.IsNullOrEmpty(slide.ResimUrl) ? "https://images.unsplash.com/photo-1586023492125-27b2c045efd7?w=1600&q=80&auto=format&fit=crop" : slide.ResimUrl)"
                         alt="@(string.IsNullOrWhiteSpace(slide.LocalizedBaslik) ? Localizer["HomepageSlider"] : slide.LocalizedBaslik)"
                         class="absolute inset-0 w-full h-full object-cover"
                         loading="@(i == 0 ? "eager" : "lazy")"
                         decoding="async"
                         fetchpriority="@(i == 0 ? "high" : "auto")">
                }

                <!-- Koyu Gradyan Overlay -->
                <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-transparent md:bg-gradient-to-r md:from-black/70 md:via-black/40 md:to-transparent"></div>

                <!-- Slayt İçeriği (Başlık + Buton) -->
                @if (hasContent)
                {
                    <div class="hero-content absolute inset-0 flex items-end md:items-center z-10">
                        <div class="container mx-auto px-4 sm:px-6 pb-8 md:pb-16 md:px-12 lg:px-20">
                            <div class="max-w-lg md:max-w-xl lg:max-w-2xl hero-text-container">
                                @if (!string.IsNullOrWhiteSpace(slide.LocalizedAltBaslik))
                                {
                                    <p class="hero-subtitle text-xs md:text-sm lg:text-base font-medium uppercase tracking-[0.2em] text-[#c6ca99] mb-2 md:mb-3 drop-shadow-lg">
                                        @slide.LocalizedAltBaslik
                                    </p>
                                }
                                @if (!string.IsNullOrWhiteSpace(slide.LocalizedBaslik))
                                {
                                    <h2 class="hero-title text-xl sm:text-2xl md:text-4xl lg:text-5xl xl:text-6xl font-bold text-white leading-tight drop-shadow-2xl mb-3 md:mb-4">
                                        @slide.LocalizedBaslik
                                    </h2>
                                }
                                @if (!string.IsNullOrWhiteSpace(slide.LocalizedAciklama))
                                {
                                    <p class="hero-description text-xs sm:text-sm md:text-base lg:text-lg text-white/80 max-w-md md:max-w-xl leading-relaxed drop-shadow-lg mb-4 md:mb-6 line-clamp-2 md:line-clamp-3">
                                        @slide.LocalizedAciklama
                                    </p>
                                }
                                @{
                                    var btnText = slide.LocalizedButonMetni;
                                    var btnUrl = slide.BaglantiUrl;
                                }
                                @if (!string.IsNullOrWhiteSpace(btnText) && !string.IsNullOrWhiteSpace(btnUrl))
                                {
                                    <a href="@btnUrl"
                                       class="hero-btn inline-flex items-center gap-2 px-5 py-2.5 md:px-7 md:py-3 rounded-full bg-[#c6ca99] text-[#1a1a1a] text-xs md:text-sm font-semibold tracking-wide
                                              hover:bg-white hover:text-[#1a1a1a] transition-all duration-300 shadow-lg hover:shadow-xl
                                              active:scale-95">
                                        @btnText
                                        <svg class="w-3.5 h-3.5 md:w-4 md:h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
                                        </svg>
                                    </a>
                                }
                                @if (!string.IsNullOrWhiteSpace(btnText) && string.IsNullOrWhiteSpace(btnUrl))
                                {
                                    <span class="hero-btn inline-flex items-center gap-2 px-5 py-2.5 md:px-7 md:py-3 rounded-full bg-[#c6ca99] text-[#1a1a1a] text-xs md:text-sm font-semibold tracking-wide shadow-lg cursor-default">
                                        @btnText
                                    </span>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <!-- Ok Butonları (Sol / Sağ) - Modern Stil -->
    <button id="heroPrev" onclick="heroSlide(-1)" aria-label="@Localizer["PreviousSlide"]"
            class="absolute left-2 md:left-6 top-1/2 -translate-y-1/2 z-20 w-9 h-9 md:w-12 md:h-12 flex items-center justify-center
                   rounded-full bg-white/10 backdrop-blur-md border border-white/20 text-white
                   hover:bg-white/25 hover:border-white/40 transition-all duration-300
                   opacity-0 md:opacity-100 group hover:scale-105 active:scale-95">
        <svg class="w-4 h-4 md:w-5 md:h-5 transition-transform duration-300 group-hover:-translate-x-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5"/>
        </svg>
    </button>
    <button id="heroNext" onclick="heroSlide(1)" aria-label="@Localizer["NextSlide"]"
            class="absolute right-2 md:right-6 top-1/2 -translate-y-1/2 z-20 w-9 h-9 md:w-12 md:h-12 flex items-center justify-center
                   rounded-full bg-white/10 backdrop-blur-md border border-white/20 text-white
                   hover:bg-white/25 hover:border-white/40 transition-all duration-300
                   opacity-0 md:opacity-100 group hover:scale-105 active:scale-95">
        <svg class="w-4 h-4 md:w-5 md:h-5 transition-transform duration-300 group-hover:translate-x-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/>
        </svg>
    </button>

    <!-- Nokta İndikatörler - Modern Stil -->
    <div class="absolute bottom-3 md:bottom-8 left-1/2 -translate-x-1/2 z-20 flex items-center gap-1.5 md:gap-2.5" id="heroDots">
        @for (int i = 0; i < aktifSlaytlar.Count; i++)
        {
            <button onclick="heroGoTo(@i)"
                    class="hero-dot block appearance-none border-0 p-0 leading-none cursor-pointer
                           rounded-full transition-all duration-500 ease-out min-h-0
                           @(i == 0 ? "bg-white w-2.5 h-2.5 md:w-3 md:h-3" : "bg-white/40 w-1.5 h-1.5 md:w-2 md:h-2 hover:bg-white/60")"
                    aria-label="@string.Format(Localizer["SlideN"], i+1)"></button>
        }
    </div>

    <!-- İlerleme Çubuğu - İnce, Şeffaf -->
    <div class="absolute bottom-0 left-0 z-20 w-full h-[2px] md:h-[3px] bg-white/10">
        <div id="heroProgress" class="h-full bg-[#c6ca99]/80 transition-none rounded-full" style="width: 0%"></div>
    </div>

</section>
<!-- END: HeroSection -->
}

<script>
(function() {
    const TOTAL = @(aktifSlaytlar.Count > 0 ? aktifSlaytlar.Count : 1);
    const INTERVAL = 5000;
    const PROGRESS_STEP = 50;
    const FADE_DURATION = 700;

    let current = 0;
    let autoTimer = null;
    let progressTimer = null;
    let progressVal = 0;
    let isTransitioning = false;

    const container = document.getElementById('heroSlidesContainer');
    const slides    = document.querySelectorAll('.hero-slide');
    const dots      = document.querySelectorAll('.hero-dot');
    const progressBar = document.getElementById('heroProgress');
    const slider    = document.getElementById('heroSlider');
    const videos    = document.querySelectorAll('[data-hero-video]');
    const prevBtn   = document.getElementById('heroPrev');
    const nextBtn   = document.getElementById('heroNext');
    const isRtl     = document.documentElement.dir === 'rtl';

    if (!slides.length || !slider) return;

    // Mobilde ok butonlarını slider hover'ında göster
    if (prevBtn && nextBtn) {
        slider.addEventListener('mouseenter', () => {
            prevBtn.classList.remove('opacity-0');
            nextBtn.classList.remove('opacity-0');
        });
        slider.addEventListener('mouseleave', () => {
            if (window.innerWidth >= 768) return;
            prevBtn.classList.add('opacity-0');
            nextBtn.classList.add('opacity-0');
        });
    }

    function stopInactiveVideos(activeVideo) {
        videos.forEach(video => {
            video.onended = null;
            video.onerror = null;
            if (video !== activeVideo) {
                video.pause();
                try { video.currentTime = 0; } catch (_) { }
            }
        });
    }

    function animateTextContent(slideEl, entering) {
        const title = slideEl.querySelector('.hero-title');
        const subtitle = slideEl.querySelector('.hero-subtitle');
        const description = slideEl.querySelector('.hero-description');
        const btn = slideEl.querySelector('.hero-btn');
        const items = [subtitle, title, description, btn].filter(Boolean);

        if (!entering) {
            items.forEach(el => {
                el.classList.add('opacity-0', 'translate-y-4');
                el.style.transitionDelay = '0ms';
            });
            return;
        }

        // Reset
        items.forEach(el => {
            el.classList.add('opacity-0', 'translate-y-4');
            el.style.transitionDelay = '0ms';
            el.classList.add('transition-all', 'duration-500', 'ease-out');
        });

        // Stagger animation
        items.forEach((el, i) => {
            setTimeout(() => {
                el.classList.remove('opacity-0', 'translate-y-4');
                el.style.transitionDelay = '0ms';
            }, 100 + i * 120);
        });
    }

    function updateDots(idx) {
        dots.forEach((d, i) => {
            d.className = 'hero-dot block appearance-none border-0 p-0 leading-none cursor-pointer rounded-full transition-all duration-500 ease-out min-h-0';
            if (i === idx) {
                d.classList.add('bg-white', 'w-2.5', 'h-2.5', 'md:w-3', 'md:h-3');
            } else {
                d.classList.add('bg-white/40', 'w-1.5', 'h-1.5', 'md:w-2', 'md:h-2', 'hover:bg-white/60');
            }
        });
    }

    function goTo(idx) {
        if (isTransitioning) return;
        isTransitioning = true;
        clearAuto();

        const prevIdx = current;
        current = (idx + TOTAL) % TOTAL;

        const prevSlide = slides[prevIdx];
        const nextSlide = slides[current];

        if (!nextSlide) { isTransitioning = false; return; }

        // Mevcut slaydı opacity 0 yap
        if (prevSlide && prevIdx !== current) {
            animateTextContent(prevSlide, false);
            prevSlide.style.transition = 'opacity ' + FADE_DURATION + 'ms ease-in-out';
            prevSlide.style.opacity = '0';
            prevSlide.style.zIndex = '1';
        }

        // Yeni slaydı hazırla
        nextSlide.style.display = '';
        nextSlide.style.transition = 'opacity ' + FADE_DURATION + 'ms ease-in-out';
        nextSlide.style.opacity = '0';
        nextSlide.style.zIndex = '2';

        // Metinleri gizle
        const textItems = nextSlide.querySelectorAll('.hero-title, .hero-subtitle, .hero-description, .hero-btn');
        textItems.forEach(function(el) {
            el.classList.add('opacity-0', 'translate-y-4');
        });

        // Force reflow
        void nextSlide.offsetHeight;

        // Fade in
        requestAnimationFrame(function() {
            nextSlide.style.opacity = '1';
        });

        updateDots(current);

        // Fade tamamlanınca metinleri animasyonla göster
        setTimeout(function() {
            if (prevSlide && prevIdx !== current) {
                prevSlide.style.display = 'none';
            }
            animateTextContent(nextSlide, true);
            isTransitioning = false;
            playActiveSlide();
        }, FADE_DURATION + 50);
    }

    window.heroSlide = function(dir) {
        goTo(current + dir);
    };

    window.heroGoTo = function(idx) {
        goTo(idx);
    };

    function resetProgress() {
        clearInterval(progressTimer);
        progressVal = 0;
        if (progressBar) {
            progressBar.style.transition = 'none';
            progressBar.style.width = '0%';
        }

        requestAnimationFrame(function() {
            progressTimer = setInterval(function() {
                progressVal += (PROGRESS_STEP / INTERVAL) * 100;
                if (progressVal >= 100) { progressVal = 100; }
                if (progressBar) {
                    progressBar.style.transition = 'width ' + PROGRESS_STEP + 'ms linear';
                    progressBar.style.width = progressVal + '%';
                }
            }, PROGRESS_STEP);
        });
    }

    function startAuto() {
        clearTimeout(autoTimer);
        autoTimer = setTimeout(function() {
            goTo(current + 1);
        }, INTERVAL);
    }

    function startImageSlide() {
        resetProgress();
        startAuto();
    }

    function startVideoProgress(video) {
        clearInterval(progressTimer);
        if (progressBar) {
            progressBar.style.transition = 'none';
            progressBar.style.width = '0%';
        }
        progressTimer = setInterval(function() {
            if (!progressBar || !video.duration || Number.isNaN(video.duration)) return;
            progressBar.style.transition = 'width 120ms linear';
            progressBar.style.width = Math.min(100, (video.currentTime / video.duration) * 100) + '%';
        }, 120);
    }

    function playActiveSlide() {
        const activeVideo = slides[current]?.querySelector('[data-hero-video]');
        stopInactiveVideos(activeVideo);

        if (!activeVideo) {
            startImageSlide();
            return;
        }

        activeVideo.muted = true;
        activeVideo.playsInline = true;
        activeVideo.onended = function() { goTo(current + 1); };
        activeVideo.onerror = function() { startImageSlide(); };

        try { activeVideo.currentTime = 0; } catch (_) { }
        startVideoProgress(activeVideo);

        const playPromise = activeVideo.play();
        if (playPromise && typeof playPromise.catch === 'function') {
            playPromise.catch(function() { startImageSlide(); });
        }
    }

    function clearAuto() {
        clearTimeout(autoTimer);
        clearInterval(progressTimer);
    }

    // Mouse ile üzerine gelince duraklat
    slider.addEventListener('mouseenter', function() {
        if (!slides[current]?.querySelector('[data-hero-video]')) {
            clearAuto();
        }
    });
    slider.addEventListener('mouseleave', function() {
        if (!slides[current]?.querySelector('[data-hero-video]')) {
            startImageSlide();
        }
    });

    // Touch/swipe desteği
    var touchStartX = 0;
    slider.addEventListener('touchstart', function(e) { touchStartX = e.touches[0].clientX; }, { passive: true });
    slider.addEventListener('touchend', function(e) {
        var diff = touchStartX - e.changedTouches[0].clientX;
        if (Math.abs(diff) > 40) {
            goTo(current + (diff > 0 ? (isRtl ? -1 : 1) : (isRtl ? 1 : -1)));
        }
    }, { passive: true });

    // İlk slaydı başlat
    slides.forEach(function(s, i) {
        if (i === 0) {
            s.style.display = '';
            s.style.opacity = '1';
            s.style.zIndex = '2';
            animateTextContent(s, true);
        } else {
            s.style.display = 'none';
            s.style.opacity = '0';
            s.style.zIndex = '1';
            var textItems = s.querySelectorAll('.hero-title, .hero-subtitle, .hero-description, .hero-btn');
            textItems.forEach(function(el) { el.classList.add('opacity-0', 'translate-y-4'); });
        }
    });

    updateDots(0);
    playActiveSlide();
})();
</script>

@* Dynamic Homepage Sections *@
@if (Model.Sections != null && Model.Sections.Any())
{
    foreach (var homeSection in Model.Sections)
    {
        // -------------------------------------------------------------
        // 1. MANUEL ÜRÜN BLOĞU
        // -------------------------------------------------------------
        if (homeSection.SectionType == HomePageSectionType.ProductBlock)
        {
            var sectionProducts = (homeSection.SectionProducts?
                .OrderBy(sp => sp.SortOrder)
                .Select(sp => sp.Urun)
                .Where(u => u != null && u.AktifMi && !u.SilindiMi)
                .ToList()) ?? new List<Urun>();

            if (sectionProducts.Any())
            {
                <section class="bg-[#fcf9f3] py-14 md:py-16" data-motion-section>
                    <div class="container mx-auto px-4">
                        <div class="mb-8 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
                            <div>
                                @if (!string.IsNullOrWhiteSpace(homeSection.Title))
                                {
                                    <h2 class="font-serif text-3xl text-[#313511]">@(homeSection.Title)</h2>
                                }
                                @if (!string.IsNullOrWhiteSpace(homeSection.Subtitle))
                                {
                                    <p class="mt-2 max-w-2xl text-sm text-[#47473d]">@(homeSection.Subtitle)</p>
                                }
                            </div>
                            @if (!string.IsNullOrWhiteSpace(homeSection.ViewAllUrl))
                            {
                                <a href="@(homeSection.ViewAllUrl)" class="inline-flex items-center gap-2 self-start border-b border-[#313511] pb-1 text-xs uppercase tracking-widest text-[#313511] transition-colors hover:text-[#b58735] md:self-auto">
                                    @(string.IsNullOrWhiteSpace(homeSection.ViewAllText) ? Localizer["ViewAll"] : homeSection.ViewAllText)
                                    <i class="fas fa-arrow-right text-[10px]"></i>
                                </a>
                            }
                        </div>
                        <div class="grid grid-cols-2 gap-5 md:grid-cols-4 lg:grid-cols-5" data-motion-stagger>
                            @foreach (var urun in sectionProducts.Take(15))
                            {
                                var gorsel = !string.IsNullOrWhiteSpace(urun.AnaGorselUrl)
                                    ? urun.AnaGorselUrl
                                    : urun.UrunResimleri?.OrderBy(r => r.Sira).FirstOrDefault()?.ResimYolu;

                                <article class="group" data-motion-item>
                                    <a href="@BuildProductUrl(urun)" class="block">
                                        <div class="relative mb-3 aspect-square overflow-hidden bg-[#f8f6f2] shadow-[inset_0_0_8px_rgba(0,0,0,0.03)] flex items-center justify-center p-2">
                                            @if (!string.IsNullOrWhiteSpace(gorsel))
                                            {
                                                <img src="@gorsel" alt="@urun.LocalizedBaslik" class="max-h-full max-w-full object-contain transition-transform duration-500 group-hover:scale-105" loading="lazy" decoding="async" />
                                            }
                                            else
                                            {
                                                <div class="flex h-full w-full items-center justify-center text-gray-300">
                                                    <i class="fas fa-image fa-2x"></i>
                                                </div>
                                            }
                                        </div>
                                        <h3 class="mb-1 line-clamp-2 text-xs font-semibold tracking-wide text-[#1c1c18] transition-colors group-hover:text-[#b58735]">@urun.LocalizedBaslik</h3>
                                        <p class="text-xs text-[#47473d]">@urun.EtkinFiyat.ToString("N0") @currencySymbol</p>
                                    </a>
                                </article>
                            }
                        </div>
                    </div>
                </section>
            }
        }
        // -------------------------------------------------------------
        // 2. ÖZEL BANNER
        // -------------------------------------------------------------
        else if (homeSection.SectionType == HomePageSectionType.CustomBanner && !string.IsNullOrWhiteSpace(homeSection.ImageUrl))
        {
            <section class="py-8" data-motion-section>
                <div class="container mx-auto px-4">
                    <a href="@(string.IsNullOrWhiteSpace(homeSection.ButtonUrl) ? "#" : homeSection.ButtonUrl)" class="block relative group overflow-hidden">
                        <img src="@(homeSection.ImageUrl)" alt="@(homeSection.Title)" class="w-full h-auto transition-transform duration-700 group-hover:scale-105" loading="lazy" decoding="async" />
                        @if (!string.IsNullOrWhiteSpace(homeSection.Title) || !string.IsNullOrWhiteSpace(homeSection.Subtitle))
                        {
                            <div class="absolute inset-0 bg-black/30 flex flex-col justify-center items-center text-center p-4">
                                <h3 class="text-white font-serif text-3xl md:text-5xl mb-2 drop-shadow-md">@homeSection.Title</h3>
                                <p class="text-white/90 text-sm md:text-base drop-shadow-md">@homeSection.Subtitle</p>
                            </div>
                        }
                    </a>
                </div>
            </section>
        }
        // -------------------------------------------------------------
        // 3. AUTO: 5 PARÇALI KOLEKSİYON
        // -------------------------------------------------------------
        else if (homeSection.SectionType == HomePageSectionType.AutoBesParcali && Model.BesParcaliKoleksiyon != null && Model.BesParcaliKoleksiyon.Any())
        {
            <section class="bg-[#fcf9f3] py-14 md:py-16">
                <div class="container mx-auto px-4">
                    <div class="mb-8 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
                        <div>
                            <h2 class="font-serif text-3xl text-[#313511]">@(string.IsNullOrWhiteSpace(homeSection.Title) ? Localizer["FeaturedProducts"] : homeSection.Title)</h2>
                            <p class="mt-2 max-w-2xl text-sm text-[#47473d]">@(string.IsNullOrWhiteSpace(homeSection.Subtitle) ? Localizer["FeaturedProductsSubtitle"] : homeSection.Subtitle)</p>
                        </div>
                        <a href="@(string.IsNullOrWhiteSpace(homeSection.ViewAllUrl) ? "/Urun?s=5%20Par%C3%A7a" : homeSection.ViewAllUrl)" class="inline-flex items-center gap-2 self-start border-b border-[#313511] pb-1 text-xs uppercase tracking-widest text-[#313511] transition-colors hover:text-[#b58735] md:self-auto">
                            @(string.IsNullOrWhiteSpace(homeSection.ViewAllText) ? Localizer["ViewAll5Piece"] : homeSection.ViewAllText)
                            <i class="fas fa-arrow-right text-[10px]"></i>
                        </a>
                    </div>
                    <div class="grid grid-cols-2 gap-5 md:grid-cols-4 lg:grid-cols-5">
                        @foreach (var urun in Model.BesParcaliKoleksiyon.Take(15))
                        {
                            var gorsel = !string.IsNullOrWhiteSpace(urun.AnaGorselUrl)
                                ? urun.AnaGorselUrl
                                : urun.UrunResimleri?.OrderBy(r => r.Sira).FirstOrDefault()?.ResimYolu;

                            <article class="group">
                                <a href="@BuildProductUrl(urun)" class="block">
                                    <div class="relative mb-3 aspect-square overflow-hidden bg-[#f8f6f2] shadow-[inset_0_0_8px_rgba(0,0,0,0.03)] flex items-center justify-center p-2">
                                        <span class="absolute left-2 top-2 z-10 bg-white/90 px-2 py-1 text-[9px] uppercase tracking-widest text-[#313511] shadow-sm">@Localizer["5Piece"]</span>
                                        @if (!string.IsNullOrWhiteSpace(gorsel))
                                        {
                                            <img src="@gorsel" alt="@urun.LocalizedBaslik" class="max-h-full max-w-full object-contain transition-transform duration-500 group-hover:scale-105" loading="lazy" decoding="async" />
                                        }
                                        else
                                        {
                                            <div class="flex h-full w-full items-center justify-center text-gray-300">
                                                <i class="fas fa-image fa-2x"></i>
                                            </div>
                                        }
                                    </div>
                                    <h3 class="mb-1 line-clamp-2 text-xs font-semibold tracking-wide text-[#1c1c18] transition-colors group-hover:text-[#b58735]">@urun.LocalizedBaslik</h3>
                                    <p class="text-xs text-[#47473d]">@urun.EtkinFiyat.ToString("N0") @currencySymbol</p>
                                </a>
                            </article>
                        }
                    </div>
                </div>
            </section>
        }
        // -------------------------------------------------------------
        // 4. AUTO: VİTRİN / ÖNE ÇIKAN ESERLER
        // -------------------------------------------------------------
        else if (homeSection.SectionType == HomePageSectionType.AutoVitrin && Model.VitrinUrunleri != null && Model.VitrinUrunleri.Any())
        {
            <section class="py-16 container mx-auto px-4">
                <div class="flex items-center justify-center mb-10">
                    <hr class="w-1/4 border-[#e5e2dc] hidden md:block"/>
                    <h2 class="font-serif text-3xl mx-8 text-center text-[#313511]">@(string.IsNullOrWhiteSpace(homeSection.Title) ? Localizer["FeaturedWorks"] : homeSection.Title)</h2>
                    <hr class="w-1/4 border-[#e5e2dc] hidden md:block"/>
                </div>
                @if (!string.IsNullOrWhiteSpace(homeSection.Subtitle))
                {
                    <p class="text-center text-sm text-[#47473d] mb-8 -mt-4">@homeSection.Subtitle</p>
                }
                <div class="grid grid-cols-2 md:grid-cols-5 gap-6">
                    @foreach (var urun in Model.VitrinUrunleri.Take(10))
                    {
                        <div class="group cursor-pointer flex flex-col">
                            <div class="relative overflow-hidden mb-4 aspect-square bg-[#f8f6f2] shadow-[inset_0_0_8px_rgba(0,0,0,0.03)] flex items-center justify-center p-2">
                                <a href="@BuildProductUrl(urun)" class="block w-full h-full flex items-center justify-center">
                                @if (urun.YeniUrunMu || urun.IndirimVarMi)
                                {
                                    <span class="absolute top-2 left-2 bg-white px-2 py-1 text-[10px] uppercase tracking-wider z-10 shadow-sm text-[#313511]">
                                        @(urun.YeniUrunMu ? Localizer["New"] : Localizer["%Indirim", urun.IndirimYuzdesi])
                                    </span>
                                }
                                @{
                                    var gorsel = !string.IsNullOrWhiteSpace(urun.AnaGorselUrl)
                                        ? urun.AnaGorselUrl
                                        : urun.UrunResimleri?.OrderBy(r => r.Sira).FirstOrDefault()?.ResimYolu;
                                }
                                @if (!string.IsNullOrWhiteSpace(gorsel))
                                {
                                <img alt="@urun.LocalizedBaslik" class="max-h-full max-w-full object-contain group-hover:scale-105 transition-transform duration-500" src="@gorsel" loading="lazy" decoding="async"/>
                                }
                                else
                                {
                                    <div class="w-full h-full flex items-center justify-center text-gray-300">
                                        <i class="fas fa-image fa-2x"></i>
                                    </div>
                                }
                                </a>
                                <!-- Kalp / Favori Butonu -->
                                <button type="button" onclick="window.toggleFavori(this, @urun.Id)" class="group/btn absolute top-3 right-3 w-9 h-9 bg-white/95 shadow-md rounded-full flex items-center justify-center transition-all duration-200 z-20 hover:scale-110 active:scale-90 md:w-8 md:h-8" title="@Localizer["AddToFavorites"]">
                                    <i class="far fa-heart text-sm text-[#47473d] group-hover/btn:text-red-400 transition-colors"></i>
                                </button>
                            </div>
                            <h3 class="text-xs font-semibold mb-1 text-[#1c1c18] tracking-wide line-clamp-2">
                                <a href="@BuildProductUrl(urun)" class="hover:text-[#b58735] transition-colors">@urun.LocalizedBaslik</a>
                            </h3>
                            <div class="flex flex-wrap items-baseline gap-x-2 gap-y-1">
                                <p class="text-xs text-[#b58735] font-semibold">@urun.EtkinFiyat.ToString("N0") @currencySymbol</p>
                                @if (urun.IndirimVarMi)
                                {
                                    <p class="text-[10px] text-[#777267] line-through">@urun.Fiyat.ToString("N0") @currencySymbol</p>
                                    <span class="text-[9px] text-white bg-[#b58735] px-1 py-0.5 rounded font-bold">-%@urun.IndirimYuzdesi</span>
                                }
                            </div>
                            @if (urun.KampanyaBitisTarihi.HasValue && urun.KampanyaBitisTarihi.Value > DateTime.UtcNow)
                            {
                                @await Html.PartialAsync("_CountdownPartial", urun.KampanyaBitisTarihi.Value)
                            }
                        </div>
                    }
                </div>
                <div class="text-center mt-12">
                    <a href="@(string.IsNullOrWhiteSpace(homeSection.ViewAllUrl) ? "/Urun" : homeSection.ViewAllUrl)" class="inline-block border border-[#313511] text-[#313511] px-8 py-3 text-xs tracking-widest hover:bg-[#313511] hover:text-white transition-colors uppercase rounded-full">
                        @(string.IsNullOrWhiteSpace(homeSection.ViewAllText) ? Localizer["ViewAll"] : homeSection.ViewAllText)
                    </a>
                </div>
            </section>
        }
        // -------------------------------------------------------------
        // 5. AUTO: ÇOK SATANLAR
        // -------------------------------------------------------------
        else if (homeSection.SectionType == HomePageSectionType.AutoCokSatanlar && Model.CokSatanlar != null && Model.CokSatanlar.Any())
        {
            <section class="container mx-auto px-4 pb-16">
                <div class="mb-8 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
                    <div>
                        <p class="mb-2 text-xs uppercase tracking-[0.25em] text-[#b58735]">@(string.IsNullOrWhiteSpace(homeSection.Subtitle) ? Localizer["BestSellers"] : homeSection.Subtitle)</p>
                        <h2 class="font-serif text-3xl text-[#313511]">@(string.IsNullOrWhiteSpace(homeSection.Title) ? Localizer["MostPreferred"] : homeSection.Title)</h2>
                    </div>
                    <a href="@(string.IsNullOrWhiteSpace(homeSection.ViewAllUrl) ? "/Urun?sort=popularity" : homeSection.ViewAllUrl)" class="inline-flex items-center gap-2 self-start border-b border-[#313511] pb-1 text-xs uppercase tracking-widest text-[#313511] transition-colors hover:text-[#b58735] md:self-auto">
                        @(string.IsNullOrWhiteSpace(homeSection.ViewAllText) ? Localizer["ViewAll"] : homeSection.ViewAllText)
                        <i class="fas fa-arrow-right text-[10px]"></i>
                    </a>
                </div>
                <div class="grid grid-cols-2 gap-6 md:grid-cols-4">
                    @foreach (var urun in Model.CokSatanlar.Take(8))
                    {
                        var gorsel = !string.IsNullOrWhiteSpace(urun.AnaGorselUrl)
                            ? urun.AnaGorselUrl
                            : urun.UrunResimleri?.OrderBy(r => r.Sira).FirstOrDefault()?.ResimYolu;

                        <article class="group">
                            <a href="@BuildProductUrl(urun)" class="block">
                                <div class="relative mb-4 aspect-[4/5] overflow-hidden bg-[#f8f6f2] shadow-[inset_0_0_8px_rgba(0,0,0,0.03)] flex items-center justify-center p-2">
                                    <span class="absolute left-3 top-3 z-10 bg-white/90 px-2.5 py-1 text-[10px] uppercase tracking-widest text-[#313511]">@Localizer["Bestseller"]</span>
                                    @if (urun.IndirimVarMi)
                                    {
                                        <span class="absolute right-3 top-3 z-10 bg-[#b58735] text-white text-[10px] font-bold px-2 py-0.5 rounded-sm shadow-sm">%@urun.IndirimYuzdesi</span>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(gorsel))
                                    {
                                        <img src="@gorsel" alt="@urun.LocalizedBaslik" class="max-h-full max-w-full object-contain transition-transform duration-500 group-hover:scale-105" loading="lazy" decoding="async" />
                                    }
                                    else
                                    {
                                        <div class="flex h-full w-full items-center justify-center text-gray-300">
                                            <i class="fas fa-image fa-2x"></i>
                                        </div>
                                    }
                                </div>
                                <h3 class="mb-1 line-clamp-2 text-sm font-semibold tracking-wide text-[#1c1c18] transition-colors group-hover:text-[#b58735]">@urun.LocalizedBaslik</h3>
                                <div class="flex flex-wrap items-baseline gap-x-2 gap-y-1">
                                    <p class="text-xs text-[#b58735] font-semibold">@urun.EtkinFiyat.ToString("N0") @currencySymbol</p>
                                    @if (urun.IndirimVarMi)
                                    {
                                        <p class="text-[10px] text-[#777267] line-through">@urun.Fiyat.ToString("N0") @currencySymbol</p>
                                        <span class="text-[9px] text-white bg-[#b58735] px-1 py-0.5 rounded font-bold">-%@urun.IndirimYuzdesi</span>
                                    }
                                </div>
                            </a>
                        </article>
                    }
                </div>
            </section>
        }
        // -------------------------------------------------------------
        // 6. AUTO: FIRSAT ÜRÜNLERİ
        // -------------------------------------------------------------
        else if (homeSection.SectionType == HomePageSectionType.AutoFirsatUrunleri && Model.FirsatUrunleri != null && Model.FirsatUrunleri.Any())
        {
            <section class="bg-[#f1ede7] py-16">
                <div class="container mx-auto px-4">
                    <div class="mb-8 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
                        <div>
                            <p class="mb-2 text-xs uppercase tracking-[0.25em] text-[#b58735]">@(string.IsNullOrWhiteSpace(homeSection.Subtitle) ? Localizer["DealProducts"] : homeSection.Subtitle)</p>
                            <h2 class="font-serif text-3xl text-[#313511]">@(string.IsNullOrWhiteSpace(homeSection.Title) ? Localizer["CampaignSelections"] : homeSection.Title)</h2>
                        </div>
                        <a href="@(string.IsNullOrWhiteSpace(homeSection.ViewAllUrl) ? "/Urun?sort=price_asc" : homeSection.ViewAllUrl)" class="inline-flex items-center gap-2 self-start border-b border-[#313511] pb-1 text-xs uppercase tracking-widest text-[#313511] transition-colors hover:text-[#b58735] md:self-auto">
                            @(string.IsNullOrWhiteSpace(homeSection.ViewAllText) ? Localizer["ViewDeals"] : homeSection.ViewAllText)
                            <i class="fas fa-arrow-right text-[10px]"></i>
                        </a>
                    </div>
                    <div class="grid grid-cols-2 gap-6 md:grid-cols-4">
                        @foreach (var urun in Model.FirsatUrunleri.Take(8))
                        {
                            var gorsel = !string.IsNullOrWhiteSpace(urun.AnaGorselUrl)
                                ? urun.AnaGorselUrl
                                : urun.UrunResimleri?.OrderBy(r => r.Sira).FirstOrDefault()?.ResimYolu;

                            <article class="group">
                                <a href="@BuildProductUrl(urun)" class="block">
                                    <div class="relative mb-4 aspect-[4/5] overflow-hidden bg-[#f8f6f2] shadow-[inset_0_0_8px_rgba(0,0,0,0.03)] flex items-center justify-center p-2">
                                        <span class="absolute left-3 top-3 z-10 bg-[#b58735] px-2.5 py-1 text-[10px] uppercase tracking-widest text-white">-%@urun.IndirimYuzdesi</span>
                                        @if (!string.IsNullOrWhiteSpace(gorsel))
                                        {
                                        <img src="@gorsel" alt="@urun.LocalizedBaslik" class="max-h-full max-w-full object-contain transition-transform duration-500 group-hover:scale-105" loading="lazy" decoding="async" />
                                        }
                                        else
                                        {
                                            <div class="flex h-full w-full items-center justify-center text-gray-300">
                                                <i class="fas fa-image fa-2x"></i>
                                            </div>
                                        }
                                    </div>
                                    <h3 class="mb-1 line-clamp-2 text-sm font-semibold tracking-wide text-[#1c1c18] transition-colors group-hover:text-[#b58735]">@urun.LocalizedBaslik</h3>
                                    <div class="flex flex-wrap items-baseline gap-2">
                                        <p class="text-xs text-[#b58735] font-semibold">@urun.EtkinFiyat.ToString("N0") @currencySymbol</p>
                                        @if (urun.IndirimVarMi)
                                        {
                                            <p class="text-[10px] text-[#777267] line-through">@urun.Fiyat.ToString("N0") @currencySymbol</p>
                                            <span class="text-[9px] text-white bg-[#b58735] px-1 py-0.5 rounded font-bold">-%@urun.IndirimYuzdesi</span>
                                        }
                                    </div>
                                    @if (urun.KampanyaBitisTarihi.HasValue && urun.KampanyaBitisTarihi.Value > DateTime.UtcNow)
                                    {
                                        @await Html.PartialAsync("_CountdownPartial", urun.KampanyaBitisTarihi.Value)
                                    }
                                </a>
                            </article>
                        }
                    </div>
                </div>
            </section>
        }
    }
}

<!-- BEGIN: Features -->
<section class="bg-[#f1ede7] py-16">
    <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
            <div>
                <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-[#e2e6b3] flex items-center justify-center text-[#313511]">
                    <i class="fas fa-shield-halved text-2xl"></i>
                </div>
                <h4 class="font-serif text-lg mb-2 text-[#1c1c18]">@Localizer["SecurePayment"]</h4>
                <p class="text-sm font-light text-[#47473d]">@Localizer["SecurePaymentDesc"]</p>
            </div>
            <div>
                <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-[#e2e6b3] flex items-center justify-center text-[#313511]">
                    <i class="fas fa-truck-fast text-2xl"></i>
                </div>
                <h4 class="font-serif text-lg mb-2 text-[#1c1c18]">@Localizer["FastDelivery"]</h4>
                <p class="text-sm font-light text-[#47473d]">@Localizer["FastDeliveryDesc"]</p>
            </div>
            <div>
                <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-[#e2e6b3] flex items-center justify-center text-[#313511]">
                    <i class="fas fa-headset text-2xl"></i>
                </div>
                <h4 class="font-serif text-lg mb-2 text-[#1c1c18]">@Localizer["CustomerSatisfaction"]</h4>
                <p class="text-sm font-light text-[#47473d]">@Localizer["CustomerSatisfactionDesc"]</p>
            </div>
        </div>
    </div>
</section>
