@inject IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["ReturnExchange"];
    ViewData["MetaDescription"] = "7ANRPS48 iade ve değişim koşulları. Memnuniyetiniz bizim için önemli, iade süreci hakkında detaylı bilgi.";
    ViewData["SeoTitle"] = Localizer["ReturnExchange"] + " - 7ANRPS48";
}

<div class="bg-[#f1ede7] border-b border-[#e5e2dc] py-3">
    <div class="container mx-auto px-4 flex items-center gap-2 text-xs text-[#47473d]">
        <a href="/" class="hover:text-[#313511] transition-colors">@Localizer["HomePage"]</a>
        <span>/</span>
        <span class="text-[#1c1c18] font-medium">@Localizer["ReturnExchange"]</span>
    </div>
</div>

<div class="container mx-auto px-4 py-16 max-w-4xl">
    <div class="text-center mb-12">
        <h1 class="font-serif text-3xl md:text-5xl text-[#313511] mb-4">@Localizer["ReturnExchange"]</h1>
        <div class="w-16 h-1 bg-[#b58735] mx-auto"></div>
    </div>

    <div class="bg-white border border-[#e5e2dc] rounded-lg p-8 md:p-12 shadow-sm prose prose-sm md:prose-base max-w-none prose-headings:font-serif prose-headings:text-[#313511] prose-a:text-[#b58735] prose-strong:text-[#1c1c18]">

        <h2>@Localizer["GeneralReturnTerms"]</h2>
        <p>@Localizer["GeneralReturnTermsContent"]</p>

        <h2>@Localizer["ReturnProcess"]</h2>
        <ul>
            <li>@Localizer["ReturnCondition"]</li>
            <li>@Localizer["ReturnHowTo"]</li>
            <li>@Localizer["ReturnShipping"]</li>
        </ul>

        <h2>@Localizer["DamagedProducts"]</h2>
        <p>@Localizer["DamagedProductsContent"]</p>

        <h2>@Localizer["CustomDesignProducts"]</h2>
        <p>@Localizer["CustomDesignProductsContent"]</p>

        <h2>@Localizer["Refund"]</h2>
        <p>@Localizer["RefundContent"]</p>

    </div>
</div>
