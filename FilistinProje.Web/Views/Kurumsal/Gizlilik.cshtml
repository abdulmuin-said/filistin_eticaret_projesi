@inject IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["PrivacyAndSecurity"];
    ViewData["MetaDescription"] = "7ANRPS48 gizlilik ve güvenlik politikası. Kişisel verilerinizin korunması ve gizliliğinize verdiğimiz önem hakkında bilgi.";
    ViewData["SeoTitle"] = Localizer["PrivacyAndSecurity"] + " - 7ANRPS48";
}

<div class="bg-[#f1ede7] border-b border-[#e5e2dc] py-3">
    <div class="container mx-auto px-4 flex items-center gap-2 text-xs text-[#47473d]">
        <a href="/" class="hover:text-[#313511] transition-colors">@Localizer["HomePage"]</a>
        <span>/</span>
        <span class="text-[#1c1c18] font-medium">@Localizer["PrivacyAndSecurity"]</span>
    </div>
</div>

<div class="container mx-auto px-4 py-16 max-w-4xl">
    <div class="text-center mb-12">
        <h1 class="font-serif text-3xl md:text-5xl text-[#313511] mb-4">@Localizer["PrivacyAndSecurity"]</h1>
        <div class="w-16 h-1 bg-[#b58735] mx-auto"></div>
    </div>

    <div class="bg-white border border-[#e5e2dc] rounded-lg p-8 md:p-12 shadow-sm prose prose-sm md:prose-base max-w-none prose-headings:font-serif prose-headings:text-[#313511] prose-a:text-[#b58735] prose-strong:text-[#1c1c18]">

        <h2>@Localizer["Intro"]</h2>
        <p>@Localizer["IntroContent"]</p>

        <h2>@Localizer["InfoCollected"]</h2>
        <p>@Localizer["InfoCollectedContent"]</p>

        <h2>@Localizer["InfoUsage"]</h2>
        <p>@Localizer["InfoUsageContent"]</p>

        <h2>@Localizer["Security"]</h2>
        <p>@Localizer["SecurityContent"]</p>

        <h2>@Localizer["Cookies"]</h2>
        <p>@Localizer["CookiesContent"]</p>

        <h2>@Localizer["Contact"]</h2>
        <p>@Localizer["ContactContent"]</p>

    </div>
</div>
