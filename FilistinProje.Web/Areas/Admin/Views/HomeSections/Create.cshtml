@model FilistinProje.Core.Varliklar.HomePageSection
@using FilistinProje.Core.Varliklar
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = Localizer["Admin_NewHomeSection"];
}

<div class="container-fluid ca-fade-in">
    <div class="ca-page-header d-flex justify-content-between align-items-center">
        <div>
            <h1 class="ca-page-title">@Localizer["Admin_AddNewSection"]</h1>
            <p class="ca-page-subtitle">@Localizer["Admin_AddNewSectionSubtitle"]</p>
        </div>
        <a href="@Url.Action("Index", "HomeSections")" class="ca-btn ca-btn-outline">
            <i class="fas fa-arrow-left"></i> @Localizer["Admin_Back"]
        </a>
    </div>

    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="ca-card">
                    <div class="ca-card-header">
                        <span class="ca-card-title"><i class="fas fa-layer-group me-2"></i>@Localizer["Admin_SectionInfo"]</span>
                    </div>
                    <div class="ca-card-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="SectionType" class="ca-label">@Localizer["Admin_SectionType"]</label>
                                <select asp-for="SectionType" class="ca-input">
                                    <option value="@HomePageSectionType.ProductBlock">@Localizer["Admin_ManualProductSelection"]</option>
                                    <option value="@HomePageSectionType.CategoryShowcase">@Localizer["Admin_CategoryShowcase"]</option>
                                    <option value="@HomePageSectionType.CustomBanner">@Localizer["Admin_CustomBanner"]</option>
                                    <option value="@HomePageSectionType.AutoVitrin">@Localizer["Admin_FeaturedAutomatic"]</option>
                                    <option value="@HomePageSectionType.AutoCokSatanlar">@Localizer["Admin_BestSellersAutomatic"]</option>
                                    <option value="@HomePageSectionType.AutoFirsatUrunleri">@Localizer["Admin_DealProductsAutomatic"]</option>
                                    <option value="@HomePageSectionType.AutoBesParcali">@Localizer["Admin_FivePieceSetsAutomatic"]</option>
                                </select>
                                <span asp-validation-for="SectionType" class="text-danger small"></span>
                            </div>
                            <div class="col-md-3">
                                <label asp-for="SortOrder" class="ca-label">@Localizer["Admin_Sira"]</label>
                                <input asp-for="SortOrder" class="ca-input" type="number" min="0" />
                            </div>
                            <div class="col-md-3">
                                <label class="ca-label">@Localizer["Admin_Aktif"]</label>
                                <div class="form-check form-switch mt-2">
                                    <input asp-for="Enabled" class="form-check-input" type="checkbox" />
                                    <label class="form-check-label" asp-for="Enabled">@Localizer["Admin_Published"]</label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Title" class="ca-label">@Localizer["Admin_Baslik"]</label>
                                <input asp-for="Title" class="ca-input" placeholder='@Localizer["Admin_SectionTitlePlaceholder"]' />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Subtitle" class="ca-label">@Localizer["Admin_Alt_Baslik"]</label>
                                <input asp-for="Subtitle" class="ca-input" placeholder='@Localizer["Admin_ShortDescriptionPlaceholder"]' />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="ViewAllText" class="ca-label">@Localizer["Admin_ButtonText"]</label>
                                <input asp-for="ViewAllText" class="ca-input" placeholder='@Localizer["Admin_ViewAll"]' />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="ViewAllUrl" class="ca-label">@Localizer["Admin_ButtonLink"]</label>
                                <input asp-for="ViewAllUrl" class="ca-input" placeholder="/Urun" />
                            </div>
                        </div>

                        <hr class="my-4">

                        <div id="bannerFields">
                            <h6 class="fw-semibold mb-3 text-muted">@Localizer["Admin_BannerFieldsCustomOnly"]</h6>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label asp-for="ImageUrl" class="ca-label">@Localizer["Admin_ImageUrl"]</label>
                                    <input asp-for="ImageUrl" class="ca-input" placeholder="/img/banner.jpg" />
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="ButtonUrl" class="ca-label">@Localizer["Admin_BannerButtonLink"]</label>
                                    <input asp-for="ButtonUrl" class="ca-input" placeholder="/Urun?k=1" />
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="ButtonText" class="ca-label">@Localizer["Admin_BannerButtonText"]</label>
                                    <input asp-for="ButtonText" class="ca-input" placeholder='@Localizer["Admin_ReviewNow"]' />
                                </div>
                                <div class="col-12">
                                    <label asp-for="Description" class="ca-label">@Localizer["Admin_Aciklama"]</label>
                                    <textarea asp-for="Description" class="ca-input" rows="3" placeholder='@Localizer["Admin_BannerDescriptionPlaceholder"]'></textarea>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="ca-card">
                    <div class="ca-card-header">
                        <span class="ca-card-title"><i class="fas fa-info-circle me-2"></i>@Localizer["Admin_Info"]</span>
                    </div>
                    <div class="ca-card-body">
                        <ul class="list-unstyled small text-muted" style="line-height:1.8">
                            <li><i class="fas fa-check text-success me-2"></i><b>@Localizer["Admin_ProductBlock"]:</b> @Localizer["Admin_ProductBlockHelp"]</li>
                            <li><i class="fas fa-check text-success me-2"></i><b>@Localizer["Admin_CategoryShowcase"]:</b> @Localizer["Admin_CategoryShowcaseHelp"]</li>
                            <li><i class="fas fa-check text-success me-2"></i><b>@Localizer["Admin_CustomBanner"]:</b> @Localizer["Admin_CustomBannerHelp"]</li>
                            <li class="mt-3"><i class="fas fa-sort text-primary me-2"></i>@Localizer["Admin_SortOrderHelp"]</li>
                        </ul>
                        <div class="mt-4 d-grid gap-2">
                            <button type="submit" class="ca-btn ca-btn-primary">
                                <i class="fas fa-save"></i> @Localizer["Admin_Create"]
                            </button>
                            <a href="@Url.Action("Index", "HomeSections")" class="ca-btn ca-btn-outline">@Localizer["Admin_Iptal"]</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>
