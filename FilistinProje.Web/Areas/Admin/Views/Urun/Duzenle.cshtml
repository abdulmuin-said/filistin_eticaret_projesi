        padding: 14px 18px;
        border: 1px solid var(--ca-border);
        border-radius: var(--ca-radius);
        background: #fff;
        margin-bottom: 16px;
    }

    .ca-product-status {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        align-items: center;
    }

    .ca-editor-tabs {
        position: sticky;
        top: 62px;
        z-index: 20;
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
        padding: 8px;
        border: 1px solid var(--ca-border);
        border-radius: var(--ca-radius);
        background: rgba(255, 255, 255, .96);
        backdrop-filter: blur(12px);
        margin-bottom: 16px;
