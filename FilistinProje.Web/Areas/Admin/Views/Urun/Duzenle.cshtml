                                    <label class="ca-label">@Localizer["Admin_GalleryImages"]</label>
                                    <input type="file" name="galeriDosyalari" multiple class="ca-input" accept=".jpg,.jpeg,.png,.webp" />
                                </div>
                            </div>

                            <div class="mt-3" style="display:grid; grid-template-columns:repeat(auto-fill,minmax(110px,1fr)); gap:10px;">
                                @foreach (var r in Model.UrunResimleri ?? Enumerable.Empty<FilistinProje.Core.Varliklar.UrunResim>())
                                {
                                    <div style="position:relative; aspect-ratio:1/1; border-radius:var(--ca-radius); overflow:hidden; border:1px solid var(--ca-border); background:#fff;">
                                        <img src="@r.ResimYolu" alt="@Model.Baslik galeri gÃ¶rseli" loading="lazy" decoding="async" style="width:100%; height:100%; object-fit:cover;" />
                                        <a href="/Admin/Urun/ResimSil/@r.Id" title="@Localizer["Admin_DeleteImage"]" style="position:absolute; top:6px; right:6px; width:24px; height:24px; border-radius:50%; background:rgba(239,68,68,.92); color:#fff; display:flex; align-items:center; justify-content:center; font-size:.72rem; text-decoration:none;">Ã—</a>
