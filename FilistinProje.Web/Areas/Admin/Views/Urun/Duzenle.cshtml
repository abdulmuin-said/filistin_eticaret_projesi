                                        {
                                            <img src="@item.Url" id="@(i == 0 ? "mainImgPreview" : null)" alt="@item.Alt" loading="lazy" decoding="async" onerror="this.onerror=null; this.src='https://placehold.co/800x800/f1ede7/8a8880?text=Gorsel';">
                                        }
                                    </div>
                                }

                                @if (previewItems.Count > 1)
                                {
                                    <button type="button" class="ca-preview-nav ca-preview-prev" data-preview-prev aria-label="@Localizer["Admin_PreviousMedia"]">
                                        <i class="fas fa-chevron-left"></i>
                                    </button>
                                    <button type="button" class="ca-preview-nav ca-preview-next" data-preview-next aria-label="@Localizer["Admin_NextMedia"]">
                                        <i class="fas fa-chevron-right"></i>
                                    </button>
                                    <span class="ca-preview-counter" data-preview-counter>1 / @previewItems.Count</span>
                                }
                            }
                            else
                            {
                                <img src="https://placehold.co/800x800/f1ede7/8a8880?text=Gorsel" id="mainImgPreview" alt="@Model.Baslik ana gÃ¶rseli" loading="lazy" decoding="async">
                            }
                        </div>
                        <div class="fw-bold">@Model.Baslik</div>
                        <div class="small text-muted mb-3">SKU: @(string.IsNullOrWhiteSpace(Model.SKU) ? "-" : Model.SKU)</div>
                        <div class="ca-mini-stat-grid">
                            <div class="ca-mini-stat"><span>@Localizer["Admin_EffectivePrice"]</span><strong>@Model.EtkinFiyat.ToString("N2") â‚ª</strong></div>
                            <div class="ca-mini-stat"><span>@Localizer["Admin_Sales"]</span><strong>@Model.SatisSayisi</strong></div>
                            <div class="ca-mini-stat"><span>@Localizer["Admin_Views"]</span><strong>@Model.GoruntulenmeSayisi</strong></div>
                            <div class="ca-mini-stat"><span>@Localizer["Admin_Favorite"]</span><strong>@Model.FavoriSayisi</strong></div>
                            <div class="ca-mini-stat"><span>@Localizer["Admin_Variation"]</span><strong>@variantCount</strong></div>
                            <div class="ca-mini-stat"><span>@Localizer["Admin_Media"]</span><strong>@mediaCount</strong></div>
                        </div>
                    </div>
                </div>
            </aside>
        </div>
