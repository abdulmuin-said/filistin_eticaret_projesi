                </section>

                <section class="ca-editor-panel" data-product-panel="varyasyon">
                    @await Html.PartialAsync("_VariantEditor", Model.UrunSecenek?.ToList() ?? new System.Collections.Generic.List<FilistinProje.Core.Varliklar.UrunSecenek>())
