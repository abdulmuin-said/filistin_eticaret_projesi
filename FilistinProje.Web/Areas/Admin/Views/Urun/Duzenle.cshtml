        aspect-ratio: 1 / 1;
        border: 1px solid var(--ca-border);
        border-radius: var(--ca-radius);
        overflow: hidden;
        background: #fff;
    }

    .ca-product-preview img,
    .ca-product-preview video {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .ca-preview-slide {
        display: none;
        width: 100%;
        height: 100%;
    }

    .ca-preview-slide.active {
        display: block;
    }

    .ca-preview-nav {
        position: absolute;
        top: 50%;
        z-index: 2;
        width: 34px;
        height: 34px;
        border: 1px solid rgba(255, 255, 255, .65);
        border-radius: 50%;
        background: rgba(28, 28, 24, .58);
        color: #fff;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transform: translateY(-50%);
        transition: background .2s ease, transform .2s ease;
    }

    .ca-preview-nav:hover {
        background: rgba(28, 28, 24, .82);
        transform: translateY(-50%) scale(1.04);
    }

    .ca-preview-prev {
        left: 10px;
    }

    .ca-preview-next {
        right: 10px;
    }

    .ca-preview-counter {
        position: absolute;
        right: 10px;
        bottom: 10px;
        z-index: 2;
        padding: 4px 8px;
        border-radius: 999px;
        background: rgba(28, 28, 24, .72);
        color: #fff;
        font-size: .72rem;
        font-weight: 700;
    }

    .ca-preview-video-chip {
        position: absolute;
        left: 10px;
        bottom: 10px;
        z-index: 2;
        padding: 4px 8px;
        border-radius: 999px;
        background: rgba(181, 135, 53, .92);
        color: #fff;
        font-size: .72rem;
        font-weight: 700;
    }

    .ca-mini-stat-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 8px;
    }

    .ca-mini-stat {
        border: 1px solid var(--ca-border);
        border-radius: var(--ca-radius-sm);
        padding: 10px;
        background: #fff;
    }

    .ca-mini-stat span {
        display: block;
        color: var(--ca-text-muted);
        font-size: .72rem;
    }

    .ca-mini-stat strong {
        color: var(--ca-text);
        font-size: 1rem;
    }

    .ca-switch-grid {
        display: grid;
        grid-template-columns: repeat(5, minmax(0, 1fr));
        gap: 10px;
    }

    .ca-switch-tile {
        border: 1px solid var(--ca-border);
        border-radius: var(--ca-radius);
        padding: 12px;
        background: #fff;
        min-height: 72px;
    }

    .ca-save-rail {
        position: sticky;
        bottom: 0;
        z-index: 30;
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        padding: 14px 0 0;
        margin-top: 18px;
        background: linear-gradient(180deg, rgba(247, 244, 238, 0), #f7f4ee 34%);
    }

    @@media (max-width: 1180px) {
        .ca-product-editor {
            grid-template-columns: 1fr;
        }

        .ca-product-aside {
            position: static;
            grid-row: 1;
        }

        .ca-switch-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 768px) {
        .ca-editor-tabs {
            top: 112px;
            overflow-x: auto;
            flex-wrap: nowrap;
        }

        .ca-editor-tab {
            white-space: nowrap;
        }

        .ca-switch-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

