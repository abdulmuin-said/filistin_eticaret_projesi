@model FilistinProje.Core.Varliklar.Slayt
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = Localizer["Admin_EditSlide"];
    var currentTur = Model.Tur;
    var isVideoTur = currentTur == "Video";
}

<div class="container-fluid">
    <div class="ca-page-header">
        <div>
            <h1 class="ca-page-title">@Localizer["Admin_EditSlide"]</h1>
            <p class="ca-page-subtitle">@Localizer["Admin_EditSlideSubtitle"]</p>
        </div>
        <div>
            <a href="@Url.Action("Index", "Slayt")" class="btn btn-secondary">
                <i class="fas fa-arrow-left me-1"></i> @Localizer["Admin_BackToSlideList"]
            </a>
        </div>
    </div>

    <div class="alert alert-info mb-3">
        <div class="d-flex align-items-start gap-2">
            <i class="fas fa-info-circle mt-1"></i>
            <div>
                <strong>@Localizer["Admin_SliderDimensions"]:</strong>
                <ul class="mb-0 mt-1 small">
                    <li><strong>@Localizer["Admin_Resim"]:</strong> @Localizer["Admin_SliderImageDimensionsHelp"]</li>
                    <li><strong>@Localizer["Admin_Video"]:</strong> @Localizer["Admin_SliderVideoDimensionsHelp"]</li>
                    <li>@Localizer["Admin_SliderFilesStorageHelp"] <code>/uploads/slider/</code></li>
                </ul>
            </div>
        </div>
    </div>

    @if (TempData["Hata"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i> @TempData["Hata"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <form method="post" enctype="multipart/form-data" autocomplete="off">
        @Html.AntiForgeryToken()
        <input type="hidden" name="Id" value="@Model.Id" />
        
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                <strong><i class="fas fa-exclamation-triangle me-2"></i> @Localizer["Admin_FixErrorsBelow"]</strong>
                @Html.ValidationSummary(false, "", new { @class = "mb-0 mt-2" })
            </div>
        }

        <div class="row g-4">
            <div class="col-lg-8">
                <div class="ca-card">
                    <div class="ca-card-header">
                        <h3 class="ca-card-title"><i class="fas fa-edit me-2 ca-text-primary"></i>@Localizer["Admin_SlideInfo"]</h3>
                    </div>
                    <div class="ca-card-body">
                        <div class="mb-3">
                            <label class="form-label">@Localizer["Admin_Baslik"] <span class="text-danger">*</span></label>
                            <input type="text" name="Baslik" value="@Model.Baslik" class="form-control" placeholder='@Localizer["Admin_SlideTitlePlaceholder"]' required />
                            @Html.ValidationMessage("Baslik", "", new { @class = "text-danger small" })
                        </div>

                        <div class="mb-3">
                            <label class="form-label">@Localizer["Admin_Alt_Baslik"]</label>
                            <input type="text" name="AltBaslik" value="@Model.AltBaslik" class="form-control" placeholder='@Localizer["Admin_SubtitlePlaceholder"]' />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">@Localizer["Admin_Aciklama"]</label>
                            <textarea name="Aciklama" class="form-control" rows="2" placeholder='@Localizer["Admin_ShortDescriptionPlaceholder"]'>@Model.Aciklama</textarea>
                        </div>

                        <!-- Çok Dilli Alanlar -->
                        <div class="accordion" id="multiLangAccordion">
                            <div class="accordion-item border-0">
                                <h2 class="accordion-header">
                                    <button class="accordion-button collapsed bg-light small fw-semibold py-2" type="button" data-bs-toggle="collapse" data-bs-target="#multiLangContent">
                                        <i class="fas fa-language me-2"></i> @Localizer["Admin_MultiLanguageFields"]
                                    </button>
                                </h2>
                                <div id="multiLangContent" class="accordion-collapse collapse">
                                    <div class="accordion-body px-0 pb-0">
                                        <div class="row mb-3">
                                            <div class="col-md-4">
                                                <label class="form-label small">@Localizer["Admin_Baslik"] (EN)</label>
                                                <input type="text" name="BaslikEn" value="@Model.BaslikEn" class="form-control form-control-sm" placeholder="English title" />
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label small">@Localizer["Admin_Baslik"] (AR)</label>
                                                <input type="text" name="BaslikAr" value="@Model.BaslikAr" class="form-control form-control-sm" placeholder="العنوان بالعربية" dir="rtl" />
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label small">@Localizer["Admin_Baslik"] (TR)</label>
                                                <input type="text" name="Baslik" value="@Model.Baslik" class="form-control form-control-sm" placeholder="Türkçe başlık" />
                                            </div>
                                        </div>
                                        <div class="row mb-3">
                                            <div class="col-md-4">
                                                <label class="form-label small">Alt Başlık (EN)</label>
                                                <input type="text" name="AltBaslikEn" value="@Model.AltBaslikEn" class="form-control form-control-sm" placeholder="English subtitle" />
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label small">Alt Başlık (AR)</label>
                                                <input type="text" name="AltBaslikAr" value="@Model.AltBaslikAr" class="form-control form-control-sm" placeholder="العنوان الفرعي" dir="rtl" />
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label small">Alt Başlık (TR)</label>
                                                <input type="text" name="AltBaslik" value="@Model.AltBaslik" class="form-control form-control-sm" placeholder="Türkçe alt başlık" />
                                            </div>
                                        </div>
                                        <div class="row mb-3">
                                            <div class="col-md-4">
                                                <label class="form-label small">Açıklama (EN)</label>
                                                <textarea name="AciklamaEn" class="form-control form-control-sm" rows="2" placeholder="English description">@Model.AciklamaEn</textarea>
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label small">Açıklama (AR)</label>
                                                <textarea name="AciklamaAr" class="form-control form-control-sm" rows="2" placeholder="الوصف بالعربية" dir="rtl">@Model.AciklamaAr</textarea>
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label small">Açıklama (TR)</label>
                                                <textarea name="Aciklama" class="form-control form-control-sm" rows="2" placeholder="Türkçe açıklama">@Model.Aciklama</textarea>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Buton Alanları -->
                        <div class="mt-3 p-3 bg-light rounded border">
                            <h6 class="fw-bold mb-3"><i class="fas fa-link me-2"></i> @Localizer["Admin_SliderButton"]</h6>
                            <div class="row mb-2">
                                <div class="col-md-4">
                                    <label class="form-label small">Buton Metni (EN)</label>
                                    <input type="text" name="ButonMetniEn" value="@Model.ButonMetniEn" class="form-control" placeholder="Shop Now" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label small">Buton Metni (AR)</label>
                                    <input type="text" name="ButonMetniAr" value="@Model.ButonMetniAr" class="form-control" placeholder="تسوق الآن" dir="rtl" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label small">Buton Metni (TR)</label>
                                    <input type="text" name="ButonMetni" value="@Model.ButonMetni" class="form-control" placeholder="Alışverişe Başla" />
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-12">
                                    <label class="form-label small">@Localizer["Admin_ButtonUrl"]</label>
                                    <input type="url" name="BaglantiUrl" value="@Model.BaglantiUrl" class="form-control" placeholder="/Urun veya https://..." />
                                    <div class="form-text small">@Localizer["Admin_ButtonUrlHelp"]</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="ca-card">
                    <div class="ca-card-header">
                        <h3 class="ca-card-title"><i class="fas fa-photo-video me-2 ca-text-primary"></i>@Localizer["Admin_ImageVideo"]</h3>
                    </div>
                    <div class="ca-card-body">
                        <div class="mb-3">
                            <label class="form-label">@Localizer["Admin_SlideType"]</label>
                            <select name="Tur" id="turSelect" class="form-select" onchange="toggleMediaFields()">
                                <option value="Resim" selected="@(!isVideoTur)">@Localizer["Admin_Resim"]</option>
                                <option value="Video" selected="@(isVideoTur)">@Localizer["Admin_Video"]</option>
                            </select>
                        </div>

                        @if (!string.IsNullOrEmpty(Model.ResimUrl))
                        {
                            <div class="alert alert-secondary d-flex align-items-center gap-2 mb-3">
                                <i class="fas fa-image text-muted"></i>
                                <div>
                                    <strong>@Localizer["Admin_CurrentImage"]:</strong> @Model.ResimUrl
                                    <div class="form-text">@Localizer["Admin_NewImageReplacesCurrentHelp"]</div>
                                    <label class="form-check-label mt-1">
                                        <input type="checkbox" name="ResimSil" value="true" class="form-check-input" /> @Localizer["Admin_DeleteCurrentImage"]
                                    </label>
                                </div>
                            </div>
                            <div class="mb-3">
                                <img src="@Model.ResimUrl" class="img-thumbnail" style="max-height:150px;" alt='@Localizer["Admin_CurrentImage"]' />
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(Model.VideoUrl))
                        {
                            <div class="alert alert-secondary d-flex align-items-center gap-2 mb-3">
                                <i class="fas fa-video text-muted"></i>
                                <div>
                                    <strong>@Localizer["Admin_CurrentVideo"]:</strong> @Model.VideoUrl
                                    <div class="form-text">@Localizer["Admin_NewVideoReplacesCurrentHelp"]</div>
                                    <label class="form-check-label mt-1">
                                        <input type="checkbox" name="VideoSil" value="true" class="form-check-input" /> @Localizer["Admin_DeleteCurrentVideo"]
                                    </label>
                                </div>
                            </div>
                            <div class="mb-3">
                                <video src="@Model.VideoUrl" controls style="max-height:150px;border-radius:8px;"></video>
                            </div>
                        }

                        <div id="resimYukleme" class="mb-3">
                            <label class="form-label">@Localizer["Admin_UploadNewImage"]</label>
                            <input type="file" name="Resim" id="resimInput" class="form-control" accept="image/*" onchange="previewResim(this)" />
                            <div class="form-text">@Localizer["Admin_ImageFormatsHelp"]</div>
                            <div id="resimOnizleme" class="d-none mt-2">
                                <img src="" id="resimPreviewImg" class="img-thumbnail" style="max-height:200px;" alt='@Localizer["Admin_Preview"]' />
                            </div>
                        </div>

                        <div id="videoYukleme" class="@(isVideoTur ? "" : "d-none") mb-3">
                            <label class="form-label">@Localizer["Admin_UploadNewVideo"]</label>
                            <input type="file" name="Video" id="videoInput" class="form-control" accept="video/mp4,video/webm" onchange="previewVideo(this)" />
                            <div class="form-text">@Localizer["Admin_VideoFormatsHelp"]</div>
                            <div id="videoOnizleme" class="d-none mt-2">
                                <video src="" id="videoPreviewTag" controls style="max-height:200px;border-radius:8px;"></video>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <label class="form-label">@Localizer["Admin_OrImageUrl"]</label>
                                <input type="url" name="ResimUrl" value="@Model.ResimUrl" class="form-control" placeholder="https://..." />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">@Localizer["Admin_OrVideoUrl"]</label>
                                <input type="url" name="VideoUrl" value="@Model.VideoUrl" class="form-control" placeholder="https://..." />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="ca-card">
                    <div class="ca-card-header">
                        <h3 class="ca-card-title"><i class="fas fa-cog me-2 ca-text-primary"></i>@Localizer["Admin_Ayarlar"]</h3>
                    </div>
                    <div class="ca-card-body">
                        <div class="mb-3">
                            <label class="form-label">@Localizer["Admin_Sira"]</label>
                            <input type="number" name="Sira" value="@Model.Sira" class="form-control" min="1" />
                            <div class="form-text">@Localizer["Admin_SortSmallNumberFirst"]</div>
                        </div>

                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <input type="checkbox" name="AktifMi" value="true" class="form-check-input" id="aktifMi" @(Model.AktifMi ? "checked" : "") />
                                <label class="form-check-label" for="aktifMi">@Localizer["Admin_Aktif"]</label>
                            </div>
                            <div class="form-text">@Localizer["Admin_InactiveSlideHiddenHelp"]</div>
                        </div>
                    </div>
                </div>

                <div class="ca-card">
                    <div class="ca-card-header">
                        <h3 class="ca-card-title"><i class="fas fa-eye me-2 ca-text-primary"></i>@Localizer["Admin_Preview"]</h3>
                    </div>
                    <div class="ca-card-body">
                        <div id="livePreview" class="bg-dark rounded p-2 text-center">
                            @if (!string.IsNullOrEmpty(Model.VideoUrl))
                            {
                                <video src="@Model.VideoUrl" controls style="max-height:150px;border-radius:8px;"></video>
                            }
                            else if (!string.IsNullOrEmpty(Model.ResimUrl))
                            {
                                <img src="@Model.ResimUrl" class="img-fluid rounded" style="max-height:150px;" alt='@Localizer["Admin_Preview"]' />
                            }
                            else
                            {
                                <div class="text-muted py-4">
                                    <i class="fas fa-image fa-2x mb-2"></i>
                                    <div class="small">@Localizer["Admin_PreviewVisibleAfterUpload"]</div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-4">
            <button type="submit" class="btn btn-primary">
                <i class="fas fa-save me-1"></i> @Localizer["Admin_Kaydet"]
            </button>
            <a href="@Url.Action("Index", "Slayt")" class="btn btn-secondary ms-2">@Localizer["Admin_Iptal"]</a>
        </div>
    </form>
</div>

@section Scripts {
<script>
function toggleMediaFields() {
    var tur = document.getElementById('turSelect').value;
    document.getElementById('resimYukleme').classList.toggle('d-none', tur === 'Video');
    document.getElementById('videoYukleme').classList.toggle('d-none', tur === 'Resim');
}

function previewResim(input) {
    var preview = document.getElementById('resimPreviewImg');
    var container = document.getElementById('resimOnizleme');
    if (input.files && input.files[0]) {
        var reader = new FileReader();
        reader.onload = function(e) {
            preview.src = e.target.result;
            container.classList.remove('d-none');
        };
        reader.readAsDataURL(input.files[0]);
    }
}

function previewVideo(input) {
    var preview = document.getElementById('videoPreviewTag');
    var container = document.getElementById('videoOnizleme');
    if (input.files && input.files[0]) {
        var reader = new FileReader();
        reader.onload = function(e) {
            preview.src = e.target.result;
            container.classList.remove('d-none');
        };
        reader.readAsDataURL(input.files[0]);
    }
}
</script>
}